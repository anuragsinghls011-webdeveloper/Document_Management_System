        <div class="absolute inset-0 z-0 opacity-50">
            <div class="particle" style="width: 2px; height: 2px; top: 10%; left: 15%; animation-delay: -2s;"></div>
            <div class="particle" style="width: 3px; height: 3px; top: 25%; left: 80%; animation-delay: -5s;"></div>
            <div class="particle" style="width: 1px; height: 1px; top: 70%; left: 50%; animation-delay: -8s;"></div>
            <div class="particle" style="width: 2px; height: 2px; top: 80%; left: 20%; animation-delay: -12s;"></div>
            <div class="particle" style="width: 3px; height: 3px; top: 50%; left: 95%; animation-delay: -15s;"></div>
            <div class="particle" style="width: 2px; height: 2px; top: 35%; left: 40%; animation-delay: -3s;"></div>
            <div class="particle" style="width: 1px; height: 1px; top: 60%; left: 70%; animation-delay: -10s;"></div>
            <div class="particle" style="width: 3px; height: 3px; top: 15%; left: 55%; animation-delay: -7s;"></div>
            <div class="particle" style="width: 2px; height: 2px; top: 90%; left: 85%; animation-delay: -18s;"></div>
            <div class="particle" style="width: 1px; height: 1px; top: 45%; left: 10%; animation-delay: -14s;"></div>
        </div>

        <!-- Header -->
        <header class="fixed top-0 left-0 right-0 z-40" style="background: rgba(10,16,42,0.6); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); border-bottom: 1px solid rgba(56,95,226,0.15);">
            <nav class="container mx-auto px-6 py-4 flex justify-between items-center">
                <!-- Logo -->
                <a href="/" class="flex items-center space-x-2 border-2 border-gray-500/50 rounded-md p-2 hover:border-blue-400/60 transition-colors duration-300">
                     <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="text-white">
                        <path d="M12 2L2 7V17L12 22L22 17V7L12 2Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        <path d="M2 7L12 12L22 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        <path d="M12 22V12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        <path d="M17 4.5L7 9.5" stroke="currentColor" stroke-width="1.5"/>
                    </svg>
                    <span class="text-white font-bold text-sm">KMRL</span>
                </a>

                <!-- Navigation Links (Desktop) -->
                <div class="desktop-nav hidden md:flex space-x-10 text-gray-400 font-semibold text-sm">
                    <a href="#about" class="nav-link">ABOUT</a>
                    <a href="/dashboard" class="nav-link">DASHBOARD</a>
                    <a href="#contact" class="nav-link">CONTACT US</a>
                </div>

                <!-- Auth Buttons (Desktop) -->
                <div class="desktop-auth hidden md:flex items-center gap-3">
                    <a href="/register" class="login-btn border border-gray-500/60 rounded-md px-6 py-2 text-gray-300 font-semibold text-sm">
                        Register
