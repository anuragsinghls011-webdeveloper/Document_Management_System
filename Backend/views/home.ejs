            </div>

            <div class="mt-12 w-full max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-8 items-center z-10 px-4">
                <!-- Left Card -->
                <div class="card-bg rounded-2xl p-6 md:p-8 space-y-8 h-full reveal reveal-delay-1">
                    <div class="flex items-center space-x-4">
                        <div class="feature-icon-ring bg-blue-900/50 p-3 rounded-lg border border-blue-600/50">
