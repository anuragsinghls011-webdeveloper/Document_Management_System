          </div>
          <article class="panel">
            <div class="insights-list">
              <div class="insight-item">
                <div class="insight-icon"><i data-feather="lock"></i></div>
                <div><p class="insight-title">Policy guardrails</p><p class="insight-copy">Approval routing is aligned with document category and user role.</p></div>
              </div>
              <div class="insight-item">
                <div class="insight-icon"><i data-feather="sliders"></i></div>
                <div><p class="insight-title">AI confidence threshold</p><p class="insight-copy">Documents below 86% confidence are routed to manual review.</p></div>
              </div>
            </div>
          </article>
        </section>
      </main>
    </div>
  </div>

  <div id="upload-modal" class="modal hidden" role="dialog" aria-modal="true" aria-labelledby="uploadTitle">
    <div class="modal-content">
      <div class="modal-head">
        <div>
          <h2 id="uploadTitle" class="modal-title">Upload New Document</h2>
          <p class="panel-subtitle">AI classification starts as soon as the file lands.</p>
        </div>
        <button id="close-upload-modal-btn" class="icon-button" type="button" aria-label="Close upload">
          <i data-feather="x"></i>
        </button>
      </div>
      <div class="modal-body">
        <div id="dropzone" class="dropzone">
          <div>
            <i data-feather="upload-cloud" style="width: 48px; height: 48px; margin: 0 auto 14px; color: var(--cyan);"></i>
            <p style="margin: 0; color: white; font-weight: 800;">Drop documents here</p>
            <p class="panel-subtitle" style="margin-top: 8px;">PDF, DOCX, XLSX, and scanned images up to 10MB.</p>
          </div>
          <input id="file-input" class="hidden" type="file" multiple>
        </div>
        <div id="upload-progress-container" style="margin-top: 14px;"></div>
      </div>
    </div>
  </div>

  <div id="ai-search-modal" class="modal hidden" role="dialog" aria-modal="true" aria-labelledby="aiSearchTitle">
    <div class="modal-content">
      <div class="modal-head">
        <div>
          <h2 id="aiSearchTitle" class="modal-title">AI Command Search</h2>
          <p class="panel-subtitle">Try: "Find all pending finance invoices from March."</p>
        </div>
        <button id="closeSearchModal" class="icon-button" type="button" aria-label="Close AI search">
          <i data-feather="x"></i>
        </button>
      </div>
      <div class="modal-body">
        <input id="aiSearchInput" class="search-modal-input" type="text" autocomplete="off" placeholder="Ask a natural language document question">
        <div id="aiSuggestions" class="suggestions"></div>
      </div>
    </div>
  </div>

  <aside id="previewDrawer" class="drawer" aria-hidden="true">
    <div class="drawer-panel">
      <div class="panel-header">
        <div>
          <h2 id="previewTitle" class="panel-title">Document Preview</h2>
          <p id="previewMeta" class="panel-subtitle"></p>
        </div>
        <button id="closePreviewDrawer" class="icon-button" type="button" aria-label="Close preview">
          <i data-feather="x"></i>
        </button>
      </div>
      <div id="previewContent" class="insights-list"></div>
    </div>
  </aside>

  <script>
    feather.replace();

    const appShell = document.getElementById("appShell");
    const sidebar = document.getElementById("sidebar");
    const sidebarToggle = document.getElementById("sidebar-toggle");
    const mobileMenu = document.getElementById("mobileMenu");
    const sidebarNav = document.getElementById("sidebar-nav");
    const pageContents = document.querySelectorAll(".page-content");
    const searchInput = document.getElementById("searchInput");
    const themeToggle = document.getElementById("theme-toggle");
    const uploadModal = document.getElementById("upload-modal");
    const uploadButtons = [
      document.getElementById("quickUploadBtn"),
      document.getElementById("heroUploadBtn"),
      document.getElementById("upload-btn")
    ].filter(Boolean);
    const closeUploadModalBtn = document.getElementById("close-upload-modal-btn");
    const dropzone = document.getElementById("dropzone");
    const fileInput = document.getElementById("file-input");
    const uploadProgressContainer = document.getElementById("upload-progress-container");
    const aiSearchModal = document.getElementById("ai-search-modal");
    const aiSearchInput = document.getElementById("aiSearchInput");
    const aiSuggestions = document.getElementById("aiSuggestions");
    const closeSearchModal = document.getElementById("closeSearchModal");
    const documentsTableBody = document.getElementById("documents-table-body");
    const dashboardDocumentsBody = document.getElementById("dashboard-documents-body");
    const documentsPagination = document.getElementById("documentsPagination");
    const previewDrawer = document.getElementById("previewDrawer");
    const closePreviewDrawer = document.getElementById("closePreviewDrawer");
    const activityPopover = document.getElementById("activityPopover");
    const activityFeedBtn = document.getElementById("activityFeedBtn");
    const notificationBtn = document.getElementById("notificationBtn");

    const state = {
      documents: [],
      visibleDocuments: [],
      stats: { total: 0, today: 0, pending: 0, archived: 0, monthly: Array(12).fill(0) },
      activities: [],
      page: 1,
      pageSize: 7,
      sortKey: "createdAt",
      sortDirection: "desc",
      searchResults: []
    };

    const workflowItems = [
      { id: "doc-1", title: "Q3_Financial_Report.pdf", type: "PDF", status: "pending", priority: "High", aiConfidence: 98, assignee: "AS" },
      { id: "doc-2", title: "Metro_Safety_Audit_v2.docx", type: "DOCX", status: "processing", priority: "Medium", aiConfidence: 87, assignee: "JD" },
      { id: "doc-3", title: "Vendor_Contract_778.pdf", type: "PDF", status: "review", priority: "High", aiConfidence: 91, assignee: "AS" },
      { id: "doc-4", title: "HR_Policy_Update.pdf", type: "PDF", status: "approved", priority: "Low", aiConfidence: 99, assignee: "AI" },
      { id: "doc-5", title: "Invoice_9901.png", type: "IMG", status: "pending", priority: "Medium", aiConfidence: 76, assignee: "OP" }
    ];

    let activityChart;
    let analyticsChart;
    let debounceTimer;

    function escapeHtml(value) {
      return String(value || "")
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#039;");
    }

    function formatStatus(status) {
      return String(status || "pending").replace(/_/g, " ");
    }

    function getDocumentId(doc) {
      return doc._id || doc.id || doc.fileName;
    }

    function hashString(value) {
      return String(value || "").split("").reduce((acc, char) => acc + char.charCodeAt(0), 0);
    }

    function getConfidence(doc) {
      if (typeof doc.confidence === "number") return doc.confidence;
      const base = 82 + (hashString(doc.fileName) % 17);
      return Math.min(99, base);
    }

    function getCategory(doc) {
      const keywords = Array.isArray(doc.keywords) ? doc.keywords.filter(Boolean) : [];
      if (keywords.length) return keywords[0];
      const type = String(doc.fileType || "").toLowerCase();
      const name = String(doc.fileName || "").toLowerCase();
      if (name.includes("invoice") || name.includes("finance")) return "Finance";
      if (name.includes("contract") || name.includes("vendor")) return "Contracts";
      if (name.includes("audit") || name.includes("safety")) return "Compliance";
      if (name.includes("hr") || name.includes("policy")) return "Policy";
      if (type === "pdf") return "Knowledge";
      if (type === "xlsx") return "Spreadsheet";
      if (type === "docx") return "Document";
      return "General";
    }

    function formatDate(value) {
      if (!value) return "-";
      return new Date(value).toLocaleDateString(undefined, { month: "short", day: "numeric", year: "numeric" });
    }

    function relativeTime(value) {
      if (!value) return "Just now";
      const diff = Date.now() - new Date(value).getTime();
      const minutes = Math.max(1, Math.round(diff / 60000));
      if (minutes < 60) return `${minutes}m ago`;
      const hours = Math.round(minutes / 60);
      if (hours < 24) return `${hours}h ago`;
      return `${Math.round(hours / 24)}d ago`;
    }

    function setGreeting() {
      const hour = new Date().getHours();
      const label = hour < 12 ? "Good Morning" : hour < 17 ? "Good Afternoon" : "Good Evening";
      document.getElementById("greeting").textContent = `${label}, User`;
    }

    function toggleModal(modal, show) {
      modal.classList.toggle("hidden", !show);
      if (show) feather.replace();
    }

    function navigate(targetId) {
      document.querySelectorAll(".nav-link").forEach(link => {
        link.classList.toggle("active", link.dataset.target === targetId);
      });

      // Smooth cross-fade transition
      const currentPage = document.querySelector(".page-content:not(.hidden)");
      const target = document.getElementById(targetId);

      if (currentPage && currentPage !== target) {
        currentPage.classList.add("page-exiting");
        setTimeout(() => {
          pageContents.forEach(page => { page.classList.add("hidden"); page.classList.remove("page-exiting", "page-entering"); });
          if (target) {
            target.classList.remove("hidden");
            target.classList.add("page-entering");
          }
          requestAnimationFrame(() => {
            if (activityChart) activityChart.resize();
            if (analyticsChart) analyticsChart.resize();
          });
          feather.replace();
        }, 200);
      } else {
        pageContents.forEach(page => page.classList.add("hidden"));
        if (target) { target.classList.remove("hidden"); target.classList.add("page-entering"); }
        feather.replace();
      }

      if (window.innerWidth < 981) {
        sidebar.classList.remove("open");
        document.getElementById("sidebarBackdrop").classList.remove("active");
      }
      window.scrollTo({ top: 0, behavior: "smooth" });
    }

    sidebarToggle.addEventListener("click", () => {
      sidebar.classList.toggle("collapsed");
      appShell.classList.toggle("sidebar-collapsed");
    });

    mobileMenu.addEventListener("click", () => {
      sidebar.classList.add("open");
      document.getElementById("sidebarBackdrop").classList.add("active");
    });

    document.getElementById("sidebarBackdrop").addEventListener("click", () => {
      sidebar.classList.remove("open");
      document.getElementById("sidebarBackdrop").classList.remove("active");
    });

    document.addEventListener("click", event => {
      if (window.innerWidth < 981 && sidebar.classList.contains("open")) {
        const clickedInsideSidebar = sidebar.contains(event.target);
        const clickedMenu = mobileMenu.contains(event.target);
        if (!clickedInsideSidebar && !clickedMenu) {
          sidebar.classList.remove("open");
          document.getElementById("sidebarBackdrop").classList.remove("active");
        }
      }
    });

    // Scroll to top button
    const scrollTopBtn = document.getElementById("scrollTopBtn");
    window.addEventListener("scroll", () => {
      scrollTopBtn.classList.toggle("visible", window.scrollY > 400);
    }, { passive: true });

    scrollTopBtn.addEventListener("click", () => {
      window.scrollTo({ top: 0, behavior: "smooth" });
    });

    sidebarNav.addEventListener("click", event => {
      const link = event.target.closest(".nav-link");
      if (!link) return;
      event.preventDefault();
      navigate(link.dataset.target);
    });

    document.addEventListener("click", event => {
      const navButton = event.target.closest("[data-nav-target]");
      if (navButton) navigate(navButton.dataset.navTarget);
    });

    themeToggle.addEventListener("click", () => {
      document.body.classList.toggle("focus-theme");
      themeToggle.innerHTML = document.body.classList.contains("focus-theme")
        ? '<i data-feather="sun"></i>'
        : '<i data-feather="moon"></i>';
      feather.replace();
    });

    uploadButtons.forEach(button => {
      button.addEventListener("click", () => toggleModal(uploadModal, true));
    });

    closeUploadModalBtn.addEventListener("click", () => toggleModal(uploadModal, false));
    uploadModal.addEventListener("click", event => {
      if (event.target === uploadModal) toggleModal(uploadModal, false);
    });

    dropzone.addEventListener("click", () => fileInput.click());
    dropzone.addEventListener("dragover", event => {
      event.preventDefault();
      dropzone.classList.add("dropzone-active");
    });
    dropzone.addEventListener("dragleave", () => dropzone.classList.remove("dropzone-active"));
    dropzone.addEventListener("drop", event => {
      event.preventDefault();
      dropzone.classList.remove("dropzone-active");
      uploadFiles(event.dataTransfer.files);
    });
    fileInput.addEventListener("change", () => uploadFiles(fileInput.files));

    async function uploadFiles(files) {
      if (!files || !files.length) return;

      const formData = new FormData();
      Array.from(files).forEach(file => formData.append("documents", file));
      uploadProgressContainer.innerHTML = '<div class="insight-item"><div class="insight-icon"><i data-feather="upload-cloud"></i></div><div><p class="insight-title">Uploading documents</p><p class="insight-copy">AI intake will refresh automatically after upload.</p></div></div>';
      feather.replace();

      try {
        const res = await fetch("/documents/upload", {
          method: "POST",
          body: formData,
          credentials: "include"
        });

        if (!res.ok) {
          uploadProgressContainer.innerHTML = `<p class="panel-subtitle">Upload failed: ${escapeHtml(await res.text())}</p>`;
          return;
        }

        uploadProgressContainer.innerHTML = '<div class="insight-item"><div class="insight-icon"><i data-feather="check-circle"></i></div><div><p class="insight-title">Upload complete</p><p class="insight-copy">Dashboard intelligence has been refreshed.</p></div></div>';
        feather.replace();
        setTimeout(() => toggleModal(uploadModal, false), 650);
        fileInput.value = "";
        await Promise.all([loadDocuments(), loadDashboardStats(), loadRecentActivity()]);
      } catch (err) {
        console.error(err);
        uploadProgressContainer.innerHTML = '<p class="panel-subtitle">Upload failed. Please try again.</p>';
      }
    }

    function animateNumber(id, target, options = {}) {
      const element = document.getElementById(id);
      if (!element) return;
      const duration = options.duration || 850;
      const decimals = options.decimals || 0;
      const start = Number(element.textContent) || 0;
      const startTime = performance.now();

      function tick(now) {
        const progress = Math.min((now - startTime) / duration, 1);
        const eased = 1 - Math.pow(1 - progress, 3);
        const value = start + (target - start) * eased;
        element.textContent = decimals ? value.toFixed(decimals) : Math.round(value);
        if (progress < 1) requestAnimationFrame(tick);
      }

      requestAnimationFrame(tick);
    }

    async function loadDashboardStats() {
      try {
        const res = await fetch("/documents/stats", { credentials: "include" });
        if (res.ok) {
          state.stats = await res.json();
        }
      } catch (err) {
        console.error("Stats error", err);
      }

      updateMetrics();
      renderCharts(state.stats.monthly || Array(12).fill(0));
      renderHeatmap();
      renderInsights();
    }

    function updateMetrics() {
      const total = Number(state.stats.total || state.documents.length || 0);
      const pending = Number(state.stats.pending || state.documents.filter(doc => doc.status === "pending").length || 0);
      const archived = Number(state.stats.archived || state.documents.filter(doc => doc.status === "archived").length || 0);
      const today = Number(state.stats.today || 0);
      const processed = Math.max(total - pending, today);
      const activeWorkflows = workflowItems.filter(item => item.status !== "approved").length;
      const accuracy = total ? Math.min(99.3, 94.8 + Math.min(total, 12) * 0.18) : 96.8;

      animateNumber("totalDocs", total);
      animateNumber("aiProcessed", processed);
      animateNumber("pendingApproval", pending);
      animateNumber("activeWorkflows", activeWorkflows);
      animateNumber("archivedDocs", archived);
      animateNumber("accuracyRate", accuracy, { decimals: 1 });

      document.getElementById("heroProcessed").textContent = processed;
      document.getElementById("heroQueue").textContent = `${pending} approvals queued`;
      document.getElementById("heroConfidence").textContent = `${accuracy.toFixed(1)}%`;
      document.getElementById("analyticsDocs").textContent = total;
      document.getElementById("analyticsPending").textContent = pending;
      document.getElementById("analyticsArchived").textContent = archived;
    }

    function renderCharts(monthly) {
      const labels = ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];
      const routed = monthly.map((value, index) => Math.max(0, Math.round(value * 0.72 + (index % 3))));

      renderLineChart("activityChart", monthly, routed, chart => activityChart = chart, activityChart);
      renderLineChart("analyticsChart", monthly, routed, chart => analyticsChart = chart, analyticsChart);

      function renderLineChart(canvasId, primary, secondary, setter, existing) {
        const canvas = document.getElementById(canvasId);
        if (!canvas) return;
        if (existing) existing.destroy();
        const ctx = canvas.getContext("2d");
        const gradient = ctx.createLinearGradient(0, 0, 0, 320);
        gradient.addColorStop(0, "rgba(56, 189, 248, 0.28)");
        gradient.addColorStop(1, "rgba(56, 189, 248, 0)");
        const violetGradient = ctx.createLinearGradient(0, 0, 0, 320);
        violetGradient.addColorStop(0, "rgba(139, 92, 246, 0.22)");
        violetGradient.addColorStop(1, "rgba(139, 92, 246, 0)");

        const chart = new Chart(ctx, {
          type: "line",
          data: {
            labels,
            datasets: [
              {
                label: "Documents",
                data: primary,
                borderColor: "#38bdf8",
                backgroundColor: gradient,
                fill: true,
                tension: 0.42,
                pointRadius: 4,
                pointHoverRadius: 7,
                pointBackgroundColor: "#081120",
                pointBorderColor: "#22d3ee",
                pointBorderWidth: 2
              },
              {
                label: "AI routed",
                data: secondary,
                borderColor: "#8b5cf6",
                backgroundColor: violetGradient,
                fill: true,
                tension: 0.42,
                pointRadius: 3,
                pointHoverRadius: 6,
                pointBackgroundColor: "#081120",
                pointBorderColor: "#c4b5fd",
                pointBorderWidth: 2
              }
            ]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            animation: { duration: 900, easing: "easeOutQuart" },
            interaction: { intersect: false, mode: "index" },
            plugins: {
              legend: {
                labels: { color: "#cbd5e1", boxWidth: 10, usePointStyle: true }
              },
              tooltip: {
                backgroundColor: "rgba(15, 23, 42, 0.94)",
                borderColor: "rgba(148, 163, 184, 0.18)",
                borderWidth: 1,
                padding: 12,
                titleColor: "#f8fafc",
                bodyColor: "#cbd5e1"
              }
            },
            scales: {
              x: {
                grid: { color: "rgba(148, 163, 184, 0.06)" },
                ticks: { color: "#94a3b8" }
              },
              y: {
                beginAtZero: true,
                grid: { color: "rgba(148, 163, 184, 0.08)" },
                ticks: { color: "#94a3b8", precision: 0 }
              }
            }
          }
        });
        setter(chart);
      }
    }

    function renderHeatmap() {
      const grid = document.getElementById("heatmapGrid");
      if (!grid) return;
      const seed = state.documents.length + (state.stats.pending || 0);
      grid.innerHTML = Array.from({ length: 35 }, (_, index) => {
        const intensity = 0.11 + (((index * 13 + seed * 7) % 70) / 100);
        return `<span class="heat-cell" style="--heat: ${intensity.toFixed(2)}" title="${Math.round(intensity * 100)} activity score"></span>`;
      }).join("");
    }

    async function loadDocuments() {
      try {
        const res = await fetch("/documents/my", { credentials: "include" });
        if (!res.ok) return;
        state.documents = await res.json();
      } catch (err) {
        console.error("Documents error", err);
      }
      state.visibleDocuments = [...state.documents];
      state.page = 1;
      sortVisibleDocuments();
      renderDocuments();
      renderDashboardDocuments();
      renderApprovalQueue();
      updateMetrics();
      renderInsights();
      renderHeatmap();
      if (!state.activities.length) renderRecentActivity();
      renderAISuggestions(aiSearchInput.value);
    }

    function sortVisibleDocuments() {
      const direction = state.sortDirection === "asc" ? 1 : -1;
      state.visibleDocuments.sort((a, b) => {
        const key = state.sortKey;
        const aValue = key === "confidence" ? getConfidence(a) : (a[key] || "");
        const bValue = key === "confidence" ? getConfidence(b) : (b[key] || "");
        if (key === "createdAt") return (new Date(aValue).getTime() - new Date(bValue).getTime()) * direction;
        return String(aValue).localeCompare(String(bValue)) * direction;
      });
    }

    function renderDocuments() {
      const start = (state.page - 1) * state.pageSize;
      const docs = state.visibleDocuments.slice(start, start + state.pageSize);
      documentsTableBody.innerHTML = renderDocumentRows(docs, true);
      renderPagination();
      feather.replace();
    }

    function renderDashboardDocuments() {
      dashboardDocumentsBody.innerHTML = renderDocumentRows(state.documents.slice(0, 5), false);
      feather.replace();
    }

    function renderDocumentRows(docs, includeEmpty) {
      if (!docs.length) {
        return `<tr><td colspan="8" class="empty-state">${includeEmpty ? "No documents match this view." : "Upload documents to activate the intelligence layer."}</td></tr>`;
      }

      return docs.map(doc => {
        const id = escapeHtml(getDocumentId(doc));
        const confidence = getConfidence(doc);
        const status = formatStatus(doc.status);
        const statusClass = escapeHtml(doc.status || "pending");
        const type = escapeHtml(String(doc.fileType || "FILE").toUpperCase());
        const category = escapeHtml(getCategory(doc));
        const fileName = escapeHtml(doc.fileName);
        const path = escapeHtml(doc.filePath || "");

        return `
          <tr>
            <td>
              <div class="doc-name">
                <span class="file-glyph"><i data-feather="file-text"></i></span>
                <span>
                  <button class="doc-title" type="button" data-preview="${id}">${fileName}</button>
                  <span class="doc-sub">${type} &middot; AI tagged</span>
                </span>
              </div>
            </td>
            <td><span class="badge"><i data-feather="tag"></i>${category}</span></td>
            <td> You </td>
            <td><span class="badge ${statusClass}">${status}</span></td>
            <td><span class="badge ${statusClass}">${status === "approved" ? "Approved" : status === "rejected" ? "Rejected" : "Needs review"}</span></td>
            <td>${formatDate(doc.updatedAt || doc.createdAt)}</td>
            <td>
              <div class="confidence">
                <span>${confidence}%</span>
                <span class="confidence-bar"><span style="width: ${confidence}%;"></span></span>
              </div>
            </td>
            <td>
              <div class="row-actions">
                <button class="icon-button" type="button" data-preview="${id}" title="Preview"><i data-feather="eye"></i></button>
                <a class="icon-button" href="/${path}" target="_blank" rel="noreferrer" title="Open"><i data-feather="external-link"></i></a>
              </div>
            </td>
          </tr>
        `;
      }).join("");
    }

    function renderPagination() {
      const totalPages = Math.max(1, Math.ceil(state.visibleDocuments.length / state.pageSize));
      documentsPagination.innerHTML = `
        <button class="button" type="button" data-page="prev" ${state.page === 1 ? "disabled" : ""}><i data-feather="chevron-left"></i>Prev</button>
        <span class="panel-subtitle">Page ${state.page} of ${totalPages}</span>
        <button class="button" type="button" data-page="next" ${state.page === totalPages ? "disabled" : ""}>Next<i data-feather="chevron-right"></i></button>
      `;
    }

    documentsPagination.addEventListener("click", event => {
      const button = event.target.closest("[data-page]");
      if (!button) return;
      const totalPages = Math.max(1, Math.ceil(state.visibleDocuments.length / state.pageSize));
      if (button.dataset.page === "prev") state.page = Math.max(1, state.page - 1);
      if (button.dataset.page === "next") state.page = Math.min(totalPages, state.page + 1);
      renderDocuments();
    });

    document.addEventListener("click", event => {
      const previewButton = event.target.closest("[data-preview]");
      if (previewButton) {
        const doc = state.documents.find(item => String(getDocumentId(item)) === String(previewButton.dataset.preview));
        if (doc) openPreview(doc);
      }

      const sortButton = event.target.closest("[data-sort]");
      if (sortButton) {
        const key = sortButton.dataset.sort;
        if (state.sortKey === key) {
          state.sortDirection = state.sortDirection === "asc" ? "desc" : "asc";
        } else {
          state.sortKey = key;
          state.sortDirection = key === "fileName" ? "asc" : "desc";
        }
        sortVisibleDocuments();
        renderDocuments();
      }
    });

    closePreviewDrawer.addEventListener("click", closePreview);
    previewDrawer.addEventListener("click", event => {
      if (event.target === previewDrawer) closePreview();
    });

    function openPreview(doc) {
      const confidence = getConfidence(doc);
      document.getElementById("previewTitle").textContent = doc.fileName || "Document";
      document.getElementById("previewMeta").textContent = `${String(doc.fileType || "file").toUpperCase()} - ${formatDate(doc.createdAt)} - ${confidence}% AI confidence`;
      document.getElementById("previewContent").innerHTML = `
        <div class="insight-item">
          <div class="insight-icon"><i data-feather="tag"></i></div>
          <div><p class="insight-title">AI Category</p><p class="insight-copy">${escapeHtml(getCategory(doc))}</p></div>
        </div>
        <div class="insight-item">
          <div class="insight-icon"><i data-feather="activity"></i></div>
          <div><p class="insight-title">Workflow Status</p><p class="insight-copy">${escapeHtml(formatStatus(doc.status))}</p></div>
        </div>
        <div class="insight-item">
          <div class="insight-icon"><i data-feather="message-square"></i></div>
          <div><p class="insight-title">AI Summary</p><p class="insight-copy">${escapeHtml(doc.summary || "No summary available yet. OCR and AI enrichment can populate this area after processing.")}</p></div>
        </div>
        <div class="insight-item">
          <div class="insight-icon"><i data-feather="download"></i></div>
          <div><p class="insight-title">Document Link</p><p class="insight-copy"><a href="/${escapeHtml(doc.filePath || "")}" target="_blank" rel="noreferrer" style="color: var(--cyan);">Open original file</a></p></div>
        </div>
      `;
      previewDrawer.classList.add("open");
      previewDrawer.setAttribute("aria-hidden", "false");
      feather.replace();
    }

    function closePreview() {
      previewDrawer.classList.remove("open");
      previewDrawer.setAttribute("aria-hidden", "true");
    }

    const docSearchInput = document.getElementById("docSearchInput");
    const statusFilter = document.getElementById("statusFilter");
    const typeFilter = document.getElementById("typeFilter");
    const dateFilter = document.getElementById("dateFilter");
    const resetFiltersBtn = document.getElementById("resetFiltersBtn");

    [docSearchInput, statusFilter, typeFilter, dateFilter].forEach(input => {
      input.addEventListener(input.tagName === "SELECT" ? "change" : "input", triggerSearch);
    });

    resetFiltersBtn.addEventListener("click", () => {
      docSearchInput.value = "";
      statusFilter.value = "all";
      typeFilter.value = "all";
      dateFilter.value = "";
      state.visibleDocuments = [...state.documents];
      state.page = 1;
      sortVisibleDocuments();
      renderDocuments();
    });

    function triggerSearch() {
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(async () => {
        const q = docSearchInput.value.trim();
        const status = statusFilter.value;
        const type = typeFilter.value;
        const date = dateFilter.value;

        if (!q && status === "all" && type === "all" && !date) {
          state.visibleDocuments = [...state.documents];
          state.page = 1;
          sortVisibleDocuments();
          renderDocuments();
          return;
        }

        const params = new URLSearchParams();
        if (q) params.append("q", q);
        if (status && status !== "all") params.append("status", status);
        if (type && type !== "all") params.append("type", type);
        if (date) params.append("date", date);

        try {
          const res = await fetch(`/documents/search?${params.toString()}`, { credentials: "include" });
          state.visibleDocuments = res.ok ? await res.json() : [];
          state.page = 1;
          sortVisibleDocuments();
          renderDocuments();
        } catch (err) {
          console.error("Search/filter error", err);
        }
      }, 260);
    }

    function renderInsights() {
      const pending = state.stats.pending || state.documents.filter(doc => doc.status === "pending").length;
      const lowConfidence = state.documents.filter(doc => getConfidence(doc) < 88).length;
      const insights = [
        {
          icon: "zap",
          title: "Automation suggestion",
          copy: pending > 0 ? `${pending} pending documents can be grouped into a priority review sprint.` : "Approval queue is clear. Keep auto-routing active for new uploads."
        },
        {
          icon: "alert-triangle",
          title: "Document anomaly",
          copy: lowConfidence ? `${lowConfidence} documents have confidence below 88% and should be checked manually.` : "No low-confidence anomalies detected in the current workspace."
        },
        {
          icon: "git-branch",
          title: "Workflow bottleneck",
          copy: "Review lane has the highest handoff time. AI suggests routing finance files directly to approvers."
        },
        {
          icon: "clock",
          title: "Approval delay",
          copy: "Escalate files that remain pending for more than 48 hours to maintain SLA health."
        }
      ];

      const markup = insights.map(item => `
        <div class="insight-item">
          <div class="insight-icon"><i data-feather="${item.icon}"></i></div>
          <div><p class="insight-title">${escapeHtml(item.title)}</p><p class="insight-copy">${escapeHtml(item.copy)}</p></div>
        </div>
      `).join("");

      document.getElementById("insightsList").innerHTML = markup;
      document.getElementById("insightsPageList").innerHTML = markup;
      feather.replace();
    }

    document.getElementById("refreshInsightsBtn").addEventListener("click", renderInsights);

    async function loadRecentActivity() {
      try {
        const res = await fetch("/activities/recent", { credentials: "include" });
        state.activities = res.ok ? await res.json() : [];
      } catch (err) {
        console.error("Recent activity error", err);
      }
      renderRecentActivity();
    }

    function renderRecentActivity() {
      const fallback = state.documents.slice(0, 5).map(doc => ({
        user: { username: "AI Intake" },
        action: "uploaded and queued",
        entityName: doc.fileName,
        entityType: "document",
        createdAt: doc.createdAt
      }));
      const activities = state.activities.length ? state.activities : fallback;
      const markup = activities.length ? activities.map(activity => {
        const actor = activity.user?.username || "User";
        const initials = actor.split(/\s+/).map(part => part[0]).join("").slice(0, 2).toUpperCase() || "AI";
        return `
          <div class="timeline-item">
            <div class="timeline-avatar">${escapeHtml(initials)}</div>
            <div>
              <p class="timeline-title"><strong>${escapeHtml(actor)}</strong> ${escapeHtml(activity.action || "updated")} <span style="color: var(--cyan);">${escapeHtml(activity.entityName || "")}</span></p>
              <div class="timeline-meta">
                <span class="badge">${escapeHtml(activity.entityType || "workflow")}</span>
                <span>${relativeTime(activity.createdAt)}</span>
              </div>
            </div>
          </div>
        `;
      }).join("") : '<div class="empty-state">No recent activity yet.</div>';

      document.getElementById("activityList").innerHTML = markup;
      document.getElementById("activityPopoverList").innerHTML = markup;
      feather.replace();
    }

    activityFeedBtn.addEventListener("click", () => activityPopover.classList.toggle("hidden"));
    notificationBtn.addEventListener("click", () => activityPopover.classList.toggle("hidden"));

    document.addEventListener("click", event => {
      const clickedActivity = activityPopover.contains(event.target) || activityFeedBtn.contains(event.target) || notificationBtn.contains(event.target);
      if (!clickedActivity) activityPopover.classList.add("hidden");
    });

    function renderApprovalQueue() {
      const approvals = state.documents.filter(doc => ["pending", "processing", "review", "changes_requested"].includes(doc.status));
      document.getElementById("approvalQueue").innerHTML = approvals.length ? approvals.map(doc => `
        <div class="timeline-item">
          <div class="timeline-avatar">${String(getCategory(doc)).slice(0, 2).toUpperCase()}</div>
          <div>
            <p class="timeline-title">${escapeHtml(doc.fileName)}</p>
            <div class="timeline-meta">
              <span class="badge ${escapeHtml(doc.status)}">${escapeHtml(formatStatus(doc.status))}</span>
              <span>${getConfidence(doc)}% AI confidence</span>
              <button class="button" type="button" data-preview="${escapeHtml(getDocumentId(doc))}"><i data-feather="eye"></i>Preview</button>
            </div>
          </div>
        </div>
      `).join("") : '<div class="empty-state">No approval items are waiting right now.</div>';
      feather.replace();
    }

    function renderKanban() {
      const columns = [
        { key: "pending", title: "Pending", color: "var(--orange)" },
        { key: "processing", title: "AI Processing", color: "var(--cyan)" },
        { key: "review", title: "In Review", color: "var(--violet)" },
        { key: "approved", title: "Approved", color: "var(--emerald)" }
      ];

      document.getElementById("kanbanBoard").innerHTML = columns.map(column => {
        const items = workflowItems.filter(item => item.status === column.key);
        return `
          <section class="kanban-column">
            <div class="kanban-head">
              <div class="kanban-title"><span class="status-dot" style="background: ${column.color};"></span>${column.title}</div>
              <span class="badge">${items.length}</span>
            </div>
            <div class="kanban-dropzone" data-status="${column.key}">
              ${items.map(createKanbanCard).join("")}
            </div>
          </section>
        `;
      }).join("");
      feather.replace();
    }

    function createKanbanCard(item) {
      const progress = item.status === "pending" ? 16 : item.status === "processing" ? 46 : item.status === "review" ? 74 : 100;
      return `
        <article class="kanban-card" draggable="true" data-workflow-id="${item.id}">
          <div class="metric-top">
            <span class="badge ${item.priority === "High" ? "rejected" : item.priority === "Medium" ? "pending" : "approved"}">${item.priority}</span>
            <button class="icon-button" type="button" title="More"><i data-feather="more-horizontal"></i></button>
          </div>
          <p class="timeline-title" style="margin-top: 12px;">${escapeHtml(item.title)}</p>
          <div class="timeline-meta">
            <span class="badge"><i data-feather="file-text"></i>${escapeHtml(item.type)}</span>
            <span>${item.aiConfidence}% AI match</span>
          </div>
          <div class="metric-top" style="margin-top: 13px;">
            <span class="panel-subtitle">Assigned to ${escapeHtml(item.assignee)}</span>
            <span class="avatar" style="width: 28px; height: 28px; border-radius: 10px; font-size: 0.7rem;">${escapeHtml(item.assignee.slice(0, 2))}</span>
          </div>
          <div class="progress-track" style="margin-top: 12px;"><span style="width: ${progress}%;"></span></div>
        </article>
      `;
    }

    document.getElementById("kanbanBoard").addEventListener("dragstart", event => {
      const card = event.target.closest(".kanban-card");
      if (!card) return;
      card.classList.add("dragging");
      event.dataTransfer.setData("text/plain", card.dataset.workflowId);
    });

    document.getElementById("kanbanBoard").addEventListener("dragend", event => {
      const card = event.target.closest(".kanban-card");
      if (card) card.classList.remove("dragging");
      document.querySelectorAll(".kanban-dropzone").forEach(zone => zone.classList.remove("is-over"));
    });

    document.getElementById("kanbanBoard").addEventListener("dragover", event => {
      const zone = event.target.closest(".kanban-dropzone");
      if (!zone) return;
      event.preventDefault();
      zone.classList.add("is-over");
    });

    document.getElementById("kanbanBoard").addEventListener("dragleave", event => {
      const zone = event.target.closest(".kanban-dropzone");
      if (zone) zone.classList.remove("is-over");
    });

    document.getElementById("kanbanBoard").addEventListener("drop", event => {
      const zone = event.target.closest(".kanban-dropzone");
      if (!zone) return;
      event.preventDefault();
      const id = event.dataTransfer.getData("text/plain");
      const item = workflowItems.find(entry => entry.id === id);
      if (item) {
        item.status = zone.dataset.status;
        renderKanban();
        updateMetrics();
      }
    });

    function openSearchModal(query = "") {
      toggleModal(aiSearchModal, true);
      aiSearchInput.value = query;
      renderAISuggestions(query);
      setTimeout(() => aiSearchInput.focus(), 40);
    }

    function closeAISearch() {
      toggleModal(aiSearchModal, false);
      searchInput.value = "";
    }

    searchInput.addEventListener("focus", () => openSearchModal(searchInput.value));
    searchInput.addEventListener("click", () => openSearchModal(searchInput.value));
    document.getElementById("heroSearchBtn").addEventListener("click", () => openSearchModal());
    document.getElementById("assistantQuickAction").addEventListener("click", () => openSearchModal());
    document.getElementById("smartSearchOpenBtn").addEventListener("click", () => openSearchModal());
    closeSearchModal.addEventListener("click", closeAISearch);
    aiSearchModal.addEventListener("click", event => {
      if (event.target === aiSearchModal) closeAISearch();
    });

    document.addEventListener("keydown", event => {
      if ((event.ctrlKey || event.metaKey) && event.key.toLowerCase() === "k") {
        event.preventDefault();
        openSearchModal();
      }
      if (event.key === "Escape") {
        closeAISearch();
        closePreview();
        toggleModal(uploadModal, false);
      }
    });

    aiSearchInput.addEventListener("input", () => renderAISuggestions(aiSearchInput.value));
    aiSearchInput.addEventListener("keydown", event => {
      if (event.key === "ArrowDown") {
        event.preventDefault();
        const first = aiSuggestions.querySelector("button");
        if (first) first.focus();
      }
      if (event.key === "Enter") {
        event.preventDefault();
        const first = aiSuggestions.querySelector("button");
        if (first) first.click();
      }
    });

    document.querySelectorAll(".smart-prompt").forEach(button => {
      button.addEventListener("click", () => openSearchModal(button.dataset.query));
    });

    function renderAISuggestions(query = "") {
      const normalized = query.trim().toLowerCase();
      let matches = state.documents.filter(doc => {
        const keywords = Array.isArray(doc.keywords) ? doc.keywords : [];
        const haystack = [doc.fileName, doc.fileType, doc.status, getCategory(doc), ...keywords].join(" ").toLowerCase();
        return !normalized || haystack.includes(normalized) || normalized.split(/\s+/).some(token => haystack.includes(token));
      }).slice(0, 5);

      if (!matches.length && state.documents.length) matches = state.documents.slice(0, 3);

      const promptSuggestions = [
        "Find all pending finance invoices from March.",
        "Show documents with low AI confidence.",
        "Which approvals are delayed today?"
      ];

      const docsMarkup = matches.map(doc => `
        <button class="suggestion-button" type="button" data-preview="${escapeHtml(getDocumentId(doc))}">
          <span class="file-glyph"><i data-feather="file-text"></i></span>
          <span>
            <strong class="doc-title">${escapeHtml(doc.fileName)}</strong>
            <span class="doc-sub">${escapeHtml(getCategory(doc))} - ${escapeHtml(formatStatus(doc.status))} - ${getConfidence(doc)}% confidence</span>
          </span>
          <i data-feather="arrow-up-right"></i>
        </button>
      `).join("");

      const promptsMarkup = promptSuggestions.map(prompt => `
        <button class="suggestion-button" type="button" data-search-prompt="${escapeHtml(prompt)}">
          <span class="file-glyph"><i data-feather="command"></i></span>
          <span>
            <strong class="doc-title">${escapeHtml(prompt)}</strong>
            <span class="doc-sub">Semantic query suggestion</span>
          </span>
          <i data-feather="send"></i>
        </button>
      `).join("");

      aiSuggestions.innerHTML = docsMarkup + promptsMarkup;
      feather.replace();
    }

    aiSuggestions.addEventListener("click", event => {
      const promptButton = event.target.closest("[data-search-prompt]");
      if (promptButton) {
        aiSearchInput.value = promptButton.dataset.searchPrompt;
        renderAISuggestions(aiSearchInput.value);
        return;
      }
      const previewButton = event.target.closest("[data-preview]");
      if (previewButton) {
        const doc = state.documents.find(item => String(getDocumentId(item)) === String(previewButton.dataset.preview));
        if (doc) {
          closeAISearch();
          openPreview(doc);
        }
      }
    });

    document.addEventListener("DOMContentLoaded", async () => {
      setGreeting();
      renderKanban();
      renderHeatmap();
      renderInsights();
      await Promise.all([loadDocuments(), loadDashboardStats(), loadRecentActivity()]);
    });
  </script>
</body>

</html>
