<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Analytics Dashboard | Document Management System</title>
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <!-- Icons -->
    <link href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css" rel="stylesheet">
    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <style>
        :root {
            /* Colors */
            --bg-color: #0b0f19;
            --surface-color: rgba(20, 27, 45, 0.6);
            --surface-border: rgba(255, 255, 255, 0.08);
            --primary-color: #6366f1;
            --primary-hover: #4f46e5;
            --secondary-color: #8b5cf6;
            --success-color: #10b981;
            --warning-color: #f59e0b;
            --danger-color: #ef4444;
            --text-main: #f8fafc;
            --text-muted: #94a3b8;
            --sidebar-width: 260px;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Outfit', sans-serif;
        }

        body {
            background-color: var(--bg-color);
            color: var(--text-main);
            display: flex;
            min-height: 100vh;
            overflow-x: hidden;
            /* Animated Background Blob */
            background-image:
                radial-gradient(circle at 15% 50%, rgba(99, 102, 241, 0.12), transparent 25%),
                radial-gradient(circle at 85% 30%, rgba(139, 92, 246, 0.12), transparent 25%);
        }

        /* Sidebar */
        .sidebar {
            width: var(--sidebar-width);
            background: var(--surface-color);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border-right: 1px solid var(--surface-border);
            padding: 1.5rem;
            display: flex;
            flex-direction: column;
            position: fixed;
            height: 100vh;
            z-index: 50;
            transition: all 0.3s ease;
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            font-size: 1.5rem;
            font-weight: 700;
            margin-bottom: 3rem;
            color: var(--text-main);
            text-decoration: none;
            background: linear-gradient(135deg, #a5b4fc 0%, #c4b5fd 100%);
            -webkit-background-clip: text;
            background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .logo i {
            background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
            -webkit-background-clip: text;
            background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .nav-links {
            list-style: none;
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }

        .nav-item {
            display: flex;
            align-items: center;
            gap: 1rem;
            padding: 0.875rem 1rem;
            border-radius: 0.75rem;
            color: var(--text-muted);
            text-decoration: none;
            font-weight: 500;
            transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
            position: relative;
            overflow: hidden;
        }

        .nav-item::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, rgba(99, 102, 241, 0.15), transparent);
            transform: translateX(-100%);
            transition: transform 0.3s ease;
            z-index: -1;
        }

        .nav-item:hover,
        .nav-item.active {
            color: var(--text-main);
            background: rgba(255, 255, 255, 0.03);
        }

        .nav-item:hover::before,
        .nav-item.active::before {
            transform: translateX(0);
        }

        .nav-item.active {
            border-left: 3px solid var(--primary-color);
        }

        .nav-item i {
            font-size: 1.25rem;
        }

        /* Main Content */
        .main-content {
            margin-left: var(--sidebar-width);
            flex: 1;
            padding: 2rem;
            width: calc(100% - var(--sidebar-width));
        }

        /* Header */
        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 2.5rem;
            animation: slideDown 0.6s cubic-bezier(0.23, 1, 0.32, 1);
        }

        .header-title h1 {
            font-size: 1.875rem;
            font-weight: 600;
            margin-bottom: 0.25rem;
        }

        .header-title p {
            color: var(--text-muted);
            font-size: 0.875rem;
        }

        .header-actions {
            display: flex;
            align-items: center;
            gap: 1.5rem;
        }

        .search-bar {
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid var(--surface-border);
            border-radius: 2rem;
            padding: 0.5rem 1rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
            width: 250px;
            transition: all 0.3s ease;
        }

        .search-bar:focus-within {
            border-color: var(--primary-color);
            box-shadow: 0 0 0 2px rgba(99, 102, 241, 0.2);
            width: 300px;
        }

        .search-bar input {
            background: transparent;
            border: none;
            color: var(--text-main);
            outline: none;
            width: 100%;
            font-family: inherit;
        }

        .search-bar i {
            color: var(--text-muted);
        }

        .icon-btn {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid var(--surface-border);
            color: var(--text-muted);
            width: 2.5rem;
            height: 2.5rem;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: all 0.2s ease;
            position: relative;
        }

        .icon-btn:hover {
            color: var(--text-main);
            background: rgba(255, 255, 255, 0.1);
            transform: translateY(-2px);
        }

        .notification-badge {
            position: absolute;
            top: -2px;
            right: -2px;
            width: 10px;
            height: 10px;
            background: var(--danger-color);
            border-radius: 50%;
            border: 2px solid var(--bg-color);
        }

        .profile-btn {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            cursor: pointer;
            padding: 0.25rem 0.75rem 0.25rem 0.25rem;
            border-radius: 2rem;
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid var(--surface-border);
            transition: all 0.2s ease;
        }

        .profile-btn:hover {
            background: rgba(255, 255, 255, 0.08);
        }

        .profile-img {
            width: 2rem;
            height: 2rem;
            border-radius: 50%;
            object-fit: cover;
        }

        /* Stats Grid */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
            gap: 1.5rem;
            margin-bottom: 2.5rem;
        }

        .stat-card {
            background: var(--surface-color);
            border: 1px solid var(--surface-border);
            border-radius: 1.25rem;
            padding: 1.5rem;
            backdrop-filter: blur(12px);
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            position: relative;
            overflow: hidden;
            animation: fadeIn 0.6s ease backwards;
        }

        .stat-card:hover {
            transform: translateY(-5px);
            border-color: rgba(255, 255, 255, 0.15);
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
        }

        .stat-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 4px;
            background: linear-gradient(90deg, var(--primary-color), var(--secondary-color));
            opacity: 0;
            transition: opacity 0.3s ease;
        }

        .stat-card:hover::before {
            opacity: 1;
        }

        .stat-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 1rem;
        }

        .stat-title {
            color: var(--text-muted);
            font-size: 0.875rem;
            font-weight: 500;
        }

        .stat-icon {
            width: 3rem;
            height: 3rem;
            border-radius: 0.75rem;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
        }

        .icon-blue {
            background: rgba(99, 102, 241, 0.1);
            color: var(--primary-color);
        }

        .icon-green {
            background: rgba(16, 185, 129, 0.1);
            color: var(--success-color);
        }

        .icon-orange {
            background: rgba(245, 158, 11, 0.1);
            color: var(--warning-color);
        }

        .icon-purple {
            background: rgba(139, 92, 246, 0.1);
            color: var(--secondary-color);
        }

        .stat-value {
            font-size: 2rem;
            font-weight: 700;
            margin-bottom: 0.5rem;
        }

        .stat-trend {
            font-size: 0.875rem;
            display: flex;
            align-items: center;
            gap: 0.25rem;
        }

        .trend-up {
            color: var(--success-color);
        }

        .trend-down {
            color: var(--danger-color);
        }

        /* Charts Grid */
        .charts-grid {
            display: grid;
            grid-template-columns: 2fr 1fr;
            gap: 1.5rem;
            margin-bottom: 2.5rem;
        }

        .chart-card {
            background: var(--surface-color);
            border: 1px solid var(--surface-border);
            border-radius: 1.25rem;
            padding: 1.5rem;
            backdrop-filter: blur(12px);
            animation: slideUp 0.6s cubic-bezier(0.23, 1, 0.32, 1) backwards;
        }

        .chart-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1.5rem;
        }

        .chart-title {
            font-size: 1.125rem;
            font-weight: 600;
        }

        .chart-actions select {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid var(--surface-border);
            color: var(--text-main);
            padding: 0.5rem 1rem;
            border-radius: 0.5rem;
            outline: none;
            cursor: pointer;
            font-family: inherit;
        }

        .chart-actions select option {
            background: var(--bg-color);
        }

        .chart-container {
            position: relative;
            height: 300px;
            width: 100%;
        }

        /* Recent Activity Table */
        .table-card {
            background: var(--surface-color);
            border: 1px solid var(--surface-border);
            border-radius: 1.25rem;
            padding: 1.5rem;
            backdrop-filter: blur(12px);
            animation: slideUp 0.7s cubic-bezier(0.23, 1, 0.32, 1) backwards;
        }

        .table-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1.5rem;
        }

        .table-title {
            font-size: 1.125rem;
            font-weight: 600;
        }

        .btn-text {
            background: transparent;
            border: none;
            color: var(--primary-color);
            font-weight: 500;
            cursor: pointer;
            transition: color 0.2s;
        }

        .btn-text:hover {
            color: var(--primary-hover);
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        th {
            text-align: left;
            padding: 1rem;
            color: var(--text-muted);
            font-weight: 500;
            font-size: 0.875rem;
            border-bottom: 1px solid var(--surface-border);
        }

        td {
            padding: 1rem;
            border-bottom: 1px solid rgba(255, 255, 255, 0.02);
            font-size: 0.95rem;
        }

        tbody tr {
            transition: background 0.2s;
        }

        tbody tr:hover {
            background: rgba(255, 255, 255, 0.02);
        }

        .doc-name {
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }

        .doc-icon {
            width: 2.25rem;
            height: 2.25rem;
            background: rgba(99, 102, 241, 0.1);
            color: var(--primary-color);
            border-radius: 0.5rem;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.25rem;
        }

        .status-badge {
            padding: 0.25rem 0.75rem;
            border-radius: 2rem;
            font-size: 0.75rem;
            font-weight: 500;
            display: inline-block;
        }

        .status-completed {
            background: rgba(16, 185, 129, 0.1);
            color: var(--success-color);
            border: 1px solid rgba(16, 185, 129, 0.2);
        }

        .status-processing {
            background: rgba(245, 158, 11, 0.1);
            color: var(--warning-color);
            border: 1px solid rgba(245, 158, 11, 0.2);
        }

        .status-failed {
            background: rgba(239, 68, 68, 0.1);
            color: var(--danger-color);
            border: 1px solid rgba(239, 68, 68, 0.2);
        }

        .action-btn {
            background: transparent;
            border: none;
            color: var(--text-muted);
            cursor: pointer;
            padding: 0.5rem;
            border-radius: 0.375rem;
            transition: all 0.2s;
        }

        .action-btn:hover {
            color: var(--text-main);
            background: rgba(255, 255, 255, 0.1);
        }

        /* Animations */
        @keyframes fadeIn {
            from {
                opacity: 0;
            }

            to {
                opacity: 1;
            }
        }

        @keyframes slideDown {
            from {
                opacity: 0;
                transform: translateY(-20px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @keyframes slideUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* Animation Delays for Staggered Effect */
        .stat-card:nth-child(1) {
            animation-delay: 0.1s;
        }

        .stat-card:nth-child(2) {
            animation-delay: 0.2s;
        }

        .stat-card:nth-child(3) {
            animation-delay: 0.3s;
        }

        .stat-card:nth-child(4) {
            animation-delay: 0.4s;
        }

        .chart-card:nth-child(1) {
            animation-delay: 0.3s;
        }

        .chart-card:nth-child(2) {
            animation-delay: 0.4s;
        }

        .table-card {
            animation-delay: 0.5s;
        }

        /* Responsive */
        @media (max-width: 1024px) {
            .charts-grid {
                grid-template-columns: 1fr;
            }
        }

        @media (max-width: 768px) {
            .sidebar {
                transform: translateX(-100%);
            }

            .main-content {
                margin-left: 0;
                width: 100%;
            }

            .stats-grid {
                grid-template-columns: 1fr 1fr;
            }

            .header-actions .search-bar {
                display: none;
                /* Hide on mobile for simplicity */
            }
        }

        @media (max-width: 480px) {
            .stats-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>

<body>

    <!-- Sidebar -->
    <aside class="sidebar">
        <a href="/" class="logo">
            <i class='bx bxs-box'></i>
            DocuFlow
        </a>
        <ul class="nav-links">
            <li><a href="/dashboard" class="nav-item active"><i class='bx bx-grid-alt'></i> Dashboard</a></li>
            <li><a href="/documents" class="nav-item"><i class='bx bx-file'></i> Documents</a></li>
            <% if (locals.userRole === 'admin' || locals.userRole === 'GM') { %>
            <li><a href="/workflows" class="nav-item"><i class='bx bx-git-branch'></i> Workflows</a></li>
            <li><a href="/approvals" class="nav-item"><i class='bx bx-check-shield'></i> Approvals</a></li>
            <% } %>
            <li><a href="/analytics" class="nav-item"><i class='bx bx-chart'></i> Analytics</a></li>
            <li><a href="/settings" class="nav-item"><i class='bx bx-cog'></i> Settings</a></li>
        </ul>

        <div style="margin-top: auto;">
            <div
                style="background: rgba(99, 102, 241, 0.1); padding: 1.25rem; border-radius: 1rem; border: 1px solid rgba(99, 102, 241, 0.2); text-align: center;">
                <i class='bx bx-cloud-upload'
                    style="font-size: 2rem; color: var(--primary-color); margin-bottom: 0.5rem;"></i>
                <h4 style="font-size: 0.875rem; margin-bottom: 0.25rem;">Storage Used</h4>
                <p style="font-size: 0.75rem; color: var(--text-muted); margin-bottom: 0.75rem;">75% of 100GB</p>
                <div
                    style="width: 100%; height: 6px; background: rgba(255,255,255,0.1); border-radius: 3px; overflow: hidden;">
                    <div
                        style="width: 75%; height: 100%; background: linear-gradient(90deg, var(--primary-color), var(--secondary-color)); border-radius: 3px;">
                    </div>
                </div>
            </div>
        </div>
    </aside>

    <!-- Main Content -->
    <main class="main-content">
        <!-- Header -->
        <header class="header">
            <div class="header-title">
                <h1>Overview Analytics</h1>
                <p>Welcome back! Here's what's happening with your documents today.</p>
            </div>
            <div class="header-actions">
                <div class="search-bar">
                    <i class='bx bx-search'></i>
                    <input type="text" placeholder="Search documents...">
                </div>
                <button class="icon-btn">
                    <i class='bx bx-bell'></i>
                    <span class="notification-badge"></span>
                </button>
                <div class="profile-btn">
                    <img src="https://ui-avatars.com/api/?name=Admin+User&background=6366f1&color=fff" alt="Profile"
                        class="profile-img">
                    <span style="font-weight: 500; font-size: 0.875rem; margin-right: 0.5rem;">Admin</span>
                </div>
            </div>
        </header>

        <!-- Stats -->
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-header">
                    <div class="stat-title">Total Documents</div>
                    <div class="stat-icon icon-blue"><i class='bx bx-file'></i></div>
                </div>
                <div class="stat-value">12,485</div>
                <div class="stat-trend trend-up">
                    <i class='bx bx-trending-up'></i>
                    <span>+14.5% from last month</span>
                </div>
            </div>

            <div class="stat-card">
                <div class="stat-header">
                    <div class="stat-title">Processed Today</div>
                    <div class="stat-icon icon-green"><i class='bx bx-check-shield'></i></div>
                </div>
                <div class="stat-value">428</div>
                <div class="stat-trend trend-up">
                    <i class='bx bx-trending-up'></i>
                    <span>+5.2% from yesterday</span>
                </div>
            </div>

            <div class="stat-card">
                <div class="stat-header">
                    <div class="stat-title">Pending Review</div>
                    <div class="stat-icon icon-orange"><i class='bx bx-time-five'></i></div>
                </div>
                <div class="stat-value">64</div>
                <div class="stat-trend trend-down">
                    <i class='bx bx-trending-down'></i>
                    <span>-2.1% from yesterday</span>
                </div>
            </div>

            <div class="stat-card">
                <div class="stat-header">
                    <div class="stat-title">Processing Accuracy</div>
                    <div class="stat-icon icon-purple"><i class='bx bx-target-lock'></i></div>
                </div>
                <div class="stat-value">98.2%</div>
                <div class="stat-trend trend-up">
                    <i class='bx bx-trending-up'></i>
                    <span>+0.8% from last month</span>
                </div>
            </div>
        </div>

        <!-- Charts -->
        <div class="charts-grid">
            <div class="chart-card">
                <div class="chart-header">
                    <h2 class="chart-title">Processing Volume</h2>
                    <div class="chart-actions">
                        <select>
                            <option>Last 7 Days</option>
                            <option>Last 30 Days</option>
                            <option>This Year</option>
                        </select>
                    </div>
                </div>
                <div class="chart-container">
                    <canvas id="volumeChart"></canvas>
                </div>
            </div>

            <div class="chart-card">
                <div class="chart-header">
                    <h2 class="chart-title">Document Types</h2>
                    <div class="chart-actions">
                        <button class="icon-btn" style="width: 2rem; height: 2rem;"><i
                                class='bx bx-dots-vertical-rounded'></i></button>
                    </div>
                </div>
                <div class="chart-container">
                    <canvas id="typeChart"></canvas>
                </div>
            </div>
        </div>

        <!-- Recent Activity Table -->
        <div class="table-card">
            <div class="table-header">
                <h2 class="table-title">Recent Document Activity</h2>
                <button class="btn-text">View All</button>
            </div>
            <div style="overflow-x: auto;">
                <table>
                    <thead>
                        <tr>
                            <th>Document Name</th>
                            <th>Category</th>
                            <th>Uploaded By</th>
                            <th>Date</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="recent-activity-body">
                        <!-- Rendered by JS -->
                    </tbody>
                </table>
            </div>

            <!-- Pagination Controls -->
            <div id="dashboard-pagination"
                style="display: flex; justify-content: space-between; align-items: center; margin-top: 1.5rem; padding-top: 1.5rem; border-top: 1px solid var(--surface-border);">
                <div style="font-size: 0.875rem; color: var(--text-muted);">
                    Showing <span id="page-start" style="color: var(--text-main); font-weight: 500;">0</span> to <span
                        id="page-end" style="color: var(--text-main); font-weight: 500;">0</span> of <span
                        id="page-total" style="color: var(--text-main); font-weight: 500;">0</span> entries
                </div>
                <div id="page-controls" style="display: flex; gap: 0.5rem;">
                    <!-- Rendered by JS -->
                </div>
            </div>
        </div>
    </main>

    <!-- Chart Initializations -->
    <script>
        // Common Chart Defaults for Dark Theme
        Chart.defaults.color = '#94a3b8';
        Chart.defaults.font.family = "'Outfit', sans-serif";

        let allDashboardDocs = [];
        let currentPage = 1;
        const itemsPerPage = 5;

        async function loadDashboardData() {
            try {
                // Fetch stats and charts data
                const response = await fetch('/dashboard/stats');
                if (!response.ok) throw new Error('Failed to fetch stats');
                const data = await response.json();

                // Fetch full document list for pagination
                const docsResponse = await fetch('/api/documents');
                if (docsResponse.ok) {
                    allDashboardDocs = await docsResponse.json();
                } else {
                    allDashboardDocs = data.recentDocuments || [];
                }

                // Update Stats
                document.querySelector('.stats-grid .stat-card:nth-child(1) .stat-value').textContent = data.totalDocuments.toLocaleString();
                document.querySelector('.stats-grid .stat-card:nth-child(2) .stat-value').textContent = data.processedToday.toLocaleString();
                document.querySelector('.stats-grid .stat-card:nth-child(3) .stat-value').textContent = data.pendingReview.toLocaleString();
                document.querySelector('.stats-grid .stat-card:nth-child(4) .stat-value').textContent = data.accuracy + '%';

                // Render the first page of the table
                renderTablePage(1);

                // Render Processing Volume Chart
                const ctxVolume = document.getElementById('volumeChart').getContext('2d');
                const gradientBlue = ctxVolume.createLinearGradient(0, 0, 0, 300);
                gradientBlue.addColorStop(0, 'rgba(99, 102, 241, 0.4)');
                gradientBlue.addColorStop(1, 'rgba(99, 102, 241, 0.0)');

                new Chart(ctxVolume, {
                    type: 'line',
                    data: {
                        labels: data.volume.labels,
                        datasets: [{
                            label: 'Processed Documents',
                            data: data.volume.data,
                            borderColor: '#6366f1',
                            backgroundColor: gradientBlue,
                            borderWidth: 3,
                            pointBackgroundColor: '#0b0f19',
                            pointBorderColor: '#6366f1',
                            pointBorderWidth: 2,
                            pointRadius: 4,
                            pointHoverRadius: 6,
                            fill: true,
                            tension: 0.4
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: { legend: { display: false }, tooltip: { backgroundColor: 'rgba(20, 27, 45, 0.9)', titleColor: '#f8fafc', bodyColor: '#f8fafc', borderColor: 'rgba(255, 255, 255, 0.1)', borderWidth: 1, padding: 12, displayColors: false, callbacks: { label: function (context) { return context.parsed.y + ' Documents'; } } } },
                        scales: { y: { beginAtZero: true, grid: { color: 'rgba(255, 255, 255, 0.05)', drawBorder: false }, border: { display: false } }, x: { grid: { display: false, drawBorder: false }, border: { display: false } } },
                        interaction: { intersect: false, mode: 'index' },
                    }
                });

                // Render Document Types Doughnut Chart
                const ctxType = document.getElementById('typeChart').getContext('2d');
                new Chart(ctxType, {
                    type: 'doughnut',
                    data: {
                        labels: data.types.labels,
                        datasets: [{
                            data: data.types.data,
                            backgroundColor: ['#6366f1', '#8b5cf6', '#10b981', '#f59e0b', '#64748b'],
                            borderWidth: 0,
                            hoverOffset: 4
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        cutout: '75%',
                        plugins: { legend: { position: 'bottom', labels: { padding: 20, usePointStyle: true, pointStyle: 'circle' } }, tooltip: { backgroundColor: 'rgba(20, 27, 45, 0.9)', titleColor: '#f8fafc', bodyColor: '#f8fafc', borderColor: 'rgba(255, 255, 255, 0.1)', borderWidth: 1, padding: 12 } }
                    }
                });

            } catch (err) {
                console.error('Error loading dashboard data:', err);
            }
        }

        function renderTablePage(page) {
            currentPage = page;
            const tbody = document.getElementById('recent-activity-body');
            tbody.innerHTML = '';

            const startIndex = (currentPage - 1) * itemsPerPage;
            const endIndex = startIndex + itemsPerPage;
            const paginatedDocs = allDashboardDocs.slice(startIndex, endIndex);

            if (paginatedDocs.length > 0) {
                paginatedDocs.forEach(doc => {
                    const ext = (doc.fileType || "unknown").toLowerCase();
                    let iconBx = "bxs-file-doc";
                    let iconStyle = "";
                    if (ext === "pdf") { iconBx = "bxs-file-pdf"; }
                    else if (["jpg", "jpeg", "png"].includes(ext)) { iconStyle = "background: rgba(239, 68, 68, 0.1); color: var(--danger-color);"; iconBx = "bxs-file-image"; }

                    let statusClass = "status-processing";
                    let statusText = doc.status || "Pending";
                    if (doc.status === "verified" || doc.status === "approved" || doc.status === "success" || doc.status === "review") {
                        statusClass = "status-completed";
                        statusText = doc.status === "review" ? "In Review" : "Completed";
                    } else if (doc.status === "rejected" || doc.status === "failed") {
                        statusClass = "status-failed";
                        statusText = "Failed";
                    }

                    const dateStr = new Date(doc.createdAt).toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" });

                    const tr = document.createElement('tr');
                    tr.innerHTML = `
                        <td>
                            <div class="doc-name">
                                <div class="doc-icon" style="${iconStyle}"><i class='bx ${iconBx}'></i></div>
                                <div>
                                    <div style="font-weight: 500; color: var(--text-main);">${doc.fileName}</div>
                                    <div style="font-size: 0.75rem; color: var(--text-muted);">${(doc.fileType || "unknown").toUpperCase()}</div>
                                </div>
                            </div>
                        </td>
                        <td>General</td>
                        <td>User</td>
                        <td>${dateStr}</td>
                        <td><span class="status-badge ${statusClass}">${statusText}</span></td>
                        <td>
                            <button class="action-btn" onclick="window.location.href='/api/documents/${doc._id}/download'"><i class='bx bx-download'></i></button>
                            <button class="action-btn" onclick="window.open('/api/documents/${doc._id}/view', '_blank')"><i class='bx bx-show'></i></button>
                        </td>
                    `;
                    tbody.appendChild(tr);
                });
            } else {
                tbody.innerHTML = '<tr><td colspan="6" style="text-align: center; padding: 2rem;">No documents found.</td></tr>';
            }

            updatePaginationUI();
        }

        function updatePaginationUI() {
            const totalItems = allDashboardDocs.length;
            const totalPages = Math.ceil(totalItems / itemsPerPage) || 1;

            if (totalItems === 0) {
                document.getElementById('dashboard-pagination').style.display = 'none';
                return;
            } else {
                document.getElementById('dashboard-pagination').style.display = 'flex';
            }

            const start = (currentPage - 1) * itemsPerPage + 1;
            const end = Math.min(start + itemsPerPage - 1, totalItems);

            document.getElementById('page-start').textContent = start;
            document.getElementById('page-end').textContent = end;
            document.getElementById('page-total').textContent = totalItems;

            const controls = document.getElementById('page-controls');
            controls.innerHTML = '';

            const btnStyle = "padding: 0.5rem 0.75rem; border: 1px solid var(--surface-border); background: var(--surface-color); color: var(--text-main); border-radius: 0.375rem; cursor: pointer; display: flex; align-items: center; gap: 0.25rem; font-size: 0.875rem; transition: all 0.2s ease;";
            const activeStyle = "background: var(--primary-color); border-color: var(--primary-color); color: white;";
            const disabledStyle = "opacity: 0.5; cursor: not-allowed;";

            // Prev Button
            const prevBtn = document.createElement('button');
            prevBtn.style = btnStyle + (currentPage === 1 ? disabledStyle : '');
            prevBtn.innerHTML = "<i class='bx bx-chevron-left'></i> Prev";
            prevBtn.onclick = () => { if (currentPage > 1) renderTablePage(currentPage - 1); };
            controls.appendChild(prevBtn);

            // Page Numbers
            for (let i = 1; i <= totalPages; i++) {
                // Show at most 5 pages around current
                if (i === 1 || i === totalPages || (i >= currentPage - 1 && i <= currentPage + 1)) {
                    const btn = document.createElement('button');
                    btn.style = btnStyle + (currentPage === i ? activeStyle : '');
                    btn.textContent = i;
                    btn.onclick = () => renderTablePage(i);
                    controls.appendChild(btn);
                } else if (i === currentPage - 2 || i === currentPage + 2) {
                    const dots = document.createElement('span');
                    dots.style = "color: var(--text-muted); align-self: center;";
                    dots.textContent = "...";
                    controls.appendChild(dots);
                }
            }

            // Next Button
            const nextBtn = document.createElement('button');
            nextBtn.style = btnStyle + (currentPage === totalPages ? disabledStyle : '');
            nextBtn.innerHTML = "Next <i class='bx bx-chevron-right'></i>";
            nextBtn.onclick = () => { if (currentPage < totalPages) renderTablePage(currentPage + 1); };
            controls.appendChild(nextBtn);
        }

        document.addEventListener("DOMContentLoaded", loadDashboardData);
    </script>
</body>

</html>