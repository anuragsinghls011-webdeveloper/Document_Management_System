});

const searchInput = document.getElementById("searchInput");
const statusFilter = document.getElementById("statusFilter");
const typeFilter = document.getElementById("typeFilter");
const dateFilter = document.getElementById("dateFilter");

let debounceTimer = null;

function triggerSearch() {
  clearTimeout(debounceTimer);

  debounceTimer = setTimeout(async () => {
    const q = searchInput.value.trim();
    const status = statusFilter.value;
    const type = typeFilter.value;
    const date = dateFilter.value;

    // 🔥 If no search + no filters → load all documents
    if (!q && status === "all" && type === "all" && !date) {
      loadDocuments();
      return;
    }

    const params = new URLSearchParams();

    if (q) params.append("q", q);
    if (status && status !== "all") params.append("status", status);
    if (type && type !== "all") params.append("type", type);
    if (date) params.append("date", date);

    try {
      const res = await fetch(`/documents/search?${params.toString()}`, {
        credentials: "include"
      });

      if (!res.ok) {
        console.error("Search API failed");
        return;
      }

      const docs = await res.json();
      renderDocuments(docs);

    } catch (err) {
      console.error("Search/filter error", err);
    }
  }, 300);
}

// 🔄 Events
searchInput.addEventListener("input", triggerSearch);
statusFilter.addEventListener("change", triggerSearch);
typeFilter.addEventListener("change", triggerSearch);
dateFilter.addEventListener("change", triggerSearch);



