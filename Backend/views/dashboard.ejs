// Mock Data for Visual Simulation (Replace with API fetch in production)
let workflowItems = [
    { id: 'doc-1', title: 'Q3_Financial_Report.pdf', type: 'PDF', status: 'pending', priority: 'High', aiConfidence: 98, assignee: 'AS' },
    { id: 'doc-2', title: 'Metro_Safety_Audit_v2.docx', type: 'DOCX', status: 'processing', priority: 'Medium', aiConfidence: 45, assignee: 'JD' },
    { id: 'doc-3', title: 'Vendor_Contract_778.pdf', type: 'PDF', status: 'review', priority: 'High', aiConfidence: 89, assignee: 'AS' },
    { id: 'doc-4', title: 'HR_Policy_Update.pdf', type: 'PDF', status: 'approved', priority: 'Low', aiConfidence: 99, assignee: 'System' },
    { id: 'doc-5', title: 'Invoice_#9901.png', type: 'IMG', status: 'pending', priority: 'Medium', aiConfidence: 0, assignee: 'Unassigned' }
];

// Initialize Board
function initWorkflowBoard() {
    renderKanbanColumns();
    updateWorkflowCounts();
}

function renderKanbanColumns() {
    // Clear all columns
    document.querySelectorAll('.kanban-dropzone').forEach(el => el.innerHTML = '');

    workflowItems.forEach(item => {
        const cardHTML = createKanbanCard(item);
        const column = document.querySelector(`.kanban-dropzone[data-status="${item.status}"]`);
        if (column) {
            column.insertAdjacentHTML('beforeend', cardHTML);
        }
    });
    
    // Re-initialize icons for newly added elements
    feather.replace();
}

function createKanbanCard(item) {
    // Style determination based on priority and AI score
    const priorityColor = item.priority === 'High' ? 'text-red-400 bg-red-400/10' : 
                          item.priority === 'Medium' ? 'text-yellow-400 bg-yellow-400/10' : 'text-blue-400 bg-blue-400/10';
    
    const aiBadge = item.aiConfidence > 0 
        ? `<div class="flex items-center gap-1 text-xs font-medium ${item.aiConfidence > 80 ? 'text-green-400' : 'text-yellow-400'}">
             <i data-feather="cpu" class="w-3 h-3"></i> ${item.aiConfidence}% AI Match
           </div>` 
        : '';

    return `
    <div id="${item.id}" draggable="true" ondragstart="drag(event)" class="kanban-card group bg-gray-800 p-4 rounded-lg border border-gray-700 hover:border-blue-500 hover:shadow-lg transition-all cursor-move select-none relative">
        <div class="flex justify-between items-start mb-2">
            <span class="px-2 py-0.5 rounded text-[10px] uppercase font-bold tracking-wider ${priorityColor}">
                ${item.priority}
            </span>
            <button class="text-gray-500 hover:text-white opacity-0 group-hover:opacity-100 transition-opacity"><i data-feather="more-horizontal" class="w-4 h-4"></i></button>
        </div>
        
        <h4 class="text-gray-200 font-medium text-sm mb-1 truncate" title="${item.title}">${item.title}</h4>
        
        <div class="flex items-center justify-between mt-3">
            ${aiBadge}
            <div class="h-6 w-6 rounded-full bg-indigo-600 flex items-center justify-center text-[10px] font-bold text-white border-2 border-gray-800" title="Assigned to ${item.assignee}">
                ${item.assignee}
            </div>
        </div>
        
        <div class="mt-3 w-full bg-gray-700 h-1 rounded-full overflow-hidden">
             <div class="bg-blue-500 h-full" style="width: ${getProgressBarWidth(item.status)}%"></div>
        </div>
    </div>
    `;
}

function getProgressBarWidth(status) {
    switch(status) {
        case 'pending': return 10;
        case 'processing': return 40;
        case 'review': return 75;
        case 'approved': return 100;
        default: return 0;
    }
}

function updateWorkflowCounts() {
    const statuses = ['pending', 'processing', 'review', 'approved'];
    statuses.forEach(status => {
        const count = workflowItems.filter(i => i.status === status).length;
        const el = document.getElementById(`count-${status}`);
        if(el) el.innerText = count;
    });
}

/* ================= DRAG AND DROP LOGIC ================= */
function allowDrop(ev) {
    ev.preventDefault();
    ev.currentTarget.classList.add('bg-gray-800/50'); // Highlight drop zone
}

function drag(ev) {
    ev.dataTransfer.setData("text", ev.target.id);
    ev.target.classList.add('opacity-50'); // Visual feedback while dragging
}

function drop(ev) {
    ev.preventDefault();
    const data = ev.dataTransfer.getData("text");
    const card = document.getElementById(data);
    
    // Find drop target (handle dropping inside a card vs on the column)
    let dropZone = ev.target.closest('.kanban-dropzone');
    
    if (dropZone && card) {
        // Remove highlight from all zones
        document.querySelectorAll('.kanban-dropzone').forEach(el => el.classList.remove('bg-gray-800/50'));
        card.classList.remove('opacity-50');
        
        dropZone.appendChild(card);
        
        // Update Data Model
        const newStatus = dropZone.getAttribute('data-status');
        const itemIndex = workflowItems.findIndex(i => i.id === data);
        if(itemIndex > -1) {
            workflowItems[itemIndex].status = newStatus;
            
            // Re-render card to update progress bar and styles
            card.outerHTML = createKanbanCard(workflowItems[itemIndex]);
            feather.replace(); // Refresh icons
            updateWorkflowCounts();
            
            // Optional: Trigger API call to save new status here
            // saveStatusChange(workflowItems[itemIndex].id, newStatus);
        }
    }
}

