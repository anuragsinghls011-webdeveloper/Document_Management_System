<!DOCTYPE html>
<html lang="en" class="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>AI Powered Intelligent Document Management System</title>
  <meta name="description" content="Premium enterprise AI-powered document management workspace.">
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/feather-icons/dist/feather.min.js"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/assets/css/enterprise.css">
  <script defer src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/gsap.min.js"></script>
  <script defer src="https://cdn.jsdelivr.net/npm/@studio-freight/lenis@1.0.42/bundled/lenis.min.js"></script>
  <script defer src="/assets/js/enterprise.js"></script>
  <style>
    :root {
      --shell-radius: 30px;
      --shell-border: rgba(255, 255, 255, 0.08);
      --glass-bg: linear-gradient(180deg, rgba(255,255,255,0.06), rgba(255,255,255,0.03));
    }
    .dashboard-title { font-size: clamp(2rem, 3.2vw, 3.2rem); }
    .hero-shell { padding-top: 12px; }
    .dashboard-shell { width: min(100%, 1600px); margin: 0 auto; }
    .sidebar-shell { padding: 14px; }
    .sidebar-section { display: grid; gap: 8px; }
    .section-card { padding: 18px; }
    .status-rail { display: flex; align-items: center; gap: 8px; }
    .status-rail .rail { flex: 1; height: 8px; border-radius: 999px; background: rgba(255,255,255,0.06); overflow: hidden; }
    .status-rail .rail > span { display: block; height: 100%; border-radius: inherit; background: linear-gradient(90deg, #4F8BFF, #8A5CFF); }
    .workflow-grid { display: grid; gap: 14px; grid-template-columns: repeat(4, minmax(0, 1fr)); }
    .workflow-step { min-height: 140px; padding: 18px; }
    .doc-shell { overflow: hidden; }
    .doc-row-actions { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
    .topbar { min-height: 82px; }
    .panel-divider { height: 1px; background: linear-gradient(90deg, transparent, rgba(255,255,255,0.08), transparent); margin: 12px 0; }
    .muted-label { color: #B6BCC8; font-size: 0.78rem; letter-spacing: 0.04em; text-transform: uppercase; }
    .hero-gradient { background: linear-gradient(135deg, rgba(79,139,255,0.12), rgba(138,92,255,0.12)); }
    .table-cell-truncate { max-width: 240px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .page-content { scroll-margin-top: 104px; }
    .panel,
    .glass-card,
    .summary-panel,
    .modal-content,
    .drawer-panel {
      border-radius: var(--shell-radius);
      border-color: var(--shell-border);
      background: var(--glass-bg);
      box-shadow: 0 24px 70px rgba(0, 0, 0, 0.28);
    }
    .hero-panel {
      padding: clamp(24px, 3vw, 40px);
      min-height: 420px;
      background:
        radial-gradient(860px 460px at 18% 12%, rgba(79,139,255,0.18), transparent 56%),
        radial-gradient(620px 360px at 86% 18%, rgba(138,92,255,0.16), transparent 52%),
        linear-gradient(180deg, rgba(255,255,255,0.06), rgba(255,255,255,0.03));
      overflow: hidden;
    }
    .hero-panel::after {
      content: "";
      position: absolute;
      inset: auto -10% -40% auto;
      width: 420px;
      height: 420px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(79,139,255,0.18), transparent 65%);
      filter: blur(12px);
      pointer-events: none;
    }
    .hero-title {
      font-size: clamp(2.7rem, 5vw, 5.2rem);
      letter-spacing: -0.075em;
      line-height: 0.9;
      max-width: 12ch;
      margin: 14px 0 16px;
      text-wrap: balance;
    }
    .hero-copy {
      max-width: 70ch;
      font-size: 1.02rem;
      line-height: 1.75;
      color: var(--muted);
    }
    .hero-copy strong { color: var(--text); }
    .hero-actions { margin-top: 24px; }
    @media (max-width: 1180px) {
      .workflow-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    }
    @media (max-width: 760px) {
      .workflow-grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>
  <div id="sidebarBackdrop" class="sidebar-backdrop"></div>

  <button id="scrollTopBtn" class="scroll-top-btn" type="button" aria-label="Scroll to top">
    <i data-feather="chevron-up"></i>
  </button>

  <div id="appShell" class="dashboard-shell app-shell">
    <aside id="sidebar" class="sidebar sidebar-shell">
      <div class="brand">
        <div class="brand-lockup">
          <div class="ai-logo" aria-hidden="true"><i data-feather="cpu"></i></div>
          <div class="brand-copy">
            <p class="brand-title">AIDMS</p>
            <p class="brand-subtitle">Intelligent Document OS</p>
          </div>
        </div>
        <button id="sidebar-toggle" class="icon-button" type="button" aria-label="Collapse sidebar">
          <i data-feather="chevrons-left"></i>
        </button>
      </div>

      <nav id="sidebar-nav" class="nav" aria-label="Main navigation">
        <a href="#dashboard" class="nav-link active" data-target="dashboard" data-tooltip="Dashboard"><i data-feather="grid"></i><span class="nav-label">Dashboard</span></a>
        <a href="#documents" class="nav-link" data-target="documents" data-tooltip="Documents"><i data-feather="file-text"></i><span class="nav-label">Documents</span></a>
        <a href="#workflows" class="nav-link" data-target="workflows" data-tooltip="Workflows"><i data-feather="git-branch"></i><span class="nav-label">Workflows</span></a>
        <a href="#ai-insights" class="nav-link" data-target="ai-insights" data-tooltip="AI Insights"><i data-feather="cpu"></i><span class="nav-label">AI Insights</span></a>
        <a href="#smart-search" class="nav-link" data-target="smart-search" data-tooltip="Smart Search"><i data-feather="search"></i><span class="nav-label">Smart Search</span></a>
        <a href="#approvals" class="nav-link" data-target="approvals" data-tooltip="Approvals"><i data-feather="check-circle"></i><span class="nav-label">Approvals</span></a>
        <a href="#analytics" class="nav-link" data-target="analytics" data-tooltip="Analytics"><i data-feather="bar-chart-2"></i><span class="nav-label">Analytics</span></a>
        <a href="#team" class="nav-link" data-target="team" data-tooltip="Team"><i data-feather="users"></i><span class="nav-label">Team</span></a>
        <a href="#settings" class="nav-link" data-target="settings" data-tooltip="Settings"><i data-feather="settings"></i><span class="nav-label">Settings</span></a>
      </nav>

      <div class="sidebar-footer">
        <div class="profile-card">
          <div class="avatar online">U</div>
          <div class="user-meta">
            <p class="user-name">Standard User</p>
            <p class="user-role">Document Contributor</p>
          </div>
          <span class="role-badge">Online</span>
        </div>
        <button id="assistantQuickAction" class="assistant-action" type="button"><i data-feather="zap"></i><span class="assist-label">Ask document AI</span></button>
        <form action="/logout" method="POST" class="m-0">
          <button id="logoutBtn" class="logout-action w-full" type="submit"><i data-feather="log-out"></i><span class="assist-label">Log out</span></button>
        </form>
      </div>
    </aside>

    <div class="main-shell">
      <header class="topbar">
        <button id="mobileMenu" class="icon-button mobile-menu" type="button" aria-label="Open menu"><i data-feather="menu"></i></button>

        <div class="ai-search">
          <i data-feather="search"></i>
          <input id="searchInput" type="text" autocomplete="off" placeholder="Ask AI to find documents, workflows, approvals...">
          <span class="shortcut">Ctrl K</span>
        </div>

        <div class="top-actions">
          <button id="quickUploadBtn" class="button primary" type="button"><i data-feather="upload-cloud"></i><span>Upload</span></button>
          <button id="activityFeedBtn" class="icon-button" type="button" aria-label="Activity feed"><i data-feather="activity"></i></button>
          <button id="notificationBtn" class="icon-button" type="button" aria-label="Notifications"><i data-feather="bell"></i><span class="notification-dot"></span></button>
          <button id="theme-toggle" class="icon-button" type="button" aria-label="Toggle theme"><i data-feather="moon"></i></button>
          <button id="avatarBtn" class="avatar" type="button" aria-label="User profile">U</button>
        </div>
      </header>

      <div id="activityPopover" class="activity-popover hidden">
        <div class="panel-header">
          <div>
            <h3 class="panel-title">Activity Feed</h3>
            <p class="panel-subtitle">Live workflow events</p>
          </div>
          <span class="panel-pill"><span class="pulse-dot"></span> Live</span>
        </div>
        <div id="activityPopoverList" class="timeline"></div>
      </div>

      <main class="content">
        <section id="dashboard" class="page-content">
          <div class="hero-grid">
            <article class="hero-panel">
              <div class="eyebrow"><span class="pulse-dot"></span><span id="aiStatus">The document intelligence market is live</span></div>
              <h1 class="hero-title"><span id="greeting">Good Evening, User</span><br><span class="gradient-text">Where documents become intelligence.</span></h1>
              <p class="hero-copy">The workspace processed <strong id="heroProcessed">0</strong> documents today, surfaced the highest-priority approvals, and routed the next actions across your operational flow.</p>
              <div class="hero-actions">
                <button id="heroUploadBtn" class="button primary" type="button"><i data-feather="upload-cloud"></i>Quick upload</button>
                <button id="heroSearchBtn" class="button" type="button"><i data-feather="command"></i>Open AI command</button>
                <button class="button" type="button" data-nav-target="workflows"><i data-feather="git-branch"></i>Review workflow</button>
              </div>
            </article>

            <aside class="panel summary-panel">
              <div class="panel-header" style="margin-bottom: 14px;">
                <div>
                  <h2 class="panel-title">Built in, not bolted on</h2>
                  <p class="panel-subtitle">Every control ships with the workspace.</p>
                </div>
                <span class="panel-pill"><i data-feather="layers"></i>Included</span>
              </div>
              <div class="summary-chip">
                <div>
                  <span>Workflow Summary</span>
                  <strong id="heroQueue">0 approvals queued</strong>
                </div>
                <div class="chip-icon"><i data-feather="check-circle"></i></div>
              </div>
              <div class="summary-chip">
                <div>
                  <span>AI Confidence</span>
                  <strong id="heroConfidence">96.8%</strong>
                </div>
                <div class="chip-icon"><i data-feather="target"></i></div>
              </div>
              <div class="summary-chip">
                <div>
                  <span>Automation Health</span>
                  <strong>Optimal</strong>
                </div>
                <div class="chip-icon"><i data-feather="shield"></i></div>
              </div>
            </aside>
          </div>

          <div class="hero-grid" style="margin-top: 18px;">
            <article class="panel section-card">
              <div class="panel-header">
                <div>
                  <h2 class="panel-title">Three steps from upload to approval</h2>
                  <p class="panel-subtitle">A compact view of the workspace pipeline.</p>
                </div>
              </div>
              <div class="workflow-grid">
                <div class="workflow-step glass-card">
                  <div class="eyebrow"><span class="pulse-dot"></span><span>01 Intake</span></div>
                  <h3 class="panel-title" style="margin-top: 10px; font-size: 1rem;">Upload and classify</h3>
                  <p class="panel-subtitle">Drop files in once. OCR, tags, and confidence arrive automatically.</p>
                </div>
                <div class="workflow-step glass-card">
                  <div class="eyebrow"><span class="pulse-dot"></span><span>02 Review</span></div>
                  <h3 class="panel-title" style="margin-top: 10px; font-size: 1rem;">Validate and comment</h3>
                  <p class="panel-subtitle">Use the queue, preview drawer, and notes to make a fast decision.</p>
                </div>
                <div class="workflow-step glass-card">
                  <div class="eyebrow"><span class="pulse-dot"></span><span>03 Route</span></div>
                  <h3 class="panel-title" style="margin-top: 10px; font-size: 1rem;">Approve or escalate</h3>
                  <p class="panel-subtitle">Send documents forward with a single action and a full audit trail.</p>
                </div>
                <div class="workflow-step glass-card">
                  <div class="eyebrow"><span class="pulse-dot"></span><span>04 Learn</span></div>
                  <h3 class="panel-title" style="margin-top: 10px; font-size: 1rem;">Improve the model</h3>
                  <p class="panel-subtitle">The workspace adapts from your actions and improves future routing.</p>
                </div>
              </div>
            </article>
          </div>

          <div class="metrics-grid">
            <article class="glass-card metric-card">
              <div class="metric-top"><div class="metric-icon"><i data-feather="file-text"></i></div><span class="trend"><i data-feather="trending-up"></i>12%</span></div>
              <p class="metric-label">Total Documents</p>
              <p class="metric-value" id="totalDocs">0</p>
              <svg class="sparkline" viewBox="0 0 120 38" aria-hidden="true"><path stroke="#38bdf8" d="M2 30 C18 18, 26 22, 40 14 S70 12, 82 20 S102 26, 118 8"></path></svg>
            </article>
            <article class="glass-card metric-card"><div class="metric-top"><div class="metric-icon violet"><i data-feather="cpu"></i></div><span class="trend"><i data-feather="zap"></i>Live</span></div><p class="metric-label">AI Processed</p><p class="metric-value" id="aiProcessed">0</p><svg class="sparkline" viewBox="0 0 120 38" aria-hidden="true"><path stroke="#8b5cf6" d="M2 28 C18 30, 24 12, 40 18 S62 34, 76 16 S96 4, 118 12"></path></svg></article>
            <article class="glass-card metric-card"><div class="metric-top"><div class="metric-icon orange"><i data-feather="clock"></i></div><span class="trend warn"><i data-feather="alert-triangle"></i>Queue</span></div><p class="metric-label">Pending Approvals</p><p class="metric-value" id="pendingApproval">0</p><svg class="sparkline" viewBox="0 0 120 38" aria-hidden="true"><path stroke="#fb923c" d="M2 26 C14 14, 28 18, 40 24 S60 32, 72 20 S94 14, 118 18"></path></svg></article>
            <article class="glass-card metric-card"><div class="metric-top"><div class="metric-icon emerald"><i data-feather="git-branch"></i></div><span class="trend"><i data-feather="activity"></i>4 lanes</span></div><p class="metric-label">Active Workflows</p><p class="metric-value" id="activeWorkflows">0</p><svg class="sparkline" viewBox="0 0 120 38" aria-hidden="true"><path stroke="#34d399" d="M2 31 C20 28, 28 8, 44 10 S70 32, 88 17 S104 20, 118 7"></path></svg></article>
            <article class="glass-card metric-card"><div class="metric-top"><div class="metric-icon"><i data-feather="archive"></i></div><span class="trend"><i data-feather="database"></i>Safe</span></div><p class="metric-label">Archived Files</p><p class="metric-value" id="archivedDocs">0</p><svg class="sparkline" viewBox="0 0 120 38" aria-hidden="true"><path stroke="#22d3ee" d="M2 24 C20 24, 25 28, 38 20 S62 18, 76 14 S96 18, 118 10"></path></svg></article>
            <article class="glass-card metric-card"><div class="metric-top"><div class="metric-icon violet"><i data-feather="target"></i></div><span class="trend"><i data-feather="check"></i>High</span></div><p class="metric-label">AI Accuracy Rate</p><p class="metric-value"><span id="accuracyRate">0</span>%</p><svg class="sparkline" viewBox="0 0 120 38" aria-hidden="true"><path stroke="#ec4899" d="M2 31 C18 27, 29 24, 42 17 S70 14, 82 10 S102 8, 118 5"></path></svg></article>
          </div>

          <div class="dashboard-grid">
            <article class="panel span-8">
              <div class="panel-header">
                <div>
                  <h2 class="panel-title">Document Intelligence Analytics</h2>
                  <p class="panel-subtitle">Monthly ingestion, AI routing, and approval motion in one view.</p>
                </div>
                <span class="panel-pill"><i data-feather="bar-chart-2"></i> Predictive</span>
              </div>
              <div class="chart-layout">
                <div class="chart-wrap"><canvas id="activityChart"></canvas></div>
                <div>
                  <div class="panel-header" style="margin-bottom: 10px;">
                    <div>
                      <h3 class="panel-title" style="font-size: 0.9rem;">Activity Heatmap</h3>
                      <p class="panel-subtitle">Last 5 weeks</p>
                    </div>
                  </div>
                  <div id="heatmapGrid" class="heatmap"></div>
                </div>
              </div>
            </article>

            <aside class="panel span-4">
              <div class="panel-header">
                <div>
                  <h2 class="panel-title">Recent Activity</h2>
                  <p class="panel-subtitle">Uploads, approvals, AI actions, and transitions.</p>
                </div>
                <span class="panel-pill"><span class="pulse-dot"></span> Now</span>
              </div>
              <div id="activityList" class="timeline"><div class="skeleton-state"><span class="skeleton-line"></span></div></div>
            </aside>

            <article class="panel span-4">
              <div class="panel-header">
                <div>
                  <h2 class="panel-title">AI Insights</h2>
                  <p class="panel-subtitle">Recommendations generated from document flow.</p>
                </div>
                <span class="panel-pill"><i data-feather="cpu"></i> AI</span>
              </div>
              <div id="insightsList" class="insights-list"></div>
            </article>

            <article class="panel span-4">
              <div class="panel-header">
                <div>
                  <h2 class="panel-title">Workflow Graph</h2>
                  <p class="panel-subtitle">AI routing paths and approval chain.</p>
                </div>
                <span class="panel-pill"><i data-feather="git-branch"></i> Node view</span>
              </div>
              <div class="workflow-map">
                <svg class="workflow-lines" viewBox="0 0 640 320" preserveAspectRatio="none" aria-hidden="true"><path d="M92 88 C190 70 210 44 296 54"></path><path d="M370 88 C450 100 492 122 548 142"></path><path d="M306 106 C250 160 244 230 306 244"></path><path d="M386 242 C450 226 500 206 548 174"></path></svg>
                <div class="node input"><span class="node-dot"></span><small>Intake</small><strong>Smart upload</strong></div>
                <div class="node ai"><span class="node-dot"></span><small>AI</small><strong>Classify and extract</strong></div>
                <div class="node review"><span class="node-dot"></span><small>Review</small><strong>Human validation</strong></div>
                <div class="node approval"><span class="node-dot"></span><small>Approval</small><strong>Route and archive</strong></div>
              </div>
            </article>

            <article class="panel span-4">
              <div class="panel-header">
                <div>
                  <h2 class="panel-title">Workflow Performance</h2>
                  <p class="panel-subtitle">SLA health, bottlenecks, and automation speed.</p>
                </div>
              </div>
              <div class="mini-grid">
                <div class="mini-tile"><strong id="slaTile">98%</strong><span>SLA met</span></div>
                <div class="mini-tile"><strong id="cycleTile">2.4h</strong><span>Avg cycle</span></div>
                <div class="mini-tile"><strong id="autoTile">74%</strong><span>Auto routed</span></div>
              </div>
              <div style="margin-top: 16px;" class="progress-track"><span style="width: 74%;"></span></div>
              <p class="panel-subtitle" style="margin-top: 12px;">AI routing is handling most low-risk documents before reviewer handoff.</p>
            </article>

            <article class="panel span-8">
              <div class="panel-header">
                <div>
                  <h2 class="panel-title">Recently Updated Documents</h2>
                  <p class="panel-subtitle">Enterprise table with AI category, status, confidence, and quick preview.</p>
                </div>
                <button class="button" type="button" data-nav-target="documents"><i data-feather="file-text"></i>Open documents</button>
              </div>
              <div class="table-wrap doc-shell">
                <table class="data-table">
                  <thead>
                    <tr>
                      <th>Document Name</th>
                      <th>AI Category</th>
                      <th>Owner</th>
                      <th>Workflow</th>
                      <th>Approval</th>
                      <th>Modified</th>
                      <th>Confidence</th>
                      <th>Actions</th>
                    </tr>
                  </thead>
                  <tbody id="dashboard-documents-body"><tr><td colspan="8" class="skeleton-state"><span class="skeleton-line"></span></td></tr></tbody>
                </table>
              </div>
            </article>
          </div>
        </section>

        <section id="documents" class="page-content hidden">
          <div class="page-heading">
            <div><h1>Documents</h1><p>AI-tagged document operations with filtering, sorting, preview drawer, and upload flow.</p></div>
            <button id="upload-btn" class="button primary" type="button"><i data-feather="upload-cloud"></i>Upload document</button>
          </div>

          <article class="panel">
            <div class="table-tools">
              <div class="filter-grid">
                <input id="docSearchInput" class="input" type="search" placeholder="Search document name or tag">
                <select id="statusFilter" class="select"><option value="all">All statuses</option><option value="approved">Approved</option><option value="pending">Pending</option><option value="processing">Processing</option><option value="review">In review</option><option value="rejected">Rejected</option><option value="archived">Archived</option></select>
                <select id="typeFilter" class="select"><option value="all">All types</option><option value="PDF">PDF</option><option value="DOCX">DOCX</option><option value="XLSX">XLSX</option><option value="PNG">PNG</option><option value="JPG">JPG</option></select>
                <input id="dateFilter" class="select" type="date">
              </div>
              <button id="resetFiltersBtn" class="button" type="button"><i data-feather="refresh-cw"></i>Reset</button>
            </div>
            <div class="table-wrap doc-shell">
              <table class="data-table">
                <thead>
                  <tr>
                    <th><button class="sort-button" type="button" data-sort="fileName">Document Name <i data-feather="chevron-down"></i></button></th>
                    <th>AI Category</th>
                    <th>Owner</th>
                    <th><button class="sort-button" type="button" data-sort="status">Workflow <i data-feather="chevron-down"></i></button></th>
                    <th>Approval</th>
                    <th><button class="sort-button" type="button" data-sort="createdAt">Last Modified <i data-feather="chevron-down"></i></button></th>
                    <th><button class="sort-button" type="button" data-sort="confidence">Confidence <i data-feather="chevron-down"></i></button></th>
                    <th>Actions</th>
                  </tr>
                </thead>
                <tbody id="documents-table-body"><tr><td colspan="8" class="skeleton-state"><span class="skeleton-line"></span></td></tr></tbody>
              </table>
            </div>
            <div id="documentsPagination" class="pagination"></div>
          </article>
        </section>

        <section id="workflows" class="page-content hidden">
          <div class="page-heading">
            <div><h1>Workflows</h1><p>Move documents across the approval lifecycle with AI confidence, priority, and routing status visible in every card.</p></div>
            <button class="button primary" type="button"><i data-feather="plus"></i>New workflow</button>
          </div>
          <article class="panel"><div id="kanbanBoard" class="kanban"></div></article>
        </section>

        <section id="ai-insights" class="page-content hidden">
          <div class="page-heading">
            <div><h1>AI Insights</h1><p>Smart alerts, anomalies, bottlenecks, and automation opportunities for the document workspace.</p></div>
            <button class="button" type="button" id="refreshInsightsBtn"><i data-feather="refresh-cw"></i>Refresh</button>
          </div>
          <article class="panel"><div id="insightsPageList" class="insights-list"></div></article>
        </section>

        <section id="smart-search" class="page-content hidden">
          <div class="page-heading">
            <div><h1>Smart Search</h1><p>Natural language retrieval for pending approvals, finance files, contracts, and OCR text.</p></div>
            <button id="smartSearchOpenBtn" class="button primary" type="button"><i data-feather="command"></i>Open command</button>
