<!DOCTYPE html>
<html lang="en" class="dark">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>AI Powered Intelligent Document Management System</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/feather-icons/dist/feather.min.js"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    :root {
      color-scheme: dark;
      --bg: #081120;
      --bg-2: #0B1220;
      --bg-3: #111827;
      --surface: rgba(23, 32, 51, 0.74);
      --surface-strong: rgba(30, 41, 59, 0.88);
      --surface-soft: rgba(15, 23, 42, 0.7);
      --border: rgba(148, 163, 184, 0.14);
      --border-strong: rgba(148, 163, 184, 0.24);
      --text: #f8fafc;
      --muted: #94a3b8;
      --muted-2: #64748b;
      --blue: #38bdf8;
      --blue-strong: #2563eb;
      --violet: #8b5cf6;
      --cyan: #22d3ee;
      --emerald: #34d399;
      --orange: #fb923c;
      --pink: #ec4899;
      --danger: #fb7185;
      --shadow: 0 24px 80px rgba(2, 8, 23, 0.5);
      --glass: saturate(140%) blur(18px);
    }

    * {
      box-sizing: border-box;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      min-height: 100vh;
      margin: 0;
      font-family: "Inter", system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      letter-spacing: 0;
      background:
        radial-gradient(1100px 620px at 10% -10%, rgba(56, 189, 248, 0.16), transparent 62%),
        radial-gradient(1000px 640px at 88% 8%, rgba(139, 92, 246, 0.13), transparent 64%),
        linear-gradient(135deg, var(--bg), var(--bg-2) 48%, var(--bg-3));
      color: var(--text);
      overflow-x: hidden;
    }

    body::before {
      content: "";
      position: fixed;
      inset: 0;
      pointer-events: none;
      background-image:
        linear-gradient(rgba(148, 163, 184, 0.035) 1px, transparent 1px),
        linear-gradient(90deg, rgba(148, 163, 184, 0.035) 1px, transparent 1px);
      background-size: 48px 48px;
      mask-image: linear-gradient(to bottom, rgba(0, 0, 0, 0.9), transparent 78%);
      z-index: -1;
    }

    body.focus-theme {
      --surface: rgba(17, 24, 39, 0.78);
      --surface-strong: rgba(15, 23, 42, 0.94);
      --border: rgba(125, 211, 252, 0.18);
    }

    ::selection {
      background: rgba(34, 211, 238, 0.26);
      color: var(--text);
    }

    ::-webkit-scrollbar {
      width: 10px;
      height: 10px;
    }

    ::-webkit-scrollbar-track {
      background: rgba(15, 23, 42, 0.9);
    }

    ::-webkit-scrollbar-thumb {
      background: linear-gradient(180deg, rgba(56, 189, 248, 0.45), rgba(139, 92, 246, 0.45));
      border: 2px solid rgba(15, 23, 42, 0.9);
      border-radius: 999px;
    }

    .hidden {
      display: none !important;
    }

    .app-shell {
      display: grid;
      grid-template-columns: 288px minmax(0, 1fr);
      gap: 16px;
      min-height: 100vh;
      padding: 16px;
      transition: grid-template-columns 0.28s ease;
    }

    .app-shell.sidebar-collapsed {
      grid-template-columns: 92px minmax(0, 1fr);
    }

    .sidebar {
      position: sticky;
      top: 16px;
      height: calc(100vh - 32px);
      display: flex;
      flex-direction: column;
      overflow: hidden;
      border: 1px solid var(--border);
      border-radius: 24px;
      background:
        linear-gradient(180deg, rgba(23, 32, 51, 0.9), rgba(8, 17, 32, 0.82)),
        rgba(15, 23, 42, 0.82);
      box-shadow: var(--shadow);
      backdrop-filter: var(--glass);
      z-index: 30;
    }

    .brand {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      padding: 18px;
      border-bottom: 1px solid var(--border);
    }

    .brand-lockup {
      display: flex;
      align-items: center;
      gap: 12px;
      min-width: 0;
    }

    .ai-logo {
      position: relative;
      display: grid;
      width: 46px;
      height: 46px;
      flex: 0 0 auto;
      place-items: center;
      border-radius: 16px;
      background: linear-gradient(135deg, rgba(34, 211, 238, 0.95), rgba(37, 99, 235, 0.95) 48%, rgba(139, 92, 246, 0.95));
      box-shadow: 0 18px 46px rgba(37, 99, 235, 0.28), inset 0 1px 0 rgba(255, 255, 255, 0.24);
    }

    .ai-logo::after {
      content: "";
      position: absolute;
      inset: -5px;
      border: 1px solid rgba(34, 211, 238, 0.36);
      border-radius: 20px;
      opacity: 0;
      animation: logoPulse 2.8s ease-in-out infinite;
    }

    @keyframes logoPulse {
      0%, 100% {
        transform: scale(0.96);
        opacity: 0;
      }
      42% {
        transform: scale(1.06);
        opacity: 0.9;
      }
    }

    .brand-title {
      margin: 0;
      font-size: 0.98rem;
      font-weight: 800;
      letter-spacing: 0;
      line-height: 1.1;
    }

    .brand-subtitle {
      margin: 4px 0 0;
      color: var(--muted);
      font-size: 0.75rem;
      white-space: nowrap;
    }

    .icon-button {
      position: relative;
      display: inline-grid;
      width: 40px;
      height: 40px;
      place-items: center;
      border: 1px solid rgba(148, 163, 184, 0.12);
      border-radius: 14px;
      background: rgba(15, 23, 42, 0.48);
      color: #cbd5e1;
      transition: transform 0.2s ease, border-color 0.2s ease, color 0.2s ease, background 0.2s ease, box-shadow 0.2s ease;
    }

    .icon-button:hover {
      transform: translateY(-2px);
      border-color: rgba(56, 189, 248, 0.38);
      color: white;
      background: rgba(30, 41, 59, 0.8);
      box-shadow: 0 18px 40px rgba(8, 145, 178, 0.13);
    }

    .nav {
      display: flex;
      flex: 1;
      flex-direction: column;
      gap: 6px;
      padding: 14px 12px;
      overflow-y: auto;
    }

    .nav-link {
      position: relative;
      display: flex;
      align-items: center;
      gap: 12px;
      min-height: 46px;
      padding: 0 14px;
      border: 1px solid transparent;
      border-radius: 16px;
      color: var(--muted);
      font-size: 0.9rem;
      font-weight: 650;
      text-decoration: none;
      transition: background 0.22s ease, color 0.22s ease, border-color 0.22s ease, transform 0.22s ease, box-shadow 0.22s ease;
    }

    .nav-link i,
    .nav-link svg {
      width: 18px;
      height: 18px;
      flex: 0 0 auto;
    }

    .nav-link:hover {
      color: white;
      border-color: rgba(56, 189, 248, 0.22);
      background: linear-gradient(135deg, rgba(56, 189, 248, 0.1), rgba(139, 92, 246, 0.08));
      transform: translateX(3px);
      box-shadow: 0 12px 32px rgba(8, 145, 178, 0.08);
    }

    .nav-link.active {
      color: white;
      border-color: rgba(34, 211, 238, 0.34);
      background: linear-gradient(135deg, rgba(37, 99, 235, 0.24), rgba(34, 211, 238, 0.11), rgba(139, 92, 246, 0.18));
      box-shadow: inset 3px 0 0 rgba(34, 211, 238, 0.82), 0 20px 52px rgba(37, 99, 235, 0.13);
    }

    .sidebar.collapsed .brand-copy,
    .sidebar.collapsed .nav-label,
    .sidebar.collapsed .user-meta,
    .sidebar.collapsed .assist-label,
    .sidebar.collapsed .role-badge,
    .sidebar.collapsed .assistant-action span {
      display: none;
    }

    .sidebar.collapsed .brand {
      justify-content: center;
      padding-inline: 12px;
    }

    .sidebar.collapsed .brand-lockup {
      justify-content: center;
    }

    .sidebar.collapsed .nav-link {
      justify-content: center;
      padding-inline: 0;
    }

    .sidebar.collapsed .nav-link::after {
      content: attr(data-tooltip);
      position: absolute;
      left: calc(100% + 10px);
      top: 50%;
      transform: translateY(-50%) translateX(-4px);
      width: max-content;
      max-width: 180px;
      padding: 8px 10px;
      border: 1px solid var(--border);
      border-radius: 10px;
      background: rgba(15, 23, 42, 0.94);
      color: white;
      font-size: 0.78rem;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.2s ease, transform 0.2s ease;
      box-shadow: 0 12px 32px rgba(2, 8, 23, 0.42);
    }

    .sidebar.collapsed .nav-link:hover::after {
      opacity: 1;
      transform: translateY(-50%) translateX(0);
    }

    .sidebar-footer {
      display: grid;
      gap: 10px;
      padding: 12px;
      border-top: 1px solid var(--border);
    }

    .profile-card {
      display: flex;
      align-items: center;
      gap: 12px;
      min-width: 0;
      padding: 12px;
      border: 1px solid rgba(148, 163, 184, 0.13);
      border-radius: 18px;
      background: rgba(15, 23, 42, 0.48);
    }

    .avatar {
      position: relative;
      display: grid;
      width: 40px;
      height: 40px;
      flex: 0 0 auto;
      place-items: center;
      border-radius: 14px;
      background: linear-gradient(135deg, rgba(139, 92, 246, 0.9), rgba(34, 211, 238, 0.72));
      color: white;
      font-weight: 800;
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.24);
    }

    .avatar.online::after {
      content: "";
      position: absolute;
      right: -1px;
      bottom: -1px;
      width: 11px;
      height: 11px;
      border: 2px solid #0f172a;
      border-radius: 999px;
      background: var(--emerald);
      box-shadow: 0 0 12px rgba(52, 211, 153, 0.7);
    }

    .user-meta {
      min-width: 0;
    }

    .user-name {
      margin: 0;
      overflow: hidden;
      color: white;
      font-size: 0.86rem;
      font-weight: 750;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .user-role {
      margin: 2px 0 0;
      color: var(--muted);
      font-size: 0.72rem;
    }

    .role-badge {
      margin-left: auto;
      padding: 4px 8px;
      border: 1px solid rgba(52, 211, 153, 0.24);
      border-radius: 999px;
      background: rgba(52, 211, 153, 0.09);
      color: #a7f3d0;
      font-size: 0.67rem;
      font-weight: 800;
      text-transform: uppercase;
    }

    .assistant-action {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 9px;
      min-height: 42px;
      border: 1px solid rgba(56, 189, 248, 0.22);
      border-radius: 16px;
      background: linear-gradient(135deg, rgba(56, 189, 248, 0.11), rgba(139, 92, 246, 0.12));
      color: white;
      font-size: 0.83rem;
      font-weight: 750;
      transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
    }

    .assistant-action:hover {
      transform: translateY(-2px);
      border-color: rgba(34, 211, 238, 0.44);
      box-shadow: 0 18px 42px rgba(37, 99, 235, 0.16);
    }

    .main-shell {
      min-width: 0;
    }

    .topbar {
      position: sticky;
      top: 16px;
      display: flex;
      align-items: center;
      gap: 12px;
      min-height: 76px;
      padding: 14px;
      border: 1px solid var(--border);
      border-radius: 24px;
      background: rgba(8, 17, 32, 0.74);
      box-shadow: 0 18px 54px rgba(2, 8, 23, 0.28);
      backdrop-filter: var(--glass);
      z-index: 20;
    }

    .mobile-menu {
      display: none;
    }

    .ai-search {
      position: relative;
      flex: 1;
      min-width: 180px;
    }

    .ai-search i,
    .ai-search svg {
      position: absolute;
      top: 50%;
      left: 16px;
      width: 18px;
      height: 18px;
      transform: translateY(-50%);
      color: var(--cyan);
      pointer-events: none;
    }

    .ai-search input {
      width: 100%;
      height: 48px;
      padding: 0 84px 0 46px;
      border: 1px solid rgba(148, 163, 184, 0.16);
      border-radius: 16px;
      outline: none;
      background: rgba(15, 23, 42, 0.72);
      color: white;
      font-size: 0.92rem;
      transition: border-color 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
    }

    .ai-search input:focus {
      border-color: rgba(34, 211, 238, 0.55);
      background: rgba(15, 23, 42, 0.9);
      box-shadow: 0 0 0 4px rgba(34, 211, 238, 0.08), 0 0 34px rgba(37, 99, 235, 0.22);
    }

    .shortcut {
      position: absolute;
      top: 50%;
      right: 12px;
      transform: translateY(-50%);
      padding: 4px 8px;
      border: 1px solid rgba(148, 163, 184, 0.16);
      border-radius: 9px;
      background: rgba(15, 23, 42, 0.85);
      color: var(--muted);
      font-size: 0.72rem;
      font-weight: 800;
    }

    .top-actions {
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 9px;
      min-height: 42px;
      padding: 0 14px;
      border: 1px solid rgba(148, 163, 184, 0.14);
      border-radius: 14px;
      background: rgba(15, 23, 42, 0.68);
      color: #e2e8f0;
      font-size: 0.86rem;
      font-weight: 750;
      text-decoration: none;
      transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease, background 0.2s ease;
    }

    button,
    a {
      cursor: pointer;
    }

    .button:hover {
      transform: translateY(-2px);
      border-color: rgba(56, 189, 248, 0.35);
      background: rgba(30, 41, 59, 0.9);
      box-shadow: 0 18px 44px rgba(2, 8, 23, 0.24);
    }

    .button.primary {
      border-color: rgba(34, 211, 238, 0.34);
      background: linear-gradient(135deg, rgba(37, 99, 235, 0.95), rgba(34, 211, 238, 0.72));
      color: white;
      box-shadow: 0 18px 44px rgba(37, 99, 235, 0.24);
    }

    .notification-dot {
      position: absolute;
      top: 9px;
      right: 9px;
      width: 9px;
      height: 9px;
      border: 2px solid #0f172a;
      border-radius: 999px;
      background: var(--orange);
      box-shadow: 0 0 14px rgba(251, 146, 60, 0.75);
    }

    .content {
      padding: 18px 0 0;
    }

    .page-content {
      animation: reveal 0.46s ease both;
    }

    .page-content.page-entering {
      animation: reveal 0.4s cubic-bezier(0.4,0,0.2,1) both;
    }

    .page-content.page-exiting {
      animation: revealOut 0.2s ease both;
    }

    @keyframes reveal {
      from {
        opacity: 0;
        transform: translateY(14px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @keyframes revealOut {
      from {
        opacity: 1;
        transform: translateY(0);
      }
      to {
        opacity: 0;
        transform: translateY(-8px);
      }
    }

    /* Scroll to top button */
    .scroll-top-btn {
      position: fixed;
      bottom: 24px;
      right: 24px;
      width: 46px;
      height: 46px;
      border-radius: 16px;
      border: 1px solid rgba(56, 189, 248, 0.25);
      background: rgba(15, 23, 42, 0.9);
      backdrop-filter: blur(12px);
      color: var(--cyan);
      display: grid;
      place-items: center;
      cursor: pointer;
      z-index: 50;
      opacity: 0;
      transform: translateY(20px);
      transition: opacity 0.3s ease, transform 0.3s ease, box-shadow 0.3s ease;
      pointer-events: none;
    }

    .scroll-top-btn.visible {
      opacity: 1;
      transform: translateY(0);
      pointer-events: auto;
    }

    .scroll-top-btn:hover {
      box-shadow: 0 12px 30px rgba(34, 211, 238, 0.18);
      transform: translateY(-3px);
    }

    /* Logout button */
    .logout-action {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 9px;
      min-height: 42px;
      border: 1px solid rgba(251, 113, 133, 0.22);
      border-radius: 16px;
      background: linear-gradient(135deg, rgba(251, 113, 133, 0.1), rgba(239, 68, 68, 0.08));
      color: #fda4af;
      font-size: 0.83rem;
      font-weight: 750;
      cursor: pointer;
      transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease, background 0.2s ease;
    }

    .logout-action:hover {
      transform: translateY(-2px);
      border-color: rgba(251, 113, 133, 0.44);
      background: linear-gradient(135deg, rgba(251, 113, 133, 0.18), rgba(239, 68, 68, 0.15));
      box-shadow: 0 18px 42px rgba(239, 68, 68, 0.12);
    }

    /* Mobile sidebar backdrop */
    .sidebar-backdrop {
      position: fixed;
      inset: 0;
      background: rgba(2, 8, 23, 0);
      backdrop-filter: blur(0px);
      z-index: 29;
      pointer-events: none;
      transition: background 0.3s ease, backdrop-filter 0.3s ease;
    }

    .sidebar-backdrop.active {
      background: rgba(2, 8, 23, 0.5);
      backdrop-filter: blur(8px);
      pointer-events: auto;
    }

    .hero-grid {
      display: grid;
      grid-template-columns: minmax(0, 1.7fr) minmax(320px, 0.8fr);
      gap: 16px;
      margin-bottom: 16px;
    }

    .hero-panel,
    .glass-card,
    .panel {
      position: relative;
      overflow: hidden;
      border: 1px solid var(--border);
      border-radius: 24px;
      background:
        linear-gradient(145deg, rgba(30, 41, 59, 0.84), rgba(8, 17, 32, 0.74)),
        var(--surface);
      box-shadow: 0 22px 70px rgba(2, 8, 23, 0.3);
      backdrop-filter: var(--glass);
    }

    .hero-panel {
      min-height: 294px;
      padding: clamp(22px, 3vw, 34px);
      isolation: isolate;
    }

    .hero-panel::before {
      content: "";
      position: absolute;
      inset: 0;
      background:
        linear-gradient(120deg, rgba(34, 211, 238, 0.18), transparent 34%),
        linear-gradient(300deg, rgba(236, 72, 153, 0.12), transparent 36%);
      z-index: -2;
    }

    .hero-panel::after {
      content: "";
      position: absolute;
      inset: auto 24px 0;
      height: 1px;
      background: linear-gradient(90deg, transparent, rgba(34, 211, 238, 0.6), transparent);
      opacity: 0.7;
    }

    .eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 18px;
      padding: 8px 11px;
      border: 1px solid rgba(34, 211, 238, 0.2);
      border-radius: 999px;
      background: rgba(8, 47, 73, 0.22);
      color: #a5f3fc;
      font-size: 0.78rem;
      font-weight: 750;
    }

    .pulse-dot {
      width: 8px;
      height: 8px;
      border-radius: 999px;
      background: var(--emerald);
      box-shadow: 0 0 0 0 rgba(52, 211, 153, 0.72);
      animation: pulseDot 2.2s infinite;
    }

    @keyframes pulseDot {
      70% {
        box-shadow: 0 0 0 10px rgba(52, 211, 153, 0);
      }
      100% {
        box-shadow: 0 0 0 0 rgba(52, 211, 153, 0);
      }
    }

    .hero-title {
      max-width: 780px;
      margin: 0;
      font-size: clamp(2.1rem, 4vw, 4rem);
      line-height: 0.98;
      font-weight: 850;
      letter-spacing: 0;
    }

    .gradient-text {
      background: linear-gradient(90deg, #f8fafc, #a5f3fc 34%, #c4b5fd 68%, #fbcfe8);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
    }

    .hero-copy {
      max-width: 650px;
      margin: 18px 0 0;
      color: #cbd5e1;
      font-size: 1rem;
      line-height: 1.75;
    }

    .hero-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin-top: 26px;
    }

    .summary-panel {
      display: grid;
      gap: 12px;
      padding: 16px;
    }

    .summary-chip {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      padding: 16px;
      border: 1px solid rgba(148, 163, 184, 0.12);
      border-radius: 18px;
      background: rgba(15, 23, 42, 0.58);
    }

    .summary-chip span {
      color: var(--muted);
      font-size: 0.79rem;
      font-weight: 700;
    }

    .summary-chip strong {
      display: block;
      margin-top: 5px;
      color: white;
      font-size: 1.08rem;
      font-weight: 850;
    }

    .chip-icon {
      display: grid;
      width: 42px;
      height: 42px;
      place-items: center;
      border-radius: 14px;
      background: linear-gradient(135deg, rgba(56, 189, 248, 0.18), rgba(139, 92, 246, 0.14));
      color: var(--cyan);
    }

    .metrics-grid {
      display: grid;
      grid-template-columns: repeat(6, minmax(0, 1fr));
      gap: 14px;
      margin-bottom: 16px;
    }

    .metric-card {
      min-height: 176px;
      padding: 16px;
      transition: transform 0.22s ease, border-color 0.22s ease, box-shadow 0.22s ease;
    }

    .metric-card:hover {
      transform: perspective(800px) translateY(-5px) rotateX(1deg);
      border-color: rgba(34, 211, 238, 0.32);
      box-shadow: 0 26px 70px rgba(8, 145, 178, 0.12);
    }

    .metric-top {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
    }

    .metric-icon {
      display: grid;
      width: 42px;
      height: 42px;
      place-items: center;
      border-radius: 14px;
      color: white;
      background: linear-gradient(135deg, rgba(56, 189, 248, 0.88), rgba(37, 99, 235, 0.88));
      box-shadow: 0 14px 32px rgba(37, 99, 235, 0.24);
    }

    .metric-icon.violet {
      background: linear-gradient(135deg, rgba(139, 92, 246, 0.92), rgba(37, 99, 235, 0.86));
      box-shadow: 0 14px 32px rgba(139, 92, 246, 0.22);
    }

    .metric-icon.emerald {
      background: linear-gradient(135deg, rgba(52, 211, 153, 0.9), rgba(20, 184, 166, 0.84));
      box-shadow: 0 14px 32px rgba(20, 184, 166, 0.18);
    }

    .metric-icon.orange {
      background: linear-gradient(135deg, rgba(251, 146, 60, 0.9), rgba(236, 72, 153, 0.76));
      box-shadow: 0 14px 32px rgba(251, 146, 60, 0.18);
    }

    .trend {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      padding: 5px 8px;
      border-radius: 999px;
      background: rgba(52, 211, 153, 0.1);
      color: #86efac;
      font-size: 0.72rem;
      font-weight: 850;
    }

    .trend.warn {
      background: rgba(251, 146, 60, 0.11);
      color: #fdba74;
    }

    .metric-label {
      margin: 20px 0 0;
      color: var(--muted);
      font-size: 0.78rem;
      font-weight: 750;
    }

    .metric-value {
      margin: 6px 0 0;
      color: white;
      font-size: 2rem;
      line-height: 1;
      font-weight: 850;
    }

    .sparkline {
      width: 100%;
      height: 38px;
      margin-top: 14px;
      overflow: visible;
    }

    .sparkline path {
      fill: none;
      stroke-linecap: round;
      stroke-linejoin: round;
      stroke-width: 3;
      filter: drop-shadow(0 0 8px rgba(34, 211, 238, 0.35));
    }

    .dashboard-grid {
      display: grid;
      grid-template-columns: repeat(12, minmax(0, 1fr));
      gap: 16px;
    }

    .panel {
      padding: 18px;
    }

    .span-8 {
      grid-column: span 8;
    }

    .span-7 {
      grid-column: span 7;
    }

    .span-6 {
      grid-column: span 6;
    }

    .span-5 {
      grid-column: span 5;
    }

    .span-4 {
      grid-column: span 4;
    }

    .panel-header {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 14px;
      margin-bottom: 16px;
    }

    .panel-title {
      margin: 0;
      color: white;
      font-size: 1rem;
      font-weight: 820;
    }

    .panel-subtitle {
      margin: 5px 0 0;
      color: var(--muted);
      font-size: 0.82rem;
      line-height: 1.5;
    }

    .panel-pill {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      padding: 7px 10px;
      border: 1px solid rgba(34, 211, 238, 0.2);
      border-radius: 999px;
      background: rgba(8, 47, 73, 0.24);
      color: #a5f3fc;
      font-size: 0.72rem;
      font-weight: 800;
      white-space: nowrap;
    }

    .chart-layout {
      display: grid;
      grid-template-columns: minmax(0, 1fr) 170px;
      gap: 18px;
      align-items: stretch;
    }

    .chart-wrap {
      min-height: 310px;
    }

    .heatmap {
      display: grid;
      grid-template-columns: repeat(7, 1fr);
      gap: 6px;
      align-content: end;
      padding: 14px;
      border: 1px solid rgba(148, 163, 184, 0.1);
      border-radius: 18px;
      background: rgba(15, 23, 42, 0.42);
    }

    .heat-cell {
      aspect-ratio: 1;
      border-radius: 7px;
      background: rgba(56, 189, 248, var(--heat, 0.12));
      box-shadow: 0 0 18px rgba(34, 211, 238, calc(var(--heat, 0.12) * 0.28));
      transition: transform 0.2s ease, background 0.2s ease;
    }

    .heat-cell:hover {
      transform: scale(1.14);
      background: rgba(52, 211, 153, 0.58);
    }

    .timeline {
      display: grid;
      gap: 12px;
      max-height: 450px;
      overflow-y: auto;
      padding-right: 2px;
    }

    .timeline-item {
      position: relative;
      display: grid;
      grid-template-columns: 40px minmax(0, 1fr);
      gap: 12px;
      padding: 12px;
      border: 1px solid rgba(148, 163, 184, 0.1);
      border-radius: 18px;
      background: rgba(15, 23, 42, 0.46);
      transition: transform 0.2s ease, border-color 0.2s ease, background 0.2s ease;
    }

    .timeline-item:hover {
      transform: translateX(3px);
      border-color: rgba(56, 189, 248, 0.22);
      background: rgba(30, 41, 59, 0.58);
    }

    .timeline-avatar {
      display: grid;
      width: 40px;
      height: 40px;
      place-items: center;
      border-radius: 14px;
      background: linear-gradient(135deg, rgba(37, 99, 235, 0.78), rgba(139, 92, 246, 0.8));
      color: white;
      font-size: 0.78rem;
      font-weight: 850;
    }

    .timeline-title {
      margin: 0;
      color: #f8fafc;
      font-size: 0.86rem;
      font-weight: 750;
      line-height: 1.35;
    }

    .timeline-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 7px;
      margin-top: 8px;
      color: var(--muted);
      font-size: 0.72rem;
    }

    .badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      width: fit-content;
      padding: 5px 8px;
      border: 1px solid rgba(148, 163, 184, 0.12);
      border-radius: 999px;
      background: rgba(15, 23, 42, 0.64);
      color: #cbd5e1;
      font-size: 0.72rem;
      font-weight: 800;
      text-transform: capitalize;
      white-space: nowrap;
    }

    .badge.approved {
      border-color: rgba(52, 211, 153, 0.22);
      background: rgba(52, 211, 153, 0.1);
      color: #bbf7d0;
    }

    .badge.pending,
    .badge.review,
    .badge.processing {
      border-color: rgba(251, 146, 60, 0.22);
      background: rgba(251, 146, 60, 0.1);
      color: #fed7aa;
    }

    .badge.rejected,
    .badge.changes_requested {
      border-color: rgba(251, 113, 133, 0.22);
      background: rgba(251, 113, 133, 0.1);
      color: #fecdd3;
    }

    .badge.archived {
      color: #cbd5e1;
    }

    .insights-list {
      display: grid;
      gap: 10px;
    }

    .insight-item {
      display: grid;
      grid-template-columns: 38px minmax(0, 1fr);
      gap: 12px;
      padding: 13px;
      border: 1px solid rgba(148, 163, 184, 0.11);
      border-radius: 18px;
      background: linear-gradient(135deg, rgba(56, 189, 248, 0.08), rgba(139, 92, 246, 0.07));
    }

    .insight-icon {
      display: grid;
      width: 38px;
      height: 38px;
      place-items: center;
      border-radius: 13px;
      background: rgba(34, 211, 238, 0.11);
      color: var(--cyan);
    }

    .insight-title {
      margin: 0;
      color: white;
      font-size: 0.84rem;
      font-weight: 800;
    }

    .insight-copy {
      margin: 5px 0 0;
      color: var(--muted);
      font-size: 0.77rem;
      line-height: 1.5;
    }

    .workflow-map {
      position: relative;
      min-height: 318px;
      border: 1px solid rgba(148, 163, 184, 0.1);
      border-radius: 20px;
      background:
        linear-gradient(rgba(148, 163, 184, 0.05) 1px, transparent 1px),
        linear-gradient(90deg, rgba(148, 163, 184, 0.05) 1px, transparent 1px),
        rgba(15, 23, 42, 0.38);
      background-size: 28px 28px;
      overflow: hidden;
    }

    .workflow-lines {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      opacity: 0.8;
    }

    .workflow-lines path {
      fill: none;
      stroke: rgba(34, 211, 238, 0.45);
      stroke-width: 2;
      stroke-dasharray: 8 10;
      animation: dashFlow 12s linear infinite;
      filter: drop-shadow(0 0 8px rgba(34, 211, 238, 0.34));
    }

    @keyframes dashFlow {
      to {
        stroke-dashoffset: -160;
      }
    }

    .node {
      position: absolute;
      width: 148px;
      padding: 12px;
      border: 1px solid rgba(148, 163, 184, 0.16);
      border-radius: 18px;
      background: rgba(15, 23, 42, 0.9);
      box-shadow: 0 16px 40px rgba(2, 8, 23, 0.28);
      transition: transform 0.2s ease, border-color 0.2s ease;
    }

    .node:hover {
      transform: translateY(-4px);
      border-color: rgba(34, 211, 238, 0.38);
    }

    .node small {
      display: block;
      color: var(--muted);
      font-size: 0.67rem;
      font-weight: 800;
      text-transform: uppercase;
    }

    .node strong {
      display: block;
      margin-top: 4px;
      color: white;
      font-size: 0.86rem;
      line-height: 1.25;
    }

    .node .node-dot {
      position: absolute;
      top: 12px;
      right: 12px;
      width: 9px;
      height: 9px;
      border-radius: 999px;
      background: var(--cyan);
      box-shadow: 0 0 14px rgba(34, 211, 238, 0.82);
    }

    .node.input {
      left: 7%;
      top: 16%;
    }

    .node.ai {
      left: 40%;
      top: 10%;
    }

    .node.review {
      left: 38%;
      top: 60%;
    }

    .node.approval {
      right: 8%;
      top: 31%;
    }

    .table-tools {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      margin-bottom: 14px;
    }

    .filter-grid {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
    }

    .input,
    .select {
      min-height: 42px;
      border: 1px solid rgba(148, 163, 184, 0.14);
      border-radius: 14px;
      outline: none;
      background: rgba(15, 23, 42, 0.62);
      color: #e2e8f0;
      font-size: 0.85rem;
      transition: border-color 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
    }

    .input {
      width: min(320px, 100%);
      padding: 0 13px;
    }

    .select {
      padding: 0 12px;
    }

    .input:focus,
    .select:focus {
      border-color: rgba(34, 211, 238, 0.5);
      box-shadow: 0 0 0 4px rgba(34, 211, 238, 0.08);
      background: rgba(15, 23, 42, 0.88);
    }

    .table-wrap {
      max-width: 100%;
      overflow: auto;
      border: 1px solid rgba(148, 163, 184, 0.1);
      border-radius: 20px;
      background: rgba(15, 23, 42, 0.36);
    }

    .data-table {
      width: 100%;
      min-width: 900px;
      border-collapse: separate;
      border-spacing: 0;
      text-align: left;
    }

    .data-table th {
      position: sticky;
      top: 0;
      z-index: 1;
      padding: 13px 14px;
      border-bottom: 1px solid rgba(148, 163, 184, 0.14);
      background: rgba(15, 23, 42, 0.96);
      color: #94a3b8;
      font-size: 0.72rem;
      font-weight: 850;
      text-transform: uppercase;
    }

    .sort-button {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      color: inherit;
      font: inherit;
    }

    .data-table td {
      padding: 14px;
      border-bottom: 1px solid rgba(148, 163, 184, 0.08);
      color: #dbeafe;
      font-size: 0.84rem;
      vertical-align: middle;
    }

    .data-table tbody tr {
      transition: background 0.2s ease, transform 0.2s ease;
    }

    .data-table tbody tr:hover {
      background: rgba(56, 189, 248, 0.055);
    }

    .doc-name {
      display: flex;
      align-items: center;
      gap: 10px;
      min-width: 0;
    }

    .file-glyph {
      display: grid;
      width: 36px;
      height: 36px;
      flex: 0 0 auto;
      place-items: center;
      border-radius: 12px;
      background: linear-gradient(135deg, rgba(56, 189, 248, 0.16), rgba(139, 92, 246, 0.14));
      color: var(--cyan);
    }

    .doc-title {
      display: block;
      max-width: 260px;
      overflow: hidden;
      color: white;
      font-weight: 800;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .doc-sub {
      display: block;
      margin-top: 3px;
      color: var(--muted);
      font-size: 0.72rem;
    }

    .confidence {
      display: flex;
      align-items: center;
      gap: 8px;
      min-width: 120px;
    }

    .confidence-bar {
      width: 72px;
      height: 6px;
      overflow: hidden;
      border-radius: 999px;
      background: rgba(148, 163, 184, 0.14);
    }

    .confidence-bar span {
      display: block;
      height: 100%;
      border-radius: inherit;
      background: linear-gradient(90deg, var(--emerald), var(--cyan));
      box-shadow: 0 0 14px rgba(34, 211, 238, 0.4);
    }

    .row-actions {
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .pagination {
      display: flex;
      align-items: center;
      justify-content: flex-end;
      gap: 8px;
      margin-top: 14px;
    }

    .empty-state,
    .skeleton-state {
      padding: 28px;
      color: var(--muted);
      text-align: center;
    }

    .skeleton-line {
      display: block;
      width: 100%;
      height: 14px;
      border-radius: 999px;
      background: linear-gradient(90deg, rgba(148, 163, 184, 0.08), rgba(148, 163, 184, 0.2), rgba(148, 163, 184, 0.08));
      background-size: 240% 100%;
      animation: skeleton 1.4s ease-in-out infinite;
    }

    @keyframes skeleton {
      to {
        background-position: -240% 0;
      }
    }

    .page-heading {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 16px;
      margin-bottom: 16px;
      padding: 22px;
      border: 1px solid var(--border);
      border-radius: 24px;
      background: rgba(8, 17, 32, 0.62);
      backdrop-filter: var(--glass);
    }

    .page-heading h1 {
      margin: 0;
      color: white;
      font-size: clamp(1.5rem, 2.5vw, 2.2rem);
      font-weight: 850;
      letter-spacing: 0;
    }

    .page-heading p {
      max-width: 720px;
      margin: 7px 0 0;
      color: var(--muted);
      line-height: 1.6;
    }

    .kanban {
      display: grid;
      grid-template-columns: repeat(4, minmax(260px, 1fr));
      gap: 14px;
      overflow-x: auto;
      padding-bottom: 4px;
    }

    .kanban-column {
      min-height: 520px;
      border: 1px solid rgba(148, 163, 184, 0.1);
      border-radius: 20px;
      background: rgba(15, 23, 42, 0.48);
    }

    .kanban-head {
      position: sticky;
      top: 0;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 14px;
      border-bottom: 1px solid rgba(148, 163, 184, 0.1);
      background: rgba(15, 23, 42, 0.88);
      border-radius: 20px 20px 0 0;
    }

    .kanban-title {
      display: flex;
      align-items: center;
      gap: 8px;
      color: white;
      font-size: 0.78rem;
      font-weight: 850;
      text-transform: uppercase;
    }

    .status-dot {
      width: 9px;
      height: 9px;
      border-radius: 999px;
      background: var(--cyan);
      box-shadow: 0 0 14px rgba(34, 211, 238, 0.7);
    }

    .kanban-dropzone {
      display: grid;
      align-content: start;
      gap: 10px;
      min-height: 450px;
      padding: 12px;
      transition: background 0.2s ease;
    }

    .kanban-dropzone.is-over {
      background: rgba(34, 211, 238, 0.06);
    }

    .kanban-card {
      cursor: grab;
      padding: 13px;
      border: 1px solid rgba(148, 163, 184, 0.13);
      border-radius: 16px;
      background: rgba(8, 17, 32, 0.78);
      transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
    }

    .kanban-card:hover {
      transform: translateY(-3px);
      border-color: rgba(34, 211, 238, 0.32);
      box-shadow: 0 18px 44px rgba(2, 8, 23, 0.24);
    }

    .kanban-card:active {
      cursor: grabbing;
    }

    .kanban-card.dragging {
      opacity: 0.55;
      transform: rotate(1deg) scale(0.98);
    }

    .progress-track {
      height: 6px;
      overflow: hidden;
      border-radius: 999px;
      background: rgba(148, 163, 184, 0.14);
    }

    .progress-track span {
      display: block;
      height: 100%;
      border-radius: inherit;
      background: linear-gradient(90deg, var(--blue), var(--emerald));
    }

    .modal {
      position: fixed;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 20px;
      background: rgba(2, 8, 23, 0.74);
      backdrop-filter: blur(18px);
      z-index: 80;
      animation: fadeIn 0.2s ease both;
    }

    @keyframes fadeIn {
      from {
        opacity: 0;
      }
      to {
        opacity: 1;
      }
    }

    .modal-content {
      width: min(680px, 100%);
      max-height: 90vh;
      overflow: auto;
      border: 1px solid var(--border-strong);
      border-radius: 24px;
      background: linear-gradient(145deg, rgba(30, 41, 59, 0.94), rgba(8, 17, 32, 0.96));
      box-shadow: 0 34px 100px rgba(2, 8, 23, 0.6);
      animation: modalIn 0.24s ease both;
    }

    @keyframes modalIn {
      from {
        transform: translateY(16px) scale(0.98);
      }
      to {
        transform: translateY(0) scale(1);
      }
    }

    .modal-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 14px;
      padding: 18px;
      border-bottom: 1px solid var(--border);
    }

    .modal-title {
      margin: 0;
      color: white;
      font-size: 1rem;
      font-weight: 850;
    }

    .modal-body {
      padding: 18px;
    }

    .dropzone {
      display: grid;
      min-height: 220px;
      place-items: center;
      padding: 24px;
      border: 1px dashed rgba(56, 189, 248, 0.38);
      border-radius: 20px;
      background: linear-gradient(135deg, rgba(56, 189, 248, 0.08), rgba(139, 92, 246, 0.08));
      color: #cbd5e1;
      text-align: center;
      transition: border-color 0.2s ease, transform 0.2s ease, background 0.2s ease;
      cursor: pointer;
    }

    .dropzone:hover,
    .dropzone.dropzone-active {
      transform: translateY(-2px);
      border-color: rgba(34, 211, 238, 0.72);
      background: linear-gradient(135deg, rgba(56, 189, 248, 0.13), rgba(139, 92, 246, 0.11));
    }

    .search-modal-input {
      width: 100%;
      height: 58px;
      padding: 0 18px;
      border: 1px solid rgba(34, 211, 238, 0.28);
      border-radius: 18px;
      outline: none;
      background: rgba(15, 23, 42, 0.75);
      color: white;
      font-size: 1rem;
      box-shadow: 0 0 0 4px rgba(34, 211, 238, 0.06);
    }

    .suggestions {
      display: grid;
      gap: 10px;
      margin-top: 14px;
    }

    .suggestion-button {
      display: grid;
      grid-template-columns: 38px minmax(0, 1fr) auto;
      align-items: center;
      gap: 12px;
      width: 100%;
      padding: 12px;
      border: 1px solid rgba(148, 163, 184, 0.12);
      border-radius: 16px;
      background: rgba(15, 23, 42, 0.5);
      color: #e2e8f0;
      text-align: left;
      transition: transform 0.2s ease, border-color 0.2s ease, background 0.2s ease;
    }

    .suggestion-button:hover,
    .suggestion-button:focus {
      transform: translateY(-2px);
      border-color: rgba(34, 211, 238, 0.32);
      background: rgba(30, 41, 59, 0.7);
      outline: none;
    }

    .drawer {
      position: fixed;
      inset: 0;
      z-index: 75;
      pointer-events: none;
    }

    .drawer::before {
      content: "";
      position: absolute;
      inset: 0;
      background: rgba(2, 8, 23, 0);
      transition: background 0.2s ease;
    }

    .drawer.open {
      pointer-events: auto;
    }

    .drawer.open::before {
      background: rgba(2, 8, 23, 0.48);
      backdrop-filter: blur(8px);
    }

    .drawer-panel {
      position: absolute;
      top: 16px;
      right: 16px;
      bottom: 16px;
      width: min(460px, calc(100vw - 32px));
      overflow: auto;
      padding: 18px;
      border: 1px solid var(--border-strong);
      border-radius: 24px;
      background: linear-gradient(145deg, rgba(30, 41, 59, 0.96), rgba(8, 17, 32, 0.98));
      box-shadow: 0 30px 100px rgba(2, 8, 23, 0.64);
      transform: translateX(calc(100% + 32px));
      transition: transform 0.24s ease;
    }

    .drawer.open .drawer-panel {
      transform: translateX(0);
    }

    .activity-popover {
      position: fixed;
      top: 94px;
      right: 120px;
      width: min(380px, calc(100vw - 32px));
      padding: 14px;
      border: 1px solid var(--border);
      border-radius: 20px;
      background: rgba(15, 23, 42, 0.96);
      box-shadow: 0 24px 80px rgba(2, 8, 23, 0.54);
      backdrop-filter: var(--glass);
      z-index: 70;
    }

    .mini-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 12px;
    }

    .mini-tile {
      padding: 14px;
      border: 1px solid rgba(148, 163, 184, 0.11);
      border-radius: 18px;
      background: rgba(15, 23, 42, 0.5);
    }

    .mini-tile strong {
      display: block;
      color: white;
      font-size: 1.2rem;
    }

    .mini-tile span {
      color: var(--muted);
      font-size: 0.76rem;
    }

    @media (max-width: 1440px) {
      .metrics-grid {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }
    }

    @media (max-width: 1180px) {
      .hero-grid {
        grid-template-columns: 1fr;
      }

      .dashboard-grid {
        grid-template-columns: repeat(6, minmax(0, 1fr));
      }

      .span-8,
      .span-7,
      .span-6,
      .span-5,
      .span-4 {
        grid-column: span 6;
      }

      .chart-layout {
        grid-template-columns: 1fr;
      }

      .heatmap {
        grid-template-columns: repeat(14, 1fr);
      }
    }

    @media (max-width: 980px) {
      .app-shell,
      .app-shell.sidebar-collapsed {
        grid-template-columns: 1fr;
        padding: 12px;
      }

      .sidebar {
        position: fixed;
        left: 12px;
        top: 12px;
        bottom: 12px;
        width: min(312px, calc(100vw - 24px));
        height: auto;
        transform: translateX(calc(-100% - 24px));
        transition: transform 0.25s ease;
      }

      .sidebar.open {
        transform: translateX(0);
      }

      .mobile-menu {
        display: inline-grid;
      }

      .topbar {
        top: 12px;
        border-radius: 20px;
      }

      .top-actions .button span {
        display: none;
      }
    }

    @media (max-width: 760px) {
      .metrics-grid {
        grid-template-columns: 1fr;
      }

      .topbar {
        flex-wrap: wrap;
      }

      .ai-search {
        flex-basis: 100%;
        order: 3;
      }

      .hero-title {
        font-size: 2.25rem;
      }

      .summary-panel {
        padding: 12px;
      }

      .page-heading {
        flex-direction: column;
      }

      .mini-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</head>

