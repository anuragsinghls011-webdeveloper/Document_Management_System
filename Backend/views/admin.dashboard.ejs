<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin — Pending Document Approvals</title>
  <meta name="description" content="Admin panel for reviewing and approving pending documents.">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: "Inter", system-ui, -apple-system, sans-serif;
      min-height: 100vh;
      background:
        radial-gradient(1100px 620px at 10% -10%, rgba(56, 189, 248, 0.12), transparent 62%),
        radial-gradient(1000px 640px at 88% 8%, rgba(139, 92, 246, 0.1), transparent 64%),
        linear-gradient(135deg, #081120, #0B1220 48%, #111827);
      color: #f8fafc;
      opacity: 0;
      animation: pageIn 0.6s ease 0.1s forwards;
    }

    @keyframes pageIn { to { opacity: 1; } }

    body::before {
      content: "";
      position: fixed;
      inset: 0;
      pointer-events: none;
      background-image:
        linear-gradient(rgba(148, 163, 184, 0.03) 1px, transparent 1px),
        linear-gradient(90deg, rgba(148, 163, 184, 0.03) 1px, transparent 1px);
      background-size: 48px 48px;
      mask-image: linear-gradient(to bottom, rgba(0,0,0,0.8), transparent 78%);
      z-index: -1;
    }

    ::-webkit-scrollbar { width: 8px; }
    ::-webkit-scrollbar-track { background: rgba(15, 23, 42, 0.9); }
    ::-webkit-scrollbar-thumb { background: linear-gradient(180deg, rgba(56, 189, 248, 0.4), rgba(139, 92, 246, 0.4)); border-radius: 999px; }

    .container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 24px 20px;
    }

    /* Header */
    .admin-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      padding: 18px 22px;
      border: 1px solid rgba(148, 163, 184, 0.12);
      border-radius: 20px;
      background: rgba(8, 17, 32, 0.7);
      backdrop-filter: blur(18px);
      margin-bottom: 20px;
      animation: slideDown 0.5s ease 0.15s both;
    }

    @keyframes slideDown {
      from { opacity: 0; transform: translateY(-16px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .admin-header h1 {
      font-size: 1.5rem;
      font-weight: 850;
      letter-spacing: -0.01em;
    }

    .header-left {
      display: flex;
      align-items: center;
      gap: 14px;
    }

    .back-btn {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 10px 16px;
      border: 1px solid rgba(148, 163, 184, 0.14);
      border-radius: 14px;
      background: rgba(15, 23, 42, 0.6);
      color: #cbd5e1;
      font-size: 0.86rem;
      font-weight: 650;
      text-decoration: none;
      transition: all 0.2s ease;
    }

    .back-btn:hover {
      transform: translateY(-2px);
      border-color: rgba(56, 189, 248, 0.3);
      color: #fff;
      background: rgba(30, 41, 59, 0.8);
      box-shadow: 0 12px 32px rgba(8, 145, 178, 0.1);
    }

    .badge-count {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 6px 12px;
      border: 1px solid rgba(251, 146, 60, 0.2);
      border-radius: 999px;
      background: rgba(251, 146, 60, 0.1);
      color: #fdba74;
      font-size: 0.76rem;
      font-weight: 800;
    }

    .pulse-dot {
      width: 8px; height: 8px;
      border-radius: 999px;
      background: #fb923c;
      box-shadow: 0 0 0 0 rgba(251, 146, 60, 0.7);
      animation: pulseDot 2s infinite;
    }

    @keyframes pulseDot {
      70% { box-shadow: 0 0 0 10px rgba(251, 146, 60, 0); }
      100% { box-shadow: 0 0 0 0 rgba(251, 146, 60, 0); }
    }

    /* Table panel */
    .table-panel {
      border: 1px solid rgba(148, 163, 184, 0.12);
      border-radius: 24px;
      background: linear-gradient(145deg, rgba(30, 41, 59, 0.7), rgba(8, 17, 32, 0.6));
      backdrop-filter: blur(18px);
      overflow: hidden;
      box-shadow: 0 20px 60px rgba(2, 8, 23, 0.3);
      animation: slideUp 0.6s ease 0.2s both;
    }

    @keyframes slideUp {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .table-wrap {
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }

    table {
      width: 100%;
      min-width: 700px;
      border-collapse: separate;
      border-spacing: 0;
    }

    th {
      position: sticky;
      top: 0;
      padding: 14px 18px;
      border-bottom: 1px solid rgba(148, 163, 184, 0.14);
      background: rgba(15, 23, 42, 0.95);
      color: #94a3b8;
      font-size: 0.72rem;
      font-weight: 850;
      text-transform: uppercase;
      text-align: left;
      letter-spacing: 0.05em;
    }

    td {
      padding: 16px 18px;
      border-bottom: 1px solid rgba(148, 163, 184, 0.07);
      font-size: 0.88rem;
      color: #dbeafe;
      vertical-align: middle;
    }

    tbody tr {
      transition: background 0.2s ease;
    }

    tbody tr:hover {
      background: rgba(56, 189, 248, 0.04);
    }

    .file-info {
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .file-icon {
      width: 38px; height: 38px;
      display: grid;
      place-items: center;
      border-radius: 12px;
      background: linear-gradient(135deg, rgba(56, 189, 248, 0.15), rgba(139, 92, 246, 0.12));
      color: #22d3ee;
      flex-shrink: 0;
    }

    .file-name {
      font-weight: 700;
      color: #f1f5f9;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      max-width: 260px;
    }

    .status-badge {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      padding: 5px 10px;
      border-radius: 999px;
      font-size: 0.72rem;
      font-weight: 800;
      text-transform: capitalize;
    }

    .status-badge.pending {
      border: 1px solid rgba(251, 146, 60, 0.22);
      background: rgba(251, 146, 60, 0.1);
      color: #fed7aa;
    }

    .status-badge.approved {
      border: 1px solid rgba(52, 211, 153, 0.22);
      background: rgba(52, 211, 153, 0.1);
      color: #bbf7d0;
    }

    .status-badge.rejected {
      border: 1px solid rgba(251, 113, 133, 0.22);
      background: rgba(251, 113, 133, 0.1);
      color: #fecdd3;
    }

    .actions-cell {
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .action-btn {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 8px 14px;
      border: none;
      border-radius: 12px;
      font-size: 0.8rem;
      font-weight: 700;
      cursor: pointer;
      transition: all 0.25s ease;
    }

    .btn-approve {
      background: linear-gradient(135deg, rgba(52, 211, 153, 0.9), rgba(20, 184, 166, 0.85));
      color: #fff;
      box-shadow: 0 8px 20px rgba(20, 184, 166, 0.2);
    }

    .btn-approve:hover {
      transform: translateY(-2px);
      box-shadow: 0 14px 30px rgba(20, 184, 166, 0.35);
    }

    .btn-reject {
      background: linear-gradient(135deg, rgba(251, 113, 133, 0.85), rgba(239, 68, 68, 0.8));
      color: #fff;
      box-shadow: 0 8px 20px rgba(239, 68, 68, 0.15);
    }

    .btn-reject:hover {
      transform: translateY(-2px);
      box-shadow: 0 14px 30px rgba(239, 68, 68, 0.3);
    }

    .btn-review {
      background: linear-gradient(135deg, rgba(56, 189, 248, 0.95), rgba(37, 99, 235, 0.9));
      color: #fff;
      box-shadow: 0 8px 20px rgba(37, 99, 235, 0.25);
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      justify-content: center;
    }

    .btn-review:hover {
      transform: translateY(-2px);
      box-shadow: 0 14px 30px rgba(37, 99, 235, 0.4);
    }

    .empty-state {
      padding: 48px 24px;
      text-align: center;
      color: #64748b;
    }

    .empty-state svg {
      margin: 0 auto 16px;
      opacity: 0.3;
    }

    .empty-state p {
      font-size: 0.9rem;
      font-weight: 600;
    }

    /* Loading skeleton */
    .skeleton-row td {
      padding: 20px 18px;
    }

    .skeleton-line {
      height: 14px;
      border-radius: 8px;
      background: linear-gradient(90deg, rgba(148,163,184,0.06), rgba(148,163,184,0.15), rgba(148,163,184,0.06));
      background-size: 240% 100%;
      animation: shimmer 1.4s ease-in-out infinite;
    }

    @keyframes shimmer { to { background-position: -240% 0; } }

    /* Confirm modal */
    .confirm-modal {
      position: fixed;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 20px;
      background: rgba(2, 8, 23, 0.7);
      backdrop-filter: blur(12px);
      z-index: 80;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.2s ease;
    }

    .confirm-modal.active {
      opacity: 1;
      pointer-events: auto;
    }

    .confirm-modal-content {
      width: min(400px, 100%);
      padding: 24px;
      border: 1px solid rgba(148, 163, 184, 0.2);
      border-radius: 20px;
      background: linear-gradient(145deg, rgba(30, 41, 59, 0.95), rgba(8, 17, 32, 0.98));
      box-shadow: 0 30px 80px rgba(2, 8, 23, 0.6);
      transform: translateY(20px) scale(0.95);
      transition: transform 0.25s ease;
      text-align: center;
    }

    .confirm-modal.active .confirm-modal-content {
      transform: translateY(0) scale(1);
    }

    .confirm-modal h3 {
      font-size: 1.1rem;
      font-weight: 800;
      margin-bottom: 8px;
    }

    .confirm-modal p {
      color: #94a3b8;
      font-size: 0.88rem;
      margin-bottom: 20px;
    }

    .confirm-modal textarea {
      width: 100%;
      padding: 10px 14px;
      border: 1px solid rgba(148, 163, 184, 0.15);
      border-radius: 12px;
      background: rgba(15, 23, 42, 0.6);
      color: #f8fafc;
      font-size: 0.88rem;
      resize: none;
      outline: none;
      margin-bottom: 16px;
      font-family: inherit;
    }

    .confirm-modal textarea:focus {
      border-color: rgba(56, 189, 248, 0.5);
    }

    .confirm-actions {
      display: flex;
      gap: 10px;
      justify-content: center;
    }

    .confirm-actions button {
      padding: 10px 20px;
      border: none;
      border-radius: 12px;
      font-weight: 700;
      font-size: 0.86rem;
      cursor: pointer;
      transition: all 0.2s ease;
    }

    .cancel-btn {
      background: rgba(15, 23, 42, 0.6);
      border: 1px solid rgba(148, 163, 184, 0.15) !important;
      color: #cbd5e1;
    }

    .cancel-btn:hover {
      background: rgba(30, 41, 59, 0.8);
    }

    @media (max-width: 640px) {
      .admin-header {
        flex-direction: column;
        align-items: flex-start;
      }

      .header-left {
        flex-direction: column;
        align-items: flex-start;
      }
    }
  </style>
</head>
<body>
  <div class="container">
    <header class="admin-header">
      <div class="header-left">
        <a href="/dashboard" class="back-btn">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
          Dashboard
        </a>
        <h1>Pending Approvals</h1>
      </div>
      <span id="pendingCount" class="badge-count">
        <span class="pulse-dot"></span> Loading...
      </span>
    </header>

    <div class="table-panel">
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Document</th>
              <th>Submitted By</th>
              <th>Status</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody id="admin-docs">
            <tr class="skeleton-row"><td><div class="skeleton-line" style="width:60%"></div></td><td><div class="skeleton-line" style="width:40%"></div></td><td><div class="skeleton-line" style="width:30%"></div></td><td><div class="skeleton-line" style="width:50%"></div></td></tr>
            <tr class="skeleton-row"><td><div class="skeleton-line" style="width:55%"></div></td><td><div class="skeleton-line" style="width:35%"></div></td><td><div class="skeleton-line" style="width:25%"></div></td><td><div class="skeleton-line" style="width:45%"></div></td></tr>
            <tr class="skeleton-row"><td><div class="skeleton-line" style="width:65%"></div></td><td><div class="skeleton-line" style="width:45%"></div></td><td><div class="skeleton-line" style="width:28%"></div></td><td><div class="skeleton-line" style="width:50%"></div></td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- Confirm modal -->
  <div id="confirmModal" class="confirm-modal" onclick="if(event.target===this)closeModal()">
    <div class="confirm-modal-content">
      <h3 id="modalTitle"></h3>
      <p id="modalDesc"></p>
      <textarea id="modalReason" rows="3" placeholder="Reason (optional)..." style="display:none"></textarea>
      <div class="confirm-actions">
        <button class="cancel-btn" onclick="closeModal()">Cancel</button>
        <button id="modalConfirmBtn" class="action-btn"></button>
      </div>
    </div>
  </div>

  <script>
    let pendingAction = null;

    function escapeHtml(str) {
      return String(str || '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
    }

    async function loadPendingDocs() {
      try {
        const res = await fetch("/admin/pending", { credentials: "include" });
        if (!res.ok) return;

        const data = await res.json();
        const docs = data.documents || [];
        const tbody = document.getElementById("admin-docs");
        const countBadge = document.getElementById("pendingCount");

        countBadge.innerHTML = `<span class="pulse-dot"></span> ${docs.length} pending`;

        if (docs.length === 0) {
          tbody.innerHTML = `
            <tr><td colspan="4">
              <div class="empty-state">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                  <polyline points="22 4 12 14.01 9 11.01"/>
                </svg>
                <p>No pending documents — all clear!</p>
              </div>
            </td></tr>`;
          return;
        }

        tbody.innerHTML = docs.map(doc => `
          <tr>
            <td>
              <div class="file-info">
                <div class="file-icon">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                    <polyline points="14 2 14 8 20 8"/>
                  </svg>
                </div>
                <a href="/admin/pending-docs?id=${doc._id}" class="file-name" style="color:#22d3ee; text-decoration:none; font-weight:600; transition:color 0.2s;" onmouseover="this.style.color='#38bdf8'" onmouseout="this.style.color='#22d3ee'">${escapeHtml(doc.fileName)}</a>
              </div>
            </td>
            <td>${escapeHtml(doc.userId?.email || "-")}</td>
            <td><span class="status-badge pending">${escapeHtml(doc.status)}</span></td>
            <td>
              <div class="actions-cell">
                <a class="action-btn btn-review" href="/admin/pending-docs?id=${doc._id}">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                  Review
                </a>
                <button class="action-btn btn-approve" onclick="showConfirm('approve', '${doc._id}', '${escapeHtml(doc.fileName)}')">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
                  Approve
                </button>
                <button class="action-btn btn-reject" onclick="showConfirm('reject', '${doc._id}', '${escapeHtml(doc.fileName)}')">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                  Reject
                </button>
              </div>
            </td>
          </tr>
        `).join('');
      } catch (err) {
        console.error("Failed to load docs", err);
      }
    }

    function showConfirm(action, id, name) {
      const modal = document.getElementById('confirmModal');
      const title = document.getElementById('modalTitle');
      const desc = document.getElementById('modalDesc');
      const reason = document.getElementById('modalReason');
      const btn = document.getElementById('modalConfirmBtn');

      pendingAction = { action, id };

      if (action === 'approve') {
        title.textContent = 'Approve Document';
        desc.textContent = `Are you sure you want to approve "${name}"?`;
        reason.style.display = 'none';
        btn.textContent = 'Approve';
        btn.className = 'action-btn btn-approve';
      } else {
        title.textContent = 'Reject Document';
        desc.textContent = `Are you sure you want to reject "${name}"?`;
        reason.style.display = 'block';
        reason.value = '';
        btn.textContent = 'Reject';
        btn.className = 'action-btn btn-reject';
      }

      btn.onclick = executeAction;
      modal.classList.add('active');
    }

    function closeModal() {
      document.getElementById('confirmModal').classList.remove('active');
      pendingAction = null;
    }

    async function executeAction() {
      if (!pendingAction) return;
      const { action, id } = pendingAction;
      const btn = document.getElementById('modalConfirmBtn');
      btn.textContent = 'Processing...';
      btn.disabled = true;

      try {
        if (action === 'approve') {
          await fetch(`/admin/approve/${id}`, { method: "POST", credentials: "include" });
        } else {
          const reason = document.getElementById('modalReason').value || '';
          await fetch(`/admin/reject/${id}`, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ reason }),
            credentials: "include"
          });
        }
      } catch (err) {
        console.error("Action failed", err);
      }

      closeModal();
      loadPendingDocs();
    }

    document.addEventListener('keydown', e => {
      if (e.key === 'Escape') closeModal();
    });

    loadPendingDocs();
  </script>
</body>
</html>
