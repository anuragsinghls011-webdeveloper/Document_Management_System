<!DOCTYPE html>
<html lang="en" class="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Create Account — Document Intelligence</title>
  <meta name="description" content="Create your enterprise document intelligence account.">
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/assets/css/enterprise.css">
  <script defer src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/gsap.min.js"></script>
  <script defer src="https://cdn.jsdelivr.net/npm/@studio-freight/lenis@1.0.42/bundled/lenis.min.js"></script>
  <script defer src="/assets/js/enterprise.js"></script>
</head>
<body>
  <main class="auth-shell min-h-screen py-6 lg:py-10">
    <div class="auth-grid items-stretch">
      <section class="auth-visual reveal hidden overflow-hidden rounded-[32px] p-8 lg:block">
        <div class="space-y-10">
          <div>
            <div class="hero-kicker">Enterprise Onboarding</div>
            <h1 class="hero-title mt-6 max-w-xl leading-[0.92]">Create an account for your premium AI document workspace.</h1>
            <p class="hero-copy mt-5 max-w-lg text-white/70">Bring OCR, semantic search, approvals, analytics, and audit trails into one elegant enterprise platform.</p>
          </div>

          <div class="grid gap-4 sm:grid-cols-2">
            <div class="summary-card"><p class="caption">Setup time</p><p class="text-2xl font-bold">Under 5 min</p></div>
            <div class="summary-card"><p class="caption">Workspace roles</p><p class="text-2xl font-bold">Flexible</p></div>
            <div class="summary-card"><p class="caption">Security</p><p class="text-2xl font-bold">Enterprise</p></div>
            <div class="summary-card"><p class="caption">Automation</p><p class="text-2xl font-bold">Ready</p></div>
          </div>

          <div class="hero-card">
            <p class="kicker mb-4">What you get</p>
            <div class="space-y-3 text-sm text-white/65">
              <div class="flex items-center justify-between rounded-2xl border border-white/8 bg-black/20 px-4 py-3"><span>AI summaries</span><span class="badge approved">Included</span></div>
              <div class="flex items-center justify-between rounded-2xl border border-white/8 bg-black/20 px-4 py-3"><span>Approval workflow</span><span class="badge pending">Live</span></div>
              <div class="flex items-center justify-between rounded-2xl border border-white/8 bg-black/20 px-4 py-3"><span>Audit logging</span><span class="badge">Enabled</span></div>
            </div>
          </div>
        </div>
      </section>

      <section class="form-card reveal mx-auto w-full max-w-xl rounded-[32px] p-6 sm:p-8 lg:p-10">
        <div class="flex items-center justify-between">
          <a href="/" class="inline-flex items-center gap-2 text-white/55 transition hover:text-white">
            <i data-feather="arrow-left" class="h-4 w-4"></i>
            Back to home
          </a>
          <span class="badge">Secure onboarding</span>
        </div>

        <div class="mt-10 space-y-3">
          <div class="hero-kicker">Create account</div>
          <h2 class="dashboard-title text-[clamp(2rem,4vw,3rem)] leading-[0.95]">Start your enterprise workspace.</h2>
          <p class="body-copy max-w-md">Create an account to manage documents with AI-driven workflows, premium UX, and enterprise-grade controls.</p>
        </div>

        <form id="registerForm" class="mt-10 space-y-5" action="/register" method="POST" novalidate>
          <div id="globalError" class="hidden rounded-2xl border border-[rgba(255,90,95,0.3)] bg-[rgba(255,90,95,0.08)] px-4 py-3 text-sm text-danger"></div>

          <div>
            <label for="fullName" class="mb-2 block text-sm font-semibold text-white/75">Full name</label>
            <input id="fullName" name="username" type="text" autocomplete="name" required class="input-field" placeholder="John Doe">
            <p id="nameError" class="caption mt-2 hidden text-danger">Please enter your full name.</p>
          </div>

          <div>
            <label for="email" class="mb-2 block text-sm font-semibold text-white/75">Email address</label>
            <input id="email" name="email" type="email" autocomplete="email" required class="input-field" placeholder="you@company.com">
            <p id="emailError" class="caption mt-2 hidden text-danger">Please enter a valid email address.</p>
          </div>

          <div>
            <label for="password" class="mb-2 block text-sm font-semibold text-white/75">Password</label>
            <input id="password" name="password" type="password" autocomplete="new-password" required class="input-field" placeholder="At least 8 characters">
            <div class="strength-bar mt-3"><div id="strengthFill" class="fill"></div></div>
            <p id="strengthLabel" class="strength-label text-white/40">Enter a password</p>
            <p id="passwordError" class="caption mt-2 hidden text-danger">Password is too weak.</p>
          </div>

          <div>
            <label for="confirm-password" class="mb-2 block text-sm font-semibold text-white/75">Confirm password</label>
            <input id="confirm-password" name="confirm-password" type="password" autocomplete="new-password" required class="input-field" placeholder="Repeat your password">
            <p id="matchIndicator" class="match-indicator"></p>
            <p id="confirmError" class="caption mt-2 hidden text-danger">Passwords do not match.</p>
          </div>

          <button type="submit" id="submitBtn" class="submit-btn magnetic w-full">
            <span class="btn-text">Create account</span>
            <span class="spinner"></span>
          </button>
        </form>

        <div class="my-8 flex items-center gap-3">
          <span class="h-px flex-1 bg-white/8"></span>
          <span class="text-xs uppercase tracking-[0.28em] text-white/35">or continue with</span>
          <span class="h-px flex-1 bg-white/8"></span>
        </div>

        <div class="grid grid-cols-3 gap-3">
          <button class="icon-button h-12 w-full rounded-2xl" type="button" aria-label="Sign up with Google"><i data-feather="chrome"></i></button>
          <button class="icon-button h-12 w-full rounded-2xl" type="button" aria-label="Sign up with GitHub"><i data-feather="github"></i></button>
          <button class="icon-button h-12 w-full rounded-2xl" type="button" aria-label="Sign up with Microsoft"><i data-feather="grid"></i></button>
        </div>

        <p class="mt-8 text-center text-sm text-white/55">
          Already have an account?
          <a href="/login" class="font-semibold text-white transition hover:text-[#BFD4FF]">Sign in</a>
        </p>
      </section>
    </div>
  </main>

  <script>
    if (window.feather) feather.replace();

    const form = document.getElementById('registerForm');
    const nameInput = document.getElementById('fullName');
    const emailInput = document.getElementById('email');
    const passwordInput = document.getElementById('password');
    const confirmInput = document.getElementById('confirm-password');
    const submitBtn = document.getElementById('submitBtn');
    const strengthFill = document.getElementById('strengthFill');
    const strengthLabel = document.getElementById('strengthLabel');
    const matchIndicator = document.getElementById('matchIndicator');
    const globalError = document.getElementById('globalError');

    const validateEmail = email => /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
    const getStrength = pw => {
      let score = 0;
      if (pw.length >= 8) score += 1;
      if (pw.length >= 12) score += 1;
      if (/[A-Z]/.test(pw)) score += 1;
      if (/[0-9]/.test(pw)) score += 1;
      if (/[^A-Za-z0-9]/.test(pw)) score += 1;
      return score;
    };

    const showError = (input, errorEl) => {
      input.classList.add('error');
      errorEl.classList.remove('hidden');
    };

    const clearError = (input, errorEl) => {
      input.classList.remove('error');
      errorEl.classList.add('hidden');
    };

    const updateStrength = () => {
      const score = getStrength(passwordInput.value);
      const levels = [
        { width: '0%', color: 'transparent', label: 'Enter a password' },
        { width: '20%', color: '#FF5A5F', label: 'Very weak' },
        { width: '40%', color: '#FFC857', label: 'Weak' },
        { width: '60%', color: '#FFC857', label: 'Fair' },
        { width: '80%', color: '#00D084', label: 'Strong' },
        { width: '100%', color: '#8A5CFF', label: 'Very strong' }
      ];
      const level = passwordInput.value.length === 0 ? levels[0] : levels[Math.min(score, 5)];
      strengthFill.style.width = level.width;
      strengthFill.style.background = level.color;
      strengthLabel.textContent = level.label;
      strengthLabel.style.color = level.color === 'transparent' ? '#64748b' : level.color;
    };

    const checkMatch = () => {
      const pw = passwordInput.value;
      const cpw = confirmInput.value;

      if (!cpw) {
        matchIndicator.style.display = 'none';
        confirmInput.classList.remove('success', 'error');
        return;
      }

      matchIndicator.style.display = 'block';
      if (pw === cpw) {
        matchIndicator.textContent = '✓ Passwords match';
        matchIndicator.style.color = '#00D084';
        confirmInput.classList.add('success');
        confirmInput.classList.remove('error');
      } else {
        matchIndicator.textContent = '✗ Passwords do not match';
        matchIndicator.style.color = '#FF5A5F';
        confirmInput.classList.remove('success');
      }
    };

    passwordInput.addEventListener('input', () => {
      clearError(passwordInput, document.getElementById('passwordError'));
      globalError.classList.add('hidden');
      updateStrength();
      checkMatch();
    });

    confirmInput.addEventListener('input', () => {
      clearError(confirmInput, document.getElementById('confirmError'));
      globalError.classList.add('hidden');
      checkMatch();
    });

    nameInput.addEventListener('input', () => {
      clearError(nameInput, document.getElementById('nameError'));
      globalError.classList.add('hidden');
    });

    emailInput.addEventListener('input', () => {
      clearError(emailInput, document.getElementById('emailError'));
      globalError.classList.add('hidden');
    });

    form.addEventListener('submit', event => {
      event.preventDefault();
      let valid = true;

      if (!nameInput.value.trim()) {
        showError(nameInput, document.getElementById('nameError'));
        valid = false;
      }

      if (!validateEmail(emailInput.value.trim())) {
        showError(emailInput, document.getElementById('emailError'));
        valid = false;
      }

      if (getStrength(passwordInput.value) < 2) {
        showError(passwordInput, document.getElementById('passwordError'));
        valid = false;
      }

      if (passwordInput.value !== confirmInput.value) {
        showError(confirmInput, document.getElementById('confirmError'));
        valid = false;
      }

      if (!valid) return;

      submitBtn.classList.add('loading');
      submitBtn.disabled = true;

      const body = new URLSearchParams(new FormData(form)).toString();

      fetch(form.action, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/x-www-form-urlencoded',
          'Accept': 'application/json'
        },
        body
      })
      .then(async response => {
        const isJson = response.headers.get('content-type')?.includes('application/json');
        const data = isJson ? await response.json() : null;

        if (!response.ok) {
          throw new Error(data?.message || 'Registration failed. Please try again.');
        }

        window.location.href = data?.redirect || '/login';
      })
      .catch(error => {
        submitBtn.classList.remove('loading');
        submitBtn.disabled = false;
        globalError.textContent = error.message;
        globalError.classList.remove('hidden');
      });
    });
  </script>
</body>
</html>