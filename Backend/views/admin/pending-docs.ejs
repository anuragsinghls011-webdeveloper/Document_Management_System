<!DOCTYPE html>
<html lang="en" class="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Document Review Workspace</title>
  <meta name="description" content="Premium approval workspace for reviewing pending documents.">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/assets/css/enterprise.css">
  <script defer src="https://cdn.jsdelivr.net/npm/feather-icons/dist/feather.min.js"></script>
  <script defer src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/gsap.min.js"></script>
  <script defer src="https://cdn.jsdelivr.net/npm/@studio-freight/lenis@1.0.42/bundled/lenis.min.js"></script>
  <script defer src="/assets/js/enterprise.js"></script>
  <style>
    .review-shell { width: min(100%, 1540px); margin: 0 auto; padding: 18px; display: grid; gap: 18px; }
    .review-topbar { display: flex; align-items: center; justify-content: space-between; gap: 14px; padding: 18px 20px; }
    .review-grid { display: grid; grid-template-columns: 1.15fr 0.85fr; gap: 18px; align-items: start; }
    .hero-panel { padding: 22px; }
    .hero-title { font-size: clamp(2rem, 3.8vw, 3.5rem); font-weight: 900; letter-spacing: -0.06em; line-height: 0.95; margin: 10px 0 12px; }
    .hero-copy { color: var(--muted); max-width: 75ch; line-height: 1.7; }
    .hero-stats { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 12px; margin-top: 18px; }
    .hero-stat { padding: 16px; border-radius: 20px; background: rgba(255,255,255,0.03); border: 1px solid var(--border); }
    .hero-stat span { display: block; color: var(--muted); font-size: 0.76rem; margin-bottom: 6px; }
    .hero-stat strong { font-size: 1.1rem; }
    .review-layout { display: grid; grid-template-columns: minmax(0, 1.05fr) minmax(360px, 0.95fr); gap: 18px; align-items: start; }
    .feature-card { padding: 18px; }
    .feature-header { display: flex; align-items: center; justify-content: space-between; gap: 10px; margin-bottom: 16px; }
    .feature-title { font-size: 1rem; font-weight: 850; margin: 0; }
    .feature-subtitle { color: var(--muted); font-size: 0.84rem; margin-top: 4px; }
    .document-card { padding: 18px; display: grid; gap: 16px; }
    .document-header { display: flex; align-items: center; gap: 14px; flex-wrap: wrap; }
    .document-icon { width: 56px; height: 56px; display: grid; place-items: center; border-radius: 18px; background: rgba(79,139,255,0.12); color: #8bb3ff; flex: 0 0 auto; }
    .document-title { font-size: 1.15rem; font-weight: 900; margin: 0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .document-meta { display: flex; flex-wrap: wrap; gap: 10px 14px; margin-top: 8px; color: var(--muted); font-size: 0.8rem; }
    .meta-item { display: inline-flex; align-items: center; gap: 6px; }
    .status-badge { display: inline-flex; align-items: center; gap: 8px; padding: 8px 14px; border-radius: 999px; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); color: var(--warning); font-size: 0.77rem; font-weight: 800; text-transform: capitalize; }
    .status-dot { width: 8px; height: 8px; border-radius: 999px; background: currentColor; box-shadow: 0 0 12px currentColor; }
    .content-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; }
    .summary-content { padding: 18px; border-radius: 20px; background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.06); }
    .summary-paragraph { color: #d5dbe8; line-height: 1.75; margin: 0 0 16px; }
    .key-points-title, .entities-title, .sentiment-title { font-size: 0.82rem; font-weight: 850; color: var(--text); margin-bottom: 10px; letter-spacing: 0.03em; }
    .key-points-list { list-style: none; display: grid; gap: 8px; margin: 0; padding: 0; }
    .key-points-list li { position: relative; padding-left: 18px; color: var(--muted); font-size: 0.86rem; line-height: 1.55; }
    .key-points-list li::before { content: ''; position: absolute; left: 0; top: 0.55rem; width: 6px; height: 6px; border-radius: 50%; background: #22d3ee; box-shadow: 0 0 8px rgba(34,211,238,0.5); }
    .entity-tags { display: flex; flex-wrap: wrap; gap: 8px; }
    .entity-tag { padding: 6px 10px; border-radius: 999px; background: rgba(79,139,255,0.08); border: 1px solid rgba(79,139,255,0.18); color: #b9ceff; font-size: 0.74rem; font-weight: 700; }
    .preview-container { display: grid; gap: 12px; }
    .preview-placeholder { min-height: 280px; display: grid; place-items: center; text-align: center; padding: 24px; border-radius: 20px; border: 1px dashed rgba(255,255,255,0.12); background: rgba(255,255,255,0.025); color: var(--muted); }
    .preview-placeholder p { margin: 10px 0 0; font-size: 0.84rem; }
    .checklist { display: grid; gap: 10px; }
    .check-item { display: flex; align-items: flex-start; gap: 12px; padding: 14px; border-radius: 16px; background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.05); }
    .checkbox-input { margin-top: 3px; accent-color: #4f8bff; }
    .check-copy strong { display: block; font-size: 0.88rem; margin-bottom: 4px; }
    .check-copy span { color: var(--muted); font-size: 0.82rem; line-height: 1.45; }
    .progress-shell { padding: 16px; border-radius: 18px; background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.06); }
    .progress-track { height: 8px; border-radius: 999px; background: rgba(255,255,255,0.08); overflow: hidden; }
    .progress-fill { height: 100%; width: 0%; border-radius: inherit; background: linear-gradient(90deg, #4f8bff, #8a5cff); transition: width 220ms ease; }
    .comments-container { display: grid; gap: 10px; }
    .comment-item { display: flex; gap: 10px; padding: 12px; border-radius: 16px; background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.05); }
    .comment-avatar { width: 36px; height: 36px; border-radius: 12px; display: grid; place-items: center; background: linear-gradient(135deg, rgba(79,139,255,0.9), rgba(138,92,255,0.8)); color: #fff; font-size: 0.72rem; font-weight: 900; flex: 0 0 auto; }
    .comment-content { min-width: 0; }
    .comment-header { display: flex; align-items: center; justify-content: space-between; gap: 12px; margin-bottom: 4px; }
    .comment-author { font-size: 0.82rem; font-weight: 800; }
    .comment-time { color: var(--muted); font-size: 0.72rem; }
    .comment-text { color: var(--muted); font-size: 0.84rem; line-height: 1.55; }
    .comment-input-wrapper { display: grid; gap: 10px; }
    .comment-input, .decision-notes { width: 100%; padding: 12px 14px; border-radius: 16px; border: 1px solid rgba(255,255,255,0.09); background: rgba(8,12,18,0.7); color: var(--text); outline: none; resize: none; }
    .comment-input:focus, .decision-notes:focus { border-color: rgba(79,139,255,0.45); }
    .decision-panel { display: grid; gap: 14px; }
    .action-stack { display: flex; flex-wrap: wrap; gap: 10px; }
    .history-list { display: grid; gap: 10px; }
    .history-item { display: flex; align-items: center; justify-content: space-between; gap: 10px; padding: 12px 14px; border-radius: 16px; background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.05); }
    .history-item strong { font-size: 0.86rem; }
    .history-item span { color: var(--muted); font-size: 0.78rem; }
    .modal { position: fixed; inset: 0; display: grid; place-items: center; padding: 20px; background: rgba(2,6,23,0.7); backdrop-filter: blur(10px); opacity: 0; pointer-events: none; transition: 180ms ease; z-index: 80; }
    .modal.active { opacity: 1; pointer-events: auto; }
    .modal-content { width: min(100%, 420px); padding: 22px; border-radius: 24px; background: linear-gradient(180deg, rgba(18,24,35,0.98), rgba(10,14,22,0.98)); border: 1px solid rgba(255,255,255,0.08); }
    .modal-icon { width: 56px; height: 56px; border-radius: 18px; display: grid; place-items: center; margin: 0 auto 14px; }
    .modal-icon.success { background: rgba(52,211,153,0.14); color: #34d399; }
    .modal-icon.error { background: rgba(251,113,133,0.14); color: #fb7185; }
    .modal-title { text-align: center; font-size: 1.08rem; font-weight: 850; margin: 0 0 8px; }
    .modal-message { text-align: center; color: var(--muted); margin-bottom: 18px; }
    .modal-content .button { width: 100%; justify-content: center; }
    @media (max-width: 1180px) {
      .review-grid, .review-layout, .content-grid { grid-template-columns: 1fr; }
      .hero-stats { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    }
    @media (max-width: 760px) {
      .review-topbar { flex-direction: column; align-items: flex-start; }
      .hero-stats { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>
  <div class="review-shell">
    <header class="panel review-topbar">
      <div>
        <div class="eyebrow"><span class="pulse-dot"></span><span>Approval workspace</span></div>
        <h1 class="dashboard-title">Where a document becomes a decision.</h1>
        <p class="hero-copy">Review the summary, inspect the checklist, comment on changes, and use the approval actions without leaving the workspace.</p>
      </div>
      <div class="action-stack">
        <a href="/admin/dashboard" class="button"><i data-feather="arrow-left"></i>Back to queue</a>
        <a id="viewDocumentBtn" href="#" target="_blank" rel="noreferrer" class="button primary"><i data-feather="external-link"></i>Open file</a>
      </div>
    </header>

    <section class="review-grid">
      <article class="panel hero-panel">
        <div class="document-card">
          <div class="document-header">
            <div class="document-icon"><i data-feather="file-text"></i></div>
            <div class="document-info">
              <p id="documentTitle" class="document-title">Loading document...</p>
              <div class="document-meta">
                <span class="meta-item"><i data-feather="calendar"></i><span id="submittedDate">-</span></span>
                <span class="meta-item"><i data-feather="user"></i><span id="submittedBy">-</span></span>
                <span class="meta-item"><i data-feather="archive"></i><span id="fileSize">-</span></span>
              </div>
            </div>
            <span id="statusBadge" class="status-badge"><span class="status-dot"></span> pending</span>
          </div>
        </div>

        <div class="content-grid">
          <section class="feature-card">
            <div class="feature-header">
              <div>
                <p class="feature-title">AI summary</p>
                <p class="feature-subtitle">Extracted context, keywords, and metadata.</p>
              </div>
              <span class="ai-badge"><i data-feather="cpu"></i>AI assisted</span>
            </div>
            <div id="summaryText" class="summary-content">
              <p class="summary-paragraph">Loading summary...</p>
            </div>
          </section>

          <section class="feature-card">
            <div class="feature-header">
              <div>
                <p class="feature-title">Preview</p>
                <p class="feature-subtitle">Open the source file or inspect the fallback preview pane.</p>
              </div>
              <button id="viewDocumentBtn" class="button" type="button"><i data-feather="eye"></i>View file</button>
            </div>
            <div class="preview-container">
              <div class="preview-placeholder" id="previewPlaceholder">
                <div>
                  <i data-feather="file"></i>
                  <p>Preview opens the original document in a new tab.</p>
                </div>
              </div>
              <div class="history-list">
                <div class="history-item"><strong>Review state</strong><span id="statusHint">Awaiting decision</span></div>
                <div class="history-item"><strong>AI confidence</strong><span id="confidenceHint">Loaded after fetch</span></div>
                <div class="history-item"><strong>Comment policy</strong><span>Required for change requests</span></div>
              </div>
            </div>
          </section>
        </div>
      </article>

      <aside class="review-layout">
        <section class="feature-card decision-panel">
          <div class="feature-header">
            <div>
              <p class="feature-title">Checklist</p>
              <p class="feature-subtitle">Mark the review points before making a decision.</p>
            </div>
            <div class="badge"><i data-feather="shield"></i>Policy</div>
          </div>
          <div class="progress-shell">
            <div class="panel-subtitle" style="margin-bottom:10px;"><span id="progressText">0 of 0 completed</span></div>
            <div class="progress-track"><div id="progressFill" class="progress-fill"></div></div>
          </div>
          <div id="checklist" class="checklist">
            <label class="check-item"><input class="checkbox-input" type="checkbox"><div class="check-copy"><strong>Identity validated</strong><span>Confirm the document owner and submission source.</span></div></label>
            <label class="check-item"><input class="checkbox-input" type="checkbox"><div class="check-copy"><strong>Summary reviewed</strong><span>Compare the AI summary against the uploaded file content.</span></div></label>
            <label class="check-item"><input class="checkbox-input" type="checkbox"><div class="check-copy"><strong>Key fields checked</strong><span>Validate amounts, dates, names, or other extracted values.</span></div></label>
            <label class="check-item"><input class="checkbox-input" type="checkbox"><div class="check-copy"><strong>Policy cleared</strong><span>Confirm the document can move through the approval policy.</span></div></label>
            <label class="check-item"><input class="checkbox-input" type="checkbox"><div class="check-copy"><strong>Decision ready</strong><span>Make sure the final action is consistent with the review notes.</span></div></label>
          </div>
        </section>

        <section class="feature-card decision-panel">
          <div class="feature-header">
            <div>
              <p class="feature-title">Decision notes</p>
              <p class="feature-subtitle">Used for rejections and change requests.</p>
            </div>
          </div>
          <textarea id="decisionNotes" class="decision-notes" rows="5" placeholder="Add notes for the submitter or reviewer..."></textarea>
          <div class="action-stack">
            <button id="approveBtn" class="button primary" type="button"><i data-feather="check-circle"></i>Approve</button>
            <button id="rejectBtn" class="button danger" type="button"><i data-feather="x-circle"></i>Reject</button>
            <button id="requestChangesBtn" class="button" type="button"><i data-feather="message-square"></i>Request changes</button>
          </div>
        </section>

        <section class="feature-card decision-panel">
          <div class="feature-header">
            <div>
              <p class="feature-title">Review comments</p>
              <p class="feature-subtitle">Add internal notes for the decision trail.</p>
            </div>
          </div>
          <div class="comments-container">
            <div class="comment-item">
              <div class="comment-avatar">AI</div>
              <div class="comment-content"><div class="comment-header"><span class="comment-author">AI intake</span><span class="comment-time">Just now</span></div><p class="comment-text">The document is ready for manual verification.</p></div>
            </div>
          </div>
          <div class="comment-input-wrapper">
            <textarea id="commentInput" class="comment-input" rows="3" placeholder="Write an internal note..."></textarea>
            <button id="addCommentBtn" class="button" type="button"><i data-feather="plus"></i>Add note</button>
          </div>
        </section>
      </aside>
    </section>
  </div>

  <div class="modal" id="notificationModal">
    <div class="modal-content">
      <div class="modal-icon" id="modalIcon"></div>
      <h3 class="modal-title" id="modalTitle"></h3>
      <p class="modal-message" id="modalMessage"></p>
      <button class="button primary" id="modalCloseBtn" type="button">Close</button>
    </div>
  </div>

  <script>
    const urlParams = new URLSearchParams(window.location.search);
    const docId = urlParams.get('id');

    if (!docId) {
      window.location.href = '/admin/dashboard';
    }

    const checklist = document.getElementById('checklist');
    const progressFill = document.getElementById('progressFill');
    const progressText = document.getElementById('progressText');

    function updateProgress() {
      const boxes = checklist.querySelectorAll('.checkbox-input');
      const checked = Array.from(boxes).filter(box => box.checked).length;
      const pct = Math.round((checked / boxes.length) * 100);
      progressFill.style.width = `${pct}%`;
      progressText.textContent = `${checked} of ${boxes.length} completed`;
    }

    checklist.addEventListener('change', updateProgress);

    document.getElementById('addCommentBtn').addEventListener('click', () => {
      const input = document.getElementById('commentInput');
      const text = input.value.trim();
      if (!text) return;
      const container = document.querySelector('.comments-container');
      const item = document.createElement('div');
      item.className = 'comment-item';
      item.innerHTML = `
        <div class="comment-avatar">YO</div>
        <div class="comment-content">
          <div class="comment-header"><span class="comment-author">You</span><span class="comment-time">Just now</span></div>
          <p class="comment-text">${text.replace(/</g, '&lt;').replace(/>/g, '&gt;')}</p>
        </div>`;
      container.appendChild(item);
      input.value = '';
    });

    async function loadDocDetails() {
      try {
        const res = await fetch(`/admin/document/${docId}`, { credentials: 'include' });
        if (!res.ok) {
          window.location.href = '/admin/dashboard';
          return;
        }
        const data = await res.json();
        const doc = data.document;
        if (!doc) {
          window.location.href = '/admin/dashboard';
          return;
        }

        document.getElementById('documentTitle').textContent = doc.fileName;
        document.getElementById('submittedDate').textContent = new Date(doc.createdAt).toLocaleDateString(undefined, { month: 'short', day: 'numeric', year: 'numeric' });
        document.getElementById('submittedBy').textContent = doc.userId?.username || 'Unknown';
        document.getElementById('fileSize').textContent = (doc.fileType || 'unknown').toUpperCase();
        document.getElementById('statusBadge').textContent = String(doc.status || 'pending').replace(/_/g, ' ');
        document.getElementById('statusBadge').className = `status-badge ${doc.status}`;
        document.getElementById('statusHint').textContent = String(doc.status || 'pending').replace(/_/g, ' ');
        document.getElementById('confidenceHint').textContent = `${doc.confidence || 92}% confidence`;

        const openFile = () => window.open(`/${doc.filePath}`, '_blank');
        document.getElementById('viewDocumentBtn').onclick = openFile;
        document.getElementById('previewPlaceholder').style.cursor = 'pointer';
        document.getElementById('previewPlaceholder').onclick = openFile;
        document.getElementById('drawerOpenLink');

        const summaryTextEl = document.getElementById('summaryText');
        const keywords = Array.isArray(doc.keywords) && doc.keywords.length
          ? `
            <div style="margin-top:18px;">
              <h4 class="key-points-title">Extracted keywords</h4>
              <ul class="key-points-list">
                ${doc.keywords.map(keyword => `<li>${keyword}</li>`).join('')}
              </ul>
            </div>`
          : '';
        summaryTextEl.innerHTML = `
          <p class="summary-paragraph">${doc.summary || 'No summary generated yet.'}</p>
          ${keywords}
          <div style="margin-top:18px;">
            <h4 class="entities-title">Document metadata</h4>
            <div class="entity-tags">
              <span class="entity-tag">Type: ${doc.fileType?.toUpperCase() || 'Unknown'}</span>
              <span class="entity-tag">Status: ${doc.status}</span>
            </div>
          </div>`;

        const metaTags = [doc.fileType, doc.status, ...(Array.isArray(doc.keywords) ? doc.keywords.slice(0, 3) : [])].filter(Boolean);
        document.querySelector('.history-list').insertAdjacentHTML('beforeend', `
          <div class="history-item"><strong>AI tags</strong><span>${metaTags.join(' · ')}</span></div>`);
      } catch (error) {
        console.error('Load doc details failed', error);
        window.location.href = '/admin/dashboard';
      }
    }

    function showModal(type, title, message, onConfirm) {
      const modal = document.getElementById('notificationModal');
      const iconEl = document.getElementById('modalIcon');
      const closeBtn = document.getElementById('modalCloseBtn');
      document.getElementById('modalTitle').textContent = title;
      document.getElementById('modalMessage').textContent = message;

      if (type === 'success') {
        iconEl.className = 'modal-icon success';
        iconEl.innerHTML = '<i data-feather="check-circle"></i>';
      } else {
        iconEl.className = 'modal-icon error';
        iconEl.innerHTML = '<i data-feather="alert-circle"></i>';
      }

      modal.classList.add('active');
      if (window.feather) feather.replace();

      const handleClose = () => {
        modal.classList.remove('active');
        if (onConfirm) onConfirm();
        closeBtn.removeEventListener('click', handleClose);
      };

      closeBtn.addEventListener('click', handleClose);
    }

    document.getElementById('notificationModal').addEventListener('click', event => {
      if (event.target === document.getElementById('notificationModal')) {
        document.getElementById('notificationModal').classList.remove('active');
      }
    });

    document.getElementById('approveBtn').addEventListener('click', async () => {
      try {
        const res = await fetch(`/api/approvals/${docId}/decision`, { 
          method: 'POST', 
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ action: 'approve' }),
          credentials: 'include' 
        });
        if (res.ok) {
          showModal('success', 'Document approved', 'The document has been approved and archived in the audit trail.', () => {
            window.location.href = '/approvals';
          });
        } else {
          const data = await res.json();
          showModal('error', 'Approval failed', data.message || 'Server error occurred during approval.');
        }
      } catch (error) {
        showModal('error', 'Approval failed', 'Network or server failure.');
      }
    });

    document.getElementById('rejectBtn').addEventListener('click', async () => {
      const notes = document.getElementById('decisionNotes').value.trim();
      try {
        const res = await fetch(`/api/approvals/${docId}/decision`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ action: 'reject', comments: notes }),
          credentials: 'include'
        });
        if (res.ok) {
          showModal('success', 'Document rejected', 'The document has been rejected and the submitter has been notified.', () => {
            window.location.href = '/approvals';
          });
        } else {
          const data = await res.json();
          showModal('error', 'Rejection failed', data.message || 'Server error occurred.');
        }
      } catch (error) {
        showModal('error', 'Rejection failed', 'Network or server failure.');
      }
    });

    document.getElementById('requestChangesBtn').addEventListener('click', async () => {
      const notes = document.getElementById('decisionNotes').value.trim();
      if (!notes) {
        showModal('error', 'Comment required', 'Please add a note before requesting changes.');
        return;
      }
      try {
        const res = await fetch(`/api/approvals/${docId}/decision`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ action: 'request_changes', comments: notes }),
          credentials: 'include'
        });
        if (res.ok) {
          showModal('success', 'Changes requested', 'The document owner has been notified of the requested changes.', () => {
            window.location.href = '/approvals';
          });
        } else {
          const data = await res.json();
          showModal('error', 'Request failed', data.message || 'Server error occurred.');
        }
      } catch (error) {
        showModal('error', 'Request failed', 'Network or server failure.');
      }
    });

    document.addEventListener('keydown', event => {
      if (event.key === 'Escape') {
        document.getElementById('notificationModal').classList.remove('active');
      }
    });

    if (window.feather) feather.replace();
    loadDocDetails();
    updateProgress();
  </script>
</body>
</html>
