<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>IDMS - The Intelligent Archive | Sign In</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500&family=Playfair+Display:ital,wght@0,400;0,600;1,400;1,600&family=Space+Mono&display=swap" rel="stylesheet">
    <!-- Phosphor Icons -->
    <script src="https://unpkg.com/@phosphor-icons/web"></script>
    
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                        serif: ['Playfair Display', 'serif'],
                        mono: ['Space Mono', 'monospace'],
                    },
                    colors: {
                        base: '#070707',
                        surface: '#111111',
                        border: '#222222',
                    }
                }
            }
        }
    </script>
    <style>
        body {
            background-color: #070707;
            color: #ffffff;
            overflow-x: hidden;
        }
        
        /* Custom scrollbar */
        ::-webkit-scrollbar {
            width: 8px;
        }
        ::-webkit-scrollbar-track {
            background: #070707;
        }
        ::-webkit-scrollbar-thumb {
            background: #333;
            border-radius: 4px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: #555;
        }
        
        /* Input autofill styling for dark mode */
        input:-webkit-autofill,
        input:-webkit-autofill:hover, 
        input:-webkit-autofill:focus, 
        input:-webkit-autofill:active,
        select:-webkit-autofill {
            -webkit-box-shadow: 0 0 0 30px #111111 inset !important;
            -webkit-text-fill-color: white !important;
            transition: background-color 5000s ease-in-out 0s;
        }

        /* Standardize select dropdown background in some browsers */
        select option {
            background-color: #111111;
            color: #ffffff;
        }

        /* Animations */
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .animate-fade-in {
            animation: fadeIn 0.8s ease-out forwards;
            opacity: 0;
        }
        .delay-100 { animation-delay: 100ms; }
        .delay-200 { animation-delay: 200ms; }
        .delay-300 { animation-delay: 300ms; }
    </style>
</head>
<body class="font-sans antialiased min-h-screen flex flex-col relative selection:bg-white selection:text-black">

    <!-- Canvas Background -->
    <canvas id="particleCanvas" class="fixed inset-0 z-0 pointer-events-none opacity-60"></canvas>

    <!-- Top Navigation -->
    <nav class="relative z-50 w-full flex items-center justify-between px-6 py-5 border-b border-white/5 backdrop-blur-sm">
        <div class="flex items-center gap-10">
            <!-- Logo -->
            <a href="#" class="flex items-center gap-3 group">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="text-white group-hover:scale-105 transition-transform">
                    <rect x="12" y="2" width="14" height="14" transform="rotate(45 12 2)" stroke="currentColor" stroke-width="1.5"/>
                    <rect x="12" y="8" width="5.5" height="5.5" transform="rotate(45 12 8)" fill="currentColor"/>
                </svg>
                <span class="font-mono text-lg tracking-widest text-white">IDMS</span>
            </a>
            
            <!-- Links -->
            <div class="hidden md:flex items-center gap-8 text-sm text-gray-400">
                <a href="#" class="hover:text-white transition-colors">Dashboard</a>
                <a href="#" class="hover:text-white transition-colors">Analytics</a>
                <a href="#" class="hover:text-white transition-colors">Workflows</a>
                <a href="#" class="hover:text-white transition-colors">About Us</a>
            </div>
        </div>

        <div class="flex items-center gap-6">
            <button class="text-gray-400 hover:text-white transition-colors">
                <i class="ph ph-magnifying-glass text-xl"></i>
            </button>
            <a href="#" class="text-sm text-gray-300 hover:text-white transition-colors">Register</a>
            <a href="#" class="bg-white text-black px-5 py-2 rounded text-sm font-medium hover:bg-gray-200 transition-colors">Sign in</a>
        </div>
    </nav>

    <!-- Main Content -->
    <main class="relative z-10 flex-grow flex items-center justify-center px-4 py-12">
        <div class="w-full max-w-md">
            
            <!-- Typography Header -->
            <div class="text-center mb-10 animate-fade-in">
                <p class="font-mono text-[10px] tracking-[0.3em] text-gray-500 uppercase mb-4">The Intelligent Archive</p>
                <h1 class="text-4xl md:text-5xl font-serif text-white mb-2">Welcome <span class="italic text-gray-300">Back</span></h1>
                <p class="text-sm text-gray-400 font-light mt-4 px-4">
                    Authenticate to access your intelligent archive and continue building your knowledge graph.
                </p>
            </div>

            <!-- Login Form -->
            <div class="bg-surface/80 backdrop-blur-xl border border-white/5 rounded-xl p-8 shadow-2xl animate-fade-in delay-100">
                
                <!-- Global Error / Success Messages -->
                <div id="formMessage" class="hidden mb-6 p-4 rounded text-sm flex items-start gap-3 border transition-all duration-300">
                    <i id="formMessageIcon" class="ph text-lg mt-0.5"></i>
                    <div id="formMessageText"></div>
                </div>

                <form id="loginForm" class="space-y-5" novalidate>
                    
                    <!-- Email -->
                    <div>
                        <label for="email" class="block text-xs font-mono text-gray-400 uppercase tracking-wider mb-2">Work Email</label>
                        <input type="email" id="email" name="email" required
                            class="w-full px-4 py-3 bg-base border border-border rounded text-sm text-white focus:outline-none focus:border-white focus:ring-1 focus:ring-white transition-all placeholder-gray-600"
                            placeholder="john@company.com">
                        <p class="hidden text-red-400 text-xs mt-1 font-light" id="emailError">Please enter a valid email address</p>
                    </div>

                    <!-- Role Based Access Selection -->
                    <div>
                        <label for="role" class="block text-xs font-mono text-gray-400 uppercase tracking-wider mb-2">System Role</label>
                        <div class="relative">
                            <select id="role" name="role" required
                                class="w-full px-4 py-3 bg-base border border-border rounded text-sm text-white focus:outline-none focus:border-white focus:ring-1 focus:ring-white transition-all appearance-none cursor-pointer">
                                <option value="" disabled selected class="text-gray-600">Select your access level...</option>
                                <option value="admin">Administrator (Full Access)</option>
                                <option value="editor">Editor (Upload & Synthesize)</option>
                                <option value="viewer">Viewer (Read Only)</option>
                            </select>
                            <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-4 text-gray-500">
                                <i class="ph ph-caret-down"></i>
                            </div>
                        </div>
                        <p class="hidden text-red-400 text-xs mt-1 font-light" id="roleError">Please select a system role</p>
                    </div>

                    <!-- Password -->
                    <div>
                        <div class="flex justify-between items-center mb-2">
                            <label for="password" class="block text-xs font-mono text-gray-400 uppercase tracking-wider">Password</label>
                            <a href="#" class="text-xs text-gray-500 hover:text-white transition-colors">Forgot password?</a>
                        </div>
                        <div class="relative">
                            <input type="password" id="password" name="password" required
                                class="w-full px-4 py-3 bg-base border border-border rounded text-sm text-white focus:outline-none focus:border-white focus:ring-1 focus:ring-white transition-all placeholder-gray-600 pr-10"
                                placeholder="••••••••">
                            <button type="button" id="togglePassword" class="absolute inset-y-0 right-0 pr-3 flex items-center text-gray-500 hover:text-white transition-colors focus:outline-none">
                                <i class="ph ph-eye" id="eyeIcon"></i>
                            </button>
                        </div>
                        <p class="hidden text-red-400 text-xs mt-1 font-light" id="passwordError">Please enter your password</p>
                    </div>

                    <!-- Submit Button -->
                    <button type="submit" id="submitBtn"
                        class="w-full mt-8 bg-white text-black font-medium py-3 px-4 rounded transition-all duration-300 hover:bg-gray-200 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-offset-base focus:ring-white flex justify-center items-center gap-2">
                        <span>Access Vault</span>
                        <i class="ph ph-sign-in"></i>
                    </button>
                    
                    <!-- Footer Link -->
                    <p class="text-center text-xs text-gray-600 mt-6 font-light">
                        Don't have an account? <a href="#" class="text-gray-400 hover:text-white underline decoration-gray-600 underline-offset-2 transition-colors">Register here</a>.
                    </p>
                </form>
            </div>
        </div>
    </main>

    <!-- JavaScript Logic -->
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            /* -----------------------------------------------------------
               1. Particle Canvas Background Animation
            ----------------------------------------------------------- */
            const canvas = document.getElementById('particleCanvas');
            const ctx = canvas.getContext('2d');
            
            let particles = [];
            const particleCount = 70; 
            
            function resizeCanvas() {
                canvas.width = window.innerWidth;
                canvas.height = window.innerHeight;
            }
            
            window.addEventListener('resize', resizeCanvas);
            resizeCanvas();

            class Particle {
                constructor() {
                    this.x = Math.random() * canvas.width;
                    this.y = Math.random() * canvas.height;
                    this.size = Math.random() * 3 + 1; 
                    this.speedX = Math.random() * 0.4 - 0.2;
                    this.speedY = Math.random() * -0.5 - 0.1; 
                    this.opacity = Math.random() * 0.5 + 0.1;
                }

                update() {
                    this.x += this.speedX;
                    this.y += this.speedY;

                    if (this.y < 0) this.y = canvas.height;
                    if (this.x < 0) this.x = canvas.width;
                    if (this.x > canvas.width) this.x = 0;
                }

                draw() {
                    ctx.fillStyle = `rgba(255, 255, 255, ${this.opacity})`;
                    ctx.fillRect(this.x, this.y, this.size, this.size);
                }
            }

            function initParticles() {
                particles = [];
                for (let i = 0; i < particleCount; i++) {
                    particles.push(new Particle());
                }
            }

            function animateParticles() {
                ctx.clearRect(0, 0, canvas.width, canvas.height);
                for (let i = 0; i < particles.length; i++) {
                    particles[i].update();
                    particles[i].draw();
                }
                requestAnimationFrame(animateParticles);
            }

            initParticles();
            animateParticles();

            /* -----------------------------------------------------------
               2. Form Logic & Validation
            ----------------------------------------------------------- */
            const form = document.getElementById('loginForm');
            const passwordInput = document.getElementById('password');
            const togglePasswordBtn = document.getElementById('togglePassword');
            const eyeIcon = document.getElementById('eyeIcon');
            const submitBtn = document.getElementById('submitBtn');
            const formMessage = document.getElementById('formMessage');
            
            const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
            let isPasswordVisible = false;

            // Toggle Password
            togglePasswordBtn.addEventListener('click', () => {
                isPasswordVisible = !isPasswordVisible;
                passwordInput.type = isPasswordVisible ? 'text' : 'password';
                eyeIcon.className = isPasswordVisible ? 'ph ph-eye-slash' : 'ph ph-eye';
            });

            // Toggle Error UI
            function toggleError(inputId, errorId, isValid) {
                const input = document.getElementById(inputId);
                const error = document.getElementById(errorId);
                if (!isValid) {
                    input.classList.add('border-red-500/50', 'focus:border-red-500', 'focus:ring-red-500');
                    input.classList.remove('border-border', 'focus:border-white', 'focus:ring-white');
                    error.classList.remove('hidden');
                } else {
                    input.classList.remove('border-red-500/50', 'focus:border-red-500', 'focus:ring-red-500');
                    input.classList.add('border-border', 'focus:border-white', 'focus:ring-white');
                    error.classList.add('hidden');
                }
            }

            // Submit Handler
            form.addEventListener('submit', (e) => {
                e.preventDefault();
                formMessage.classList.add('hidden');

                const email = document.getElementById('email').value.trim();
                const role = document.getElementById('role').value;
                const pwd = passwordInput.value;

                let isValid = true;
                
                const isEmailValid = emailRegex.test(email);
                toggleError('email', 'emailError', isEmailValid);
                if(!isEmailValid) isValid = false;

                const isRoleValid = role !== "";
                toggleError('role', 'roleError', isRoleValid);
                if(!isRoleValid) isValid = false;

                const isPwdValid = pwd.length > 0;
                toggleError('password', 'passwordError', isPwdValid);
                if(!isPwdValid) isValid = false;

                if (isValid) {
                    // Simulate Loading
                    submitBtn.disabled = true;
                    submitBtn.classList.add('opacity-70', 'cursor-not-allowed');
                    submitBtn.innerHTML = `<i class="ph ph-spinner animate-spin text-xl"></i> Authenticating...`;

                    setTimeout(() => {
                        // Success State
                        form.classList.add('hidden');
                        
                        formMessage.classList.remove('hidden', 'bg-red-500/10', 'text-red-400', 'border-red-500/20');
                        formMessage.classList.add('bg-white/5', 'text-white', 'border-white/10', 'p-6', 'flex-col', 'items-center', 'text-center', 'animate-fade-in');
                        
                        const displayRole = role.charAt(0).toUpperCase() + role.slice(1);

                        document.getElementById('formMessageIcon').className = 'ph-light ph-check-circle text-4xl text-white mb-2';
                        document.getElementById('formMessageText').innerHTML = `
                            <h3 class="text-xl font-serif mb-2">Authentication Successful, ${displayRole}</h3>
                            <p class="text-sm text-gray-400 font-light mb-6">Welcome back to the Vault. Redirecting to your dashboard...</p>
                            <button onclick="window.location.reload()" class="w-full px-4 py-2 bg-white text-black rounded text-sm font-medium hover:bg-gray-200 transition-colors">Go to Dashboard</button>
                        `;
                    }, 1500); 
                } else {
                    // Error State
                    formMessage.classList.remove('hidden', 'bg-white/5', 'text-white', 'border-white/10', 'flex-col', 'items-center', 'text-center');
                    formMessage.classList.add('bg-red-500/10', 'text-red-400', 'border-red-500/20');
                    document.getElementById('formMessageIcon').className = 'ph-fill ph-warning-circle text-lg mt-0.5 text-red-400';
                    document.getElementById('formMessageText').innerHTML = `Please enter valid login credentials.`;
                }
            });
        });
    </script>
</body>
</html>