<!DOCTYPE html>
<html lang="en" class="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sign In — Document Intelligence</title>
  <meta name="description" content="Sign in to the enterprise AI document management workspace.">
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/assets/css/enterprise.css">
  <script defer src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/gsap.min.js"></script>
  <script defer src="https://cdn.jsdelivr.net/npm/@studio-freight/lenis@1.0.42/bundled/lenis.min.js"></script>
  <script defer src="/assets/js/enterprise.js"></script>
</head>
<body>
  <main class="auth-shell min-h-screen py-6 lg:py-10">
    <div class="auth-grid items-stretch">
      <section class="auth-visual reveal hidden overflow-hidden rounded-[32px] p-8 lg:block">
        <div class="space-y-10">
          <div>
            <div class="hero-kicker">Enterprise Access</div>
            <h1 class="hero-title mt-6 max-w-xl leading-[0.92]">Sign in to your premium document intelligence workspace.</h1>
            <p class="hero-copy mt-5 max-w-lg text-white/70">Access approvals, OCR queues, analytics, and AI-assisted search from a calm, high-end enterprise interface.</p>
          </div>

          <div class="grid gap-4 sm:grid-cols-2">
            <div class="summary-card">
              <p class="caption">Fast workflow</p>
              <p class="text-2xl font-bold">Instant review</p>
            </div>
            <div class="summary-card">
              <p class="caption">Security</p>
              <p class="text-2xl font-bold">Role-based access</p>
            </div>
            <div class="summary-card">
              <p class="caption">AI Assistant</p>
              <p class="text-2xl font-bold">Natural search</p>
            </div>
            <div class="summary-card">
              <p class="caption">Observability</p>
              <p class="text-2xl font-bold">Live audits</p>
            </div>
          </div>

          <div class="hero-card">
            <p class="kicker mb-4">Preview</p>
            <div class="space-y-3 text-sm text-white/65">
              <div class="flex items-center justify-between rounded-2xl border border-white/8 bg-black/20 px-4 py-3"><span>Pending approvals</span><span class="badge pending">42</span></div>
              <div class="flex items-center justify-between rounded-2xl border border-white/8 bg-black/20 px-4 py-3"><span>OCR pipeline</span><span class="badge approved">Healthy</span></div>
              <div class="flex items-center justify-between rounded-2xl border border-white/8 bg-black/20 px-4 py-3"><span>AI summaries</span><span class="badge">Enabled</span></div>
            </div>
          </div>
        </div>
      </section>

      <section class="form-card reveal mx-auto w-full max-w-xl rounded-[32px] p-6 sm:p-8 lg:p-10">
        <div class="flex items-center justify-between">
          <a href="/" class="inline-flex items-center gap-2 text-white/55 transition hover:text-white">
            <i data-feather="arrow-left" class="h-4 w-4"></i>
            Back to home
          </a>
          <span class="badge">Secure sign in</span>
        </div>

        <div class="mt-10 space-y-3">
          <div class="hero-kicker">Welcome back</div>
          <h2 class="dashboard-title text-[clamp(2rem,4vw,3rem)] leading-[0.95]">Access your enterprise workspace.</h2>
          <p class="body-copy max-w-md">Continue with your secure account to manage documents, approvals, and AI workflows.</p>
        </div>

        <form id="loginForm" class="mt-10 space-y-5" action="/login" method="POST" novalidate>
          <div id="globalError" class="hidden rounded-2xl border border-[rgba(255,90,95,0.3)] bg-[rgba(255,90,95,0.08)] px-4 py-3 text-sm text-danger"></div>

          <div>
            <label for="email" class="mb-2 block text-sm font-semibold text-white/75">Email address</label>
            <input id="email" name="email" type="email" autocomplete="email" required class="input-field" placeholder="you@company.com">
            <p id="emailError" class="caption mt-2 hidden text-danger">Please enter a valid email address.</p>
          </div>

          <div>
            <div class="mb-2 flex items-center justify-between">
              <label for="password" class="block text-sm font-semibold text-white/75">Password</label>
              <a href="#" class="text-sm text-white/45 transition hover:text-white">Forgot password?</a>
            </div>
            <input id="password" name="password" type="password" autocomplete="current-password" required class="input-field" placeholder="••••••••">
            <p id="passwordError" class="caption mt-2 hidden text-danger">Password is required.</p>
          </div>

          <button type="submit" id="submitBtn" class="submit-btn magnetic w-full">
            <span class="btn-text">Sign in</span>
            <span class="spinner"></span>
          </button>
        </form>

        <div class="my-8 flex items-center gap-3">
          <span class="h-px flex-1 bg-white/8"></span>
          <span class="text-xs uppercase tracking-[0.28em] text-white/35">or continue with</span>
          <span class="h-px flex-1 bg-white/8"></span>
        </div>

        <div class="grid grid-cols-3 gap-3">
          <button class="icon-button h-12 w-full rounded-2xl" type="button" aria-label="Sign in with Google"><i data-feather="chrome"></i></button>
          <button class="icon-button h-12 w-full rounded-2xl" type="button" aria-label="Sign in with GitHub"><i data-feather="github"></i></button>
          <button class="icon-button h-12 w-full rounded-2xl" type="button" aria-label="Sign in with Microsoft"><i data-feather="grid"></i></button>
        </div>

        <p class="mt-8 text-center text-sm text-white/55">
          Don’t have an account?
          <a href="/register" class="font-semibold text-white transition hover:text-[#BFD4FF]">Create one</a>
        </p>
      </section>
    </div>
  </main>

  <script>
    if (window.feather) feather.replace();

    const form = document.getElementById('loginForm');
    const emailInput = document.getElementById('email');
    const passwordInput = document.getElementById('password');
    const submitBtn = document.getElementById('submitBtn');
    const globalError = document.getElementById('globalError');

    const validateEmail = email => /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);

    const showError = (input, errorEl) => {
      input.classList.add('error');
      errorEl.classList.remove('hidden');
    };

    const clearError = (input, errorEl) => {
      input.classList.remove('error');
      errorEl.classList.add('hidden');
    };

    emailInput.addEventListener('input', () => {
      clearError(emailInput, document.getElementById('emailError'));
      globalError.classList.add('hidden');
    });

    passwordInput.addEventListener('input', () => {
      clearError(passwordInput, document.getElementById('passwordError'));
      globalError.classList.add('hidden');
    });

    form.addEventListener('submit', event => {
      event.preventDefault();

      let valid = true;

      if (!validateEmail(emailInput.value.trim())) {
        showError(emailInput, document.getElementById('emailError'));
        valid = false;
      }

      if (!passwordInput.value.trim()) {
        showError(passwordInput, document.getElementById('passwordError'));
        valid = false;
      }

      if (!valid) return;

      submitBtn.classList.add('loading');
      submitBtn.disabled = true;

      const body = new URLSearchParams(new FormData(form)).toString();

      fetch(form.action, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/x-www-form-urlencoded',
          'Accept': 'application/json'
        },
        body
      })
      .then(async response => {
        const isJson = response.headers.get('content-type')?.includes('application/json');
        const data = isJson ? await response.json() : null;

        if (!response.ok) {
          throw new Error(data?.message || 'Invalid email or password.');
        }

        window.location.href = data?.redirect || '/dashboard';
      })
      .catch(error => {
        submitBtn.classList.remove('loading');
        submitBtn.disabled = false;
        globalError.textContent = error.message;
        globalError.classList.remove('hidden');
      });
    });
  </script>
</body>
</html>